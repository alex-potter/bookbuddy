"},{"character":"John Boone","relationship":"Colleague and fellow colonist"},{"character":"Nadia Cherneshevsky","relationship":"Traveler group member"}],"recentEvents":"Confronted Ann over her guilt and Frank's death."},{"name":"Gene","aliases":[],"importance":"main","status":"alive","lastSeen":"9","currentLocation":"Mars","description":"Brickmaker struggling with production quality and material composition.","relationships":[{"character":"Nadia","relationship":"Colleague"},{"character":"John Boone","relationship":"Close friend"}],"recentEvents":"Participated in reunion and sabotage discussions"},{"name":"Igor","aliases":[],"importance":"secondary","status":"alive","lastSeen":"2","currentLocation":"Mars","description":"Team member involved in parachute salvage and geological surveys.","relationships":[{"character":"Ann Clayborne","relationship":"Teammate"}],"recentEvents":"Participated in parachute search and thermokarst sinkhole exploration"},{"name":"Spencer Jackson","aliases":["Spencer"],"importance":"secondary","status":"alive","lastSeen":"2","currentLocation":"Elysium","description":"A scientist and friend of John Boone, involved in Martian colonization efforts.","relationships":[{"character":"Nadia","relationship":"Colleague"},{"character":"John Boone","relationship":"Friend"},{"character":"Frank Chalmers","relationship":"Colleague in treaty negotiations"}],"recentEvents":"Mentioned as builder of the 16D planes used for transportation."},{"name":"George Berkovic","aliases":[],"importance":"secondary","status":"alive","lastSeen":"4","currentLocation":"Mars","description":"Geologist and friend of Phyllis from NASA days, supportive of applied geological studies.","relationships":[{"character":"Phyllis Boyle","relationship":"Friend and colleague"}],"recentEvents":"Participated in geological surveys and discussions about mineral outcroppings."},{"name":"Edvard Perrin","aliases":["Edvard"],"importance":"main","status":"alive","lastSeen":"4","currentLocation":"Mars",
tType":"story"},{"id":"id14","title":"Praise for Kim Stanley Robinson","order":42,"preview":"Praise for Kim Stanley Robinson and Red Mars","contentType":"story"},{"id":"id13","title":"Copyright","order":43,"preview":"A Bantam Spectra Book / February 1993","contentType":"front-matter"},{"id":"id12","title":"Part 45","order":44,"preview":"Table of Contents","contentType":"story"}]},"chapterRange":{"start":1,"end":38},"parentArcs":[{"name":"Discovery of Hidden Martian Settlement","children":["Discovery of Hidden Martian Settlement"],"summary":"The group uncovers secret Martian settlements, challenging their assumptions about colonization and resistance."},{"name":"Communication and Information Control","children":["Communication and Information Control"],"summary":"Tensions arise over control of information between settlers and UNOMA, highlighting power struggles in a new society."},{"name":"Environmental Survival and Resistance","children":["Environmental Survival and Resistance"],"summary":"Surviving Mars' harsh environment reveals complex resistance strategies and the adaptability of human communities."}]},"mapState":null}
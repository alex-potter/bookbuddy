 alliance"},{"character":"Nadia","relationship":"Collaborator on farm projects"},{"character":"Sax Russell","relationship":"Colleague"},{"character":"Michel Duval","relationship":"Colleague"},{"character":"John Boone","relationship":"Longtime friend, estranged for 20 years"},{"character":"Kasei","relationship":"Parent of child involved in sabotage activities"}],"recentEvents":"Reunited with John Boone, discussed genetic experiments and sabotage network, denied involvement in sabotage"},{"name":"Ivana","aliases":[],"importance":"secondary","status":"alive","lastSeen":"1","currentLocation":"Nicosia","description":"Russian contingent member, part of the complex social dynamics.","relationships":[{"character":"Maya Toitovna","relationship":"Colleague in mission planning"}],"recentEvents":"Participated in social and scientific discussions."},{"name":"Janet Blyleven","aliases":[],"importance":"secondary","status":"alive","lastSeen":"3","currentLocation":"Ares","description":"American TV reporter, documenting the mission for public consumption.","relationships":[{"character":"Maya Toitovna","relationship":"Media contact"},{"character":"Mary Dunkel","relationship":"Romantic rival"},{"character":"Alex Zhalin","relationship":"Romantic rival"}],"recentEvents":"Participated in sexual gossip, engaged in public relationship dynamics"},{"name":"Ann Clayborne","aliases":[],"importance":"main","status":"alive","lastSeen":"1","currentLocation":"Argyre Basin","description":"A crew member involved in mission planning and discussions about Martian governance.","relationships":[{"character":"Arkady Bogdanov","relationship":"Debated on Antarctic treaty analogies"},{"character":"Simon Frazier","relationship":"Partner"}],"recentEvents":"Conducting survey in Argyre Basin; John Boone plans to visit her"},{"name":"Rya Jimenez","aliases":[],"importance":"secondary","status":"alive","lastSeen":"2","currentLocation":"Nicosia","description":"American crew member part of the room exchange with Russians.","relationships":[{"character":"Arkady Bogdanov","relationship":"Colleague"}],"recentEvents":"Participated in solar flare response, observed political debates."},{"name":"Mary Dunkel","aliases":[],"importance":"secondary","status":"alive","lastSeen":"7","currentLocation":"Mars","description":"Engineer working at Turner Wells on aquifer extraction and power generation.","relationships":[{"character":"Arkady Bogdanov","relationship":"Debater"},{"character":"Janet Blyleven","relationship":"Romantic rival"},{"character":"Alex Zhalin","relationship":"Romantic rival"},{"character":"John Boone","relationship":"Colleague"}],"recentEvents":"Capped a gushing aquifer well with John Boone's assistance, discussed seismic testing methods"},{"name":"Phyllis Boyle","aliases":[],"importance":"main","status":"alive","lastSeen":"9","currentLocation":"Mars","description":"Scientist involved in corporate consulting, part of the transnational economic network on Mars.","relationships":[{"character":"Arkady Bogdanov","relationship":"Debated wind power vs. nuclear energy"},{"character":"John Boone","relationship":"Colleague discussing space elevator feasibility"},{"character":"Ann Clayborne","relationship":"Professional rival on geological theories"},{"character":"Nadia","relationship":"Colleague and informal mentor"},{"character":"George Berkovic","relationship":"Team member"},{"character":"Sax Russell","relationship":"colleague"},{"character":"Ursula","relationship":"Friend"}],"recentEvents":"Present at gathering, involved in political discussions","import,ance":"minor"},{"name":"Ursula","aliases":[],"importance":"main","status":"alive","lastSeen":"5","currentLocation":"Mars","description":"Medical professional at Acheron, administered DNA repair treatment.","relationships":[{"character":"Vlad Taneev","relationship":"Partner"},{"character":"Phyllis Boyle","relationship":"Friend"},{"character":"John Boone","relationship":"Doctor-patient"},{"character":"Maya Toitovna","relationship":
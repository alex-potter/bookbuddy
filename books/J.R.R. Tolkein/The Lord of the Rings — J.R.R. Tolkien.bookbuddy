ollaborated in blocking the culvert"},{"character":"Pippin Took","relationship":"Companion"},{"character":"Merry Brandybuck","relationship":"Companion"}],"recentEvents":"Commented on the debate with Saruman"},{"name":"Legolas Greenleaf","aliases":["Legolas"],"importance":"main","status":"alive","lastSeen":"Chapter 10: THE VOICE OF SARUMAN","currentLocation":"Orthanc","description":"Elven archer who received a Galadhrim bow and quiver of arrows from Galadriel.","relationships":[{"character":"Thranduil","relationship":"King of Mirkwood"},{"character":"Elrond","relationship":"Advisor"},{"character":"Aragorn son of Arathorn","relationship":"Traveling companion"},{"character":"Gandalf the Grey","relationship":"Companion"},{"character":"Gimli son of Glóin","relationship":"Traveling companion"},{"character":"Frodo Baggins","relationship":"Companion"},{"character":"Gimli","relationship":"Companion and friend"},{"character":"Galadriel","relationship":"Recipient of a bow and quiver"},{"character":"Aragorn","relationship":"Allied warrior"},{"character":"Háma","relationship":"Gave his weapons to"},{"character":"Éomer","relationship":"Comrade"},{"character":"Gandalf the White","relationship":"Allied"},{"character":"Pippin Took","relationship":"Companion"},{"character":"Merry Brandybuck","relationship":"Companion"},{"character":"Treebeard","relationship":"Allied with"}],"recentEvents":"Met Treebeard and Ents, discussed Fangorn Forest"},{"name":"Erestor","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter 2: THE COUNCIL OF ELROND","currentLocation":"Rivendell","description":"Elven scholar and advisor, part of the Council.","relationships":[{"character":"Elrond","relationship":"Allied"}],"recentEvents":"Participated in debates about the Ring's fate."},{"name":"Galdor of the Havens","aliases":["Galdor"],"importance":"secondary","status":"alive","lastSeen":"Chapter 2: THE COUNCIL OF ELROND","currentLocation":"Rivendell","description":"Elven lord from the Havens
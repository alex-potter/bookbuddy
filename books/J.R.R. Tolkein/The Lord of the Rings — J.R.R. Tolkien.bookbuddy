:[{"character":"Frodo Baggins","relationship":"Rescuer of"},{"character":"Sam Gamgee","relationship":"Rescuer of"},{"character":"Goldberry","relationship":"Spouse"},{"character":"Farmer Maggot","relationship":"Informant"},{"character":"Gildor Inglorion","relationship":"Contact"},{"character":"Pippin Took","relationship":"Rescuer of"},{"character":"Merry Brandybuck","relationship":"Rescuer of"}],"recentEvents":"Rescued Frodo, Sam, Pippin, and Merry from Barrow-wights, defeated a Barrow-wight"},{"name":"Old Man Willow","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter 7: IN THE HOUSE OF TOM BOMBADIL","currentLocation":"Old Forest","description":"A sentient willow tree with a cunning and malevolent nature, feared by the forest creatures.","relationships":[{"character":"Tom Bombadil","relationship":"Antagonist"}],"recentEvents":"Discussed by Tom Bombadil as a dangerous entity in the forest."},{"name":"Goldberry","aliases":["River-daughter"],"importance":"main","status":"alive","lastSeen":"Chapter 7: IN THE HOUSE OF TOM BOMBADIL","currentLocation":"Old Forest","description":"Daughter of the River, wife of Tom Bombadil, and a figure of serene beauty and mystery.","relationships":[{"character":"Tom Bombadil","relationship":"Spouse"}],"recentEvents":"Sang songs to Frodo and Sam, prepared food, and assisted in setting the table."},{"name":"Barrow-wight","aliases":[],"importance":"main","status":"alive","lastSeen":"Chapter 8: FOG ON THE BARROW-DOWNS","currentLocation":"Barrow-downs","description":"Malevolent spirit that captured the hobbits and was defeated by Tom Bombadil","relationships":[{"character":"Tom Bombadil","relationship":"Defeated by"}],"recentEvents":"Captured Frodo, Sam, Pippin, and Merry; defeated by Tom Bombadil"},{"name":"Nob","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter 10: STRIDER","currentLocation":"Bree","description":"Member of the Butterbur family, helped set up disguises","relationships":[{"character":"Barliman Butterbur","relationship":"Servant"},{"character":"The Butterbur Family","relationship":"Part of"}],"recentEvents":"Assisted in preparing disguises and reported on Black Riders' movements"},{"name":"Gatekeeper","aliases":[],"importance":"minor","status":"alive","lastSeen":"Chapter 9: AT THE SIGN OF THE PRANCING PONY","currentLocation":"Bree","description":"Guardian of the West-gate of Bree","relationships":[],"recentEvents":"Checked the hobbits' credentials and allowed them entry"},{"name":"Bill the pony","aliases":["Bill Ferny"],"importance":"secondary","status":"alive","lastSeen":"Chapter 4: A JOURNEY IN THE DARK","currentLocation":"Near the lake","description":"A man in Bree who sold a pony to the group at an inflated price.","relationships":[],"recentEvents":"Trembled and sweated during the journey, part of the group's survival against wolves and Wargs"},{"name":"Glorfindel","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter 2: THE COUNCIL OF ELROND","currentLocation":"Rivendell","description":"Elven lord and warrior, advocate for the Ring's destruction.","relationships":[{"character":"Frodo Baggins","relationship":"Rescuer"},{"character":"Strider","relationship":"Allied warrior"},{"character":"Elrond","relationship":"Lord and companion"},{"character":"Aragorn","relationship":"Allied warrior"}],"recentEvents":"Argued for the Ring's destruction to prevent Sauron's return."},{"name":"Elrond","aliases":[],"importance":"main","status":"alive","lastSeen":"Chapter 3: THE RING GOES SOUTH","currentLocation":"High moor","description":"Elven lord and leader of the Council, advocate for the Ring's destruction.","relationships":[{"character":"Frodo Baggins","relationship":"Patient"},{"character":"Glorfindel","relationship":"Lord and companion"},{"character":"Arwen","relationship":"Spouse"},{"character":"Aragorn","relationship":"Allied"},{"character":"Gandalf the Grey","relationship":"Respected advisor"},{"character":"Galadriel","relatio
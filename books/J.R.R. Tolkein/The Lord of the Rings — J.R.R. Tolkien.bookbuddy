ationship":"Father"},{"character":"Bilbo Baggins","relationship":"Friend"},{"character":"Frodo Baggins","relationship":"Travel companion and loyal friend"},{"character":"Pippin Took","relationship":"Companion and friend"},{"character":"Fro, Baggins","relationship":"Traveling companion"},{"character":"Tom Bombadil","relationship":"Rescued by"},{"character":"Goldberry","relationship":"Guest"},{"character":"Strider","relationship":"Suspicious of"},{"character":"Merry Brandybuck","relationship":"Companion"},{"character":"Gandalf the Grey","relationship":"Mentor"},{"character":"Frodo","relationship":"Companion and friend"},{"character":"Galadriel","relationship":"Visited by Galadriel in her realm"},{"character":"Aragorn son of Arathorn","relationship":"Leader of the Company"},{"character":"Gollum","relationship":"Suspicious of Gollum's true intentions but forced to rely on him"},{"character":"Faramir","relationship":"Captured by soldiers"}],"recentEvents":"Stumbled upon fire incident, witnessed battle with Southrons and Mûmak"},{"name":"Old Noakes","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter 1: A LONG-EXPECTED PARTY","currentLocation":"Bywater","description":"Hobbit from Bywater who discussed rumors about Frodo's family.","relationships":[],"recentEvents":"Commented on Frodo's Brandybuck heritage and Bilbo's wealth."},{"name":"Daddy Twofoot","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter 1: A LONG-EXPECTED PARTY","currentLocation":"Bywater","description":"Neighbor of the Gaffer, known for his opinions on local matters.","relationships":[{"character":"Ham Gamgee","relationship":"Neighbor"}],"recentEvents":"Spoke about the Brandybucks and their connection to the Old Forest."},{"name":"Stranger from Michel Delving","aliases":[],"importance":"minor","status":"alive","lastSeen":"Chapter 1: A LONG-EXPECTED PARTY","currentLocation":"Michel Delving","description":"Visitor from the Westfarthing who speculated about Bilbo's treasure.","relationships":[],"recentEvents":"Talked about Bilbo's rumored tunnels and wealth."},{"name":"Sackville-Bagginses","aliases":[],"importance":"secondary","status":"unknown","lastSeen":"Chapter 1: A LONG-EXPECTED PARTY","currentLocation":"Unknown","description":"Family of hobbits who scowled at Bilbo's announcement.","relationships":[],"recentEvents":"Departed in wrath after Bilbo's disappearance."},{"name":"Old Odo Proudfoot","aliases":[],"importance":"minor","status":"alive","lastSeen":"Chapter 1: A LONG-EXPECTED PARTY","currentLocation":"Unknown","description":"Hobbit with large, furry feet who commented on Bilbo's disappearance.","relationships":[],"recentEvents":"Suspected Bilbo's disappearance was not a prank."},{"name":"Adelard Took","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter 1: A LONG-EXPECTED PARTY","currentLocation":"Unknown","description":"Recipient of an umbrella labeled 'For Adelard Took, for his VERY OWN, from Bilbo'.","relationships":[],"recentEvents":"Received an umbrella from Bilbo's estate."},{"name":"Dora Baggins","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter 1: A LONG-EXPECTED PARTY","currentLocation":"Unknown","description":"Drogo’s sister and the eldest surviving female relative of Bilbo and Frodo; ninety-nine years old.","relationships":[],"recentEvents":"Received a waste-paper basket labeled 'For Dora Baggins in memory of a LONG correspondence'."},{"name":"Milo Burrows","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter 1: A LONG-EXPECTED PARTY","currentLocation":"Unknown","description":"Recipient of a gold pen and ink-bottle labeled 'For Milo Burrows, hoping it will be useful, from B.B'.","relationships":[],"recentEvents":"Received a gold pen and ink-bottle from Bilbo's estate."},{"name":"Angelica","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter 1: A LONG-EXPECTED PARTY","currentLocation":"Unknown","description":"A young Baggins who received a round convex mirror labeled 'For Angelica’s use, from Uncle Bilbo'.","relationships":[],"recentEvents":"Received a mirror from Bilbo's estate."},{"name":"Hugo Bracegirdle","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter 1: A LONG-EXPECTED PARTY","currentLocation":"Unknown","description":"A collector of books who received an empty book-case labeled 'For the collection of Hugo Bracegirdle'.","relationships":[],"recentEvents":"Received an empty book-case from Bilbo's estate."},{"name":"Lobelia Sackville-Baggins","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter 1: A LONG-EXPECTED PARTY","currentLocation":"Unknown","description":"Bilbo’s relative who took silver spoons labeled 'For Lobelia Sackville-Baggins, as a PRESENT'.","relationships":[],"recentEvents":"Argued with Frodo over spoons and left with them."},{"name":"Otho Sackville-Baggins","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter 1: A LONG-EXPECTED PARTY","currentLocation":"Unknown","description":"Bilbo’s heir (before Frodo’s adoption) who demanded to see Frodo’s will.","relationships":[],"recentEvents":"Argued with Frodo over the will and left in frustration."},{"name":"Sancho Proudfoot","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter 1: A LONG-EXPECTED PARTY","currentLocation":"Unknown","description":"Old Odo Proudfoot’s grandson who excavated the pantry seeking Bilbo’s gold.","relationships":[],"recentEvents":"Attempted to excavate the pantry and was ejected by Frodo."},{"name":"Merry Brandybuck","aliases":["Master of Buckland","Merry"],"importance":"main","status":"alive","lastSeen":"Chapter 11: THE PALANTÍR","currentLocation":"En route to Helm’s Deep","description":"A hobbit who joined the company of the Ring and was presumed lost but was found feasting in Isengard","relationships":[{"character":"Frodo Baggins","relationship":"Friend and companion"},{"character":"Pippin Took","
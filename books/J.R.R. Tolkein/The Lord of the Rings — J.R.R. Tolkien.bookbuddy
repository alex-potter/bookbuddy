m Isengard.","relationships":[{"character":"Gandalf the Grey","relationship":"Rescuer"}],"recentEvents":"Brought Gandalf to safety after his capture by Saruman."},{"name":"Shadowfax","aliases":[],"importance":"main","status":"alive","lastSeen":"Chapter 7: HELM’S DEEP","currentLocation":"Helm’s Deep","description":"Legendary horse of Rohan, ridden by Gandalf to the Shire.","relationships":[{"character":"Gandalf the Grey","relationship":"Rider"},{"character":"Aragorn son of Arathorn","relationship":"Companion"},{"character":"Théoden son of Thengel","relationship":"Companion"}],"recentEvents":"Ran alongside Aragorn and the Riders during the final charge"},{"name":"Haldir","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter 8: FAREWELL TO LÓRIEN","currentLocation":"Lothlórien","description":"Elven guard of Lothlórien, guided the Company to Caras Galadhon.","relationships":[{"character":"Legolas","relationship":"Elven kin"},{"character":"Rúmil","relationship":"Elven companion"},{"character":"Orophin","relationship":"Elven companion"},{"character":"Gimli son of Glóin","relationship":"Guide"},{"character":"Aragorn son of Arathorn","relationship":"Guide"},{"character":"Frodo Baggins","relationship":"Guide"},{"character":"Celeborn","relationship":"Companion"}],"recentEvents":"Guided the Company out of Lothlórien, spoke of the dangers ahead"},{"name":"Rúmil","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter 6: LOTHLÓRIEN","currentLocation":"Lothlórien","description":"Elven guard of Lórien, part of the Galadhrim","relationships":[{"character":"Haldir","relationship":"Elven companion"}],"recentEvents":"Assisted in guarding the Company, crossed the river with ropes, and discussed the Company's journey"},{"name":"Orophin","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter 6: LOTHLÓRIEN","currentLocation":"Lothlórien","description":"Elven guard of Lórien, part of the Galadhrim","relationships":[{"character":"H
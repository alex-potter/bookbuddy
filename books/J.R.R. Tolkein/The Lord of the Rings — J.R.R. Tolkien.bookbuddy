rrentLocation":"Unknown","description":"Family of hobbits who scowled at Bilbo's announcement.","relationships":[],"recentEvents":"Departed in wrath after Bilbo's disappearance."},{"name":"Old Odo Proudfoot","aliases":[],"importance":"minor","status":"alive","lastSeen":"Chapter 1: A LONG-EXPECTED PARTY","currentLocation":"Unknown","description":"Hobbit with large, furry feet who commented on Bilbo's disappearance.","relationships":[],"recentEvents":"Suspected Bilbo's disappearance was not a prank."},{"name":"Adelard Took","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter 1: A LONG-EXPECTED PARTY","currentLocation":"Unknown","description":"Recipient of an umbrella labeled 'For Adelard Took, for his VERY OWN, from Bilbo'.","relationships":[],"recentEvents":"Received an umbrella from Bilbo's estate."},{"name":"Dora Baggins","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter 1: A LONG-EXPECTED PARTY","currentLocation":"Unknown","description":"Drogo’s sister and the eldest surviving female relative of Bilbo and Frodo; ninety-nine years old.","relationships":[],"recentEvents":"Received a waste-paper basket labeled 'For Dora Baggins in memory of a LONG correspondence'."},{"name":"Milo Burrows","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter 1: A LONG-EXPECTED PARTY","currentLocation":"Unknown","description":"Recipient of a gold pen and ink-bottle labeled 'For Milo Burrows, hoping it will be useful, from B.B'.","relationships":[],"recentEvents":"Received a gold pen and ink-bottle from Bilbo's estate."},{"name":"Angelica","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter 1: A LONG-EXPECTED PARTY","currentLocation":"Unknown","description":"A young Baggins who received a round convex mirror labeled 'For Angelica’s use, from Uncle Bilbo'.","relationships":[],"recentEvents":"Received a mirror from Bilbo's estate."},{"name":"Hugo Bracegirdle","aliases":[],"importance":"secondary",
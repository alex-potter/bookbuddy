ter 8: THE SCOURING OF THE SHIRE","order":70,"bookIndex":0,"bookTitle":"Part 2"},{"id":"chap-62","title":"Chapter 9: THE GREY HAVENS","order":71,"bookIndex":0,"bookTitle":"Part 2"},{"id":"appe-1","title":"APPENDIX A: ANNALS OF THE KINGS AND RULERS","order":72,"bookIndex":0,"bookTitle":"Part 2"},{"id":"appe-2","title":"APPENDIX B: THE TALE OF YEARS","order":73,"bookIndex":0,"bookTitle":"Part 2"},{"id":"appe-3","title":"APPENDIX C: FAMILY TREES","order":74,"bookIndex":0,"bookTitle":"Part 2"},{"id":"appe-4","title":"APPENDIX D: SHIRE CALENDAR FOR USE IN ALL YEARS","order":75,"bookIndex":0,"bookTitle":"Part 2"},{"id":"appe-5","title":"APPENDIX E: WRITING AND SPELLING","order":76,"bookIndex":0,"bookTitle":"Part 2"},{"id":"appe-6","title":"APPENDIX F","order":77,"bookIndex":0,"bookTitle":"Part 2"},{"id":"index","title":"INDEX","order":78,"bookIndex":0,"bookTitle":"Part 2"},{"id":"adca-1","title":"Works by J.R.R. Tolkien","order":79,"bookIndex":0,"bookTitle":"Part 2"},{"id":"copyright","title":"Copyright","order":80,"bookIndex":0,"bookTitle":"Part 2"},{"id":"foot-1","title":"Part 82","order":81,"bookIndex":1,"bookTitle":"Part 82"}],"books":["Part 2","Part 82"]}},"mapState":null}
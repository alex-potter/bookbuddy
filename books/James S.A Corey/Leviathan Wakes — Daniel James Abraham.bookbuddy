ain Theresa Yao","relationship":"Debriefed by Martian naval officer"},{"character":"Kelly","relationship":"Crewmate (deceased)"},{"character":"Fred Johnson","relationship":"Business associate"},{"character":"Detective Miller","relationship":"Accompanied by Miller during the investigation"}],"recentEvents":"Discussed Protogen's presentation about the protomolecule and its potential dangers."},{"name":"Naomi Nagata","aliases":["Naomi"],"importance":"main","status":"alive","lastSeen":"Chapter Thirty-Four: Miller","currentLocation":"Rocinante","description":"Medical officer who tends to Miller and Holden. Engages in a tense conversation with Holden about his feelings for her.","relationships":[{"character":"Jim Holden","relationship":"Commander and romantic interest"},{"character":"Amos Burton","relationship":"Subordinate"},{"character":"Alex Kamal","relationship":"Crew member"},{"character":"Kelly","relationship":"Crewmate (deceased)"},{"character":"Fred Johnson","relationship":"Business associate"},{"character":"Detective Miller","relationship":"Fought alongside during ambush"}],"recentEvents":"Notified Holden about potential discoveries related to the protomolecule."},{"name":"Amos Burton","aliases":["Amos"],"importance":"main","status":"alive","lastSeen":"Chapter Thirty-Four: Miller","currentLocation":"Rocinante","description":"Earthborn assistant to Naomi Nagata. Known for his loud personality and loyalty to Naomi.","relationships":[{"character":"Naomi Nagata","relationship":"Subordinate"},{"character":"Jim Holden","relationship":"Companion on the mission"},{"character":"Alex Kamal","relationship":"Crew member"},{"character":"Fred Johnson","relationship":"Business associate"},{"character":"Detective Miller","relationship":"Fought alongside during ambush"}],"recentEvents":"Diagnosed the dead ship's reactor, warned of radiation exposure"},{"name":"Shed Garvey","aliases":["Shed"],"importance":"secondary","status":"dead","lastSeen":"Chapter Eleven: Holden","currentLocation":"Donnager","description":"Medical tech responsible for treating injured crew members. Known for using medical maggots in procedures.","relationships":[{"character":"Cameron Paj","relationship":"Patient"},{"character":"Jim Holden","relationship":"Crew member"},{"character":"Naomi Nagata","relationship":"Crew member"},{"character":"Alex Kamal","relationship":"Crew member"}],"recentEvents":"Mentioned by Holden as someone he wished was still alive."},{"name":"Cameron Paj","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter Five: Holden","currentLocation":"Knight","description":"Crew member who lost his left arm in an ice-related accident. Uses a prosthetic limb.","relationships":[{"character":"Shed Garvey","relationship":"Crewmate"}],"recentEvents":"Implied to have an injured arm, mentioned by Shed during the aftermath."},{"name":"Ade Tukunbo","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter Five: Holden","currentLocation":"Knight","description":"Navigator with a Nigerian accent and a fondness for music. Has a flirtatious relationship with Holden.","relationships":[{"character":"Jim Holden","relationship":"Romantic interest"}],"recentEvents":"Attempted to power up the Knight's drive, survived the nuke blast, communicated with Holden during the crisis."},{"name":"Rebecca Byers","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter One: Holden","currentLocation":"Canterbury","description":"Comm officer with a sharp appearance and a history of legal troubles. Handles emergency communications.","relationships":[{"character":"Captain McDowell","relationship":"Subordinate"}],"recentEvents":"Received and relayed the emergency signal from an unknown ship."},{"name":"Captain McDowell","aliases":[],"importance":"main","status":"alive","lastSeen":"Chapter Five: Holden","currentLocation":"Knight","description":"Commanding officer of the Canterbury. A grizzled veteran with a distrust of corrective surgery.","relationships":[{"character":"Jim Holden","relationship":"Former subordinate"}],"recentEvents":"Gave Holden instructions for the broadcast operation"},{"name":"Detective Miller","aliases":["Miller"],"importance":"main","status":"alive","lastSeen":"Chapter Thirty-Four: Miller","currentLocation":"Rocinante","description":"Experienced security officer with a troubled past, investigating Julie Mao's disappearance while navigating political tensions between Mars, the Belt, and Earth.","relationships":[{"character":"Dmitri Havelock","relationship":"Partner"},{"character":"Captain Shaddid","relationship":"Superior"},{"character":"Juliette Andromeda Mao","relationship":"OPA contact"},{"character":"Havelock","relationship":"Partner who covers for Miller's absence"},{"character":"Octavia Muss","relationship":"Partner"},{"character":"Julie Mao","relationship":"Subject of investigation"},{"character":"Muss","relationship":"Partner"},{"character":"Shaddid","relationship":"Superior"},{"character":"Dawes","relationship":"Colleague"},{"character":"Inspector Sematimba","relationship":"Contacted for police assistance"},{"character":"Jim Holden","relationship":"Partner in investigating the station's crisis"},{"character":"Naomi Nagata","relationship":"Collaborated on the investigation"},{"character":"Sematimba","relationship":"Contacted police"},{"character":"Amos Burton","relationship":"Team member"}],"recentEvents":"Analyzed Protogen's presentation and warned about the protomolecule's risks."},{"name":"Captain Shaddid","aliases":["Shaddid"],"importance":"main","status":"alive","lastSeen":"Chapter Sixteen: Miller","currentLocation":"Ceres Station","description":"Commander of Star Helix Security on Ceres, known for her pragmatic approach and disdain for inner planet residents.","relationships":[{"character":"Miller","relationship":"Subordinate"},{"character":"Julie Mao","relationship":"Client"},{"character":"Detective Miller","relationship":"Superior"}],"recentEvents":"Reassigned Miller from the Mao case, emphasized Star Helix's neutrality in Martian conflicts."},{"name":"Alex Kamal","aliases":["Alex"],"importance":"main","status":"alive","lastSeen":"Chapter Thirty-Four: Miller","currentLocation":"Rocinante","description":"Crewmate and engineer, skeptical of Martian involvement in the Canterbury's destruction.","relationships":[{"character":"Jim Holden","relationship":"Companion on the mission"},{"character":"Naomi Nagata","relationship":"Crew member"},{"character":"Amos Burton","relationship":"Crew member"},{"character":"Shed Garvey","relationship":"Crew member"},{"character":"Kelly","relationship":"Crewmate (deceased)"},{"character":"Fred Johnson","relationship":"Business associate"}],"recentEvents":"Assisted with reactor diagnostics, confirmed the ship's security override status"},{"name":"Dmitri Havelock","aliases":["Havelock"],"importance":"main","status":"alive","lastSeen":"Chapter Twelve: Miller","currentLocation":"Ceres","description":"Miller's partner and fellow security officer, who agrees to cover for Miller's absence while he investigates Julie Mao's case.","relationships":[{"character":"Detective Miller","relationship":"Partner"},{"character":"Miller","relationship":"Partner who covers for Miller's absence"},{"character":"Captain Shaddid","relationship":"Superior"}],"recentEvents":"Agreed to take sick leave to avoid potential conflict, supporting Miller's decision to continue the investigation despite OPA warnings."},{"name":"Hasini","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter Sixteen: Miller","currentLocation":"Blue Frog (Ceres Station)","description":"Assistant manager of the Blue Frog, a portside bar on Ceres, who interacted with Detective Miller.","relationships":[{"character":"Detective Miller","relationship":"Informal acquaintance"}],"recentEvents":"Accompanied Miller home after a drinking session, revealed his feelings for Julie Mao."},{"name":"Brown","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter Six: Miller","currentLocation":"Ceres","description":"Security officer with SWAT experience, leading crowd control wings.","relationships":[],"recentEvents":"Part of Miller's riot squad, led during the mob confrontation."},{"name":"Gelbfish","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter Six: Miller","currentLocation":"Ceres","description":"Security officer with SWAT experience, part of Miller's team.","relationships":[],"recentEvents":"Identified the shirtless man's OPA tattoo, participated in crowd control."},{"name":"Aberforth","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter Six: Miller","currentLocation":"Ceres","description":"Security officer with a history of excessive violence, placed in second-string role.","relationships":[],"recentEvents":"Assigned to secondary roles due to past disciplinary issues."},{"name":"Yevgeny","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter Six: Miller","currentLocation":"Ceres","description":"Homicide detective who commented on government offices during the crisis.","relationships":[],"recentEvents":"Mentioned the government's infrastructure status during Shaddid's briefing."},{"name":"Shirtless Man","aliases":[],"importance":"minor","status":"alive","lastSeen":"Chapter Eight: Miller","currentLocation":"Ceres","description":"A former suspect in a crime, now in Star Helix detainment infirmary preparing for trial.","relationships":[],"recentEvents":"Mentioned in context of Ceres Station's ongoing legal cases"},{"name":"OPA Man","aliases":[],"importance":"minor","status":"alive","lastSeen":"Chapter Ten: Miller","currentLocation":"Ceres","description":"An OPA representative with a pock-marked face, engaged in a tense conversation with Miller about OPA's role.","relationships":[{"character":"Detective Miller","relationship":"OPA contact"}],"recentEvents":"Discussed OPA's economic terrorism claims, denied involvement in Mateo Judd's death, and warned Miller to stay away."},{"name":"Wallace Fitz","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter Seven: Holden","currentLocation":"Saturn Station","description":"P and K legal counsel who issued formal orders to Holden and his crew.","relationships":[{"character":"Jim Holden","relationship":"Legal contact"}],"recentEvents":"Delivered official response to Holden's request for assistance, accused Holden of unfounded Martian accusations."},{"name":"Captain Theresa Yao","aliases":[],"importance":"main","status":"alive","lastSeen":"Chapter Eleven: Holden","currentLocation":"Donnager","description":"Commander of the Donnager, a Martian capital ship, overseeing the interrogation of Holden's crew.","relationships":[{"character":"Jim Holden","relationship":"Debriefed by Martian naval officer"}],"recentEvents":"Ordered the torpedo launch against the Belt ships and interrogated Holden about the pursuing vessels."},{"name":"Masked Woman","aliases":["Woman"],"importance":"minor","status":"alive","lastSeen":"Chapter Eight: Miller","currentLocation":"Ceres","description":"Victim beaten to death by the shirtless man, identified as a Martian freight line employee.","relationships":[],"recentEvents":"Featured in Miller's terminal screen as part of OPA propaganda"},{"name":"Fred Johnson","aliases":[],"importance":"main","status":"alive","lastSeen":"Chapter Twenty-One: Holden","currentLocation":"Tycho Station","description":"Colonel and leader of the Outer Planets Alliance, contacting Holden about potential Martian threats.","relationships":[{"character":"Jim Holden","relationship":"Communications contact"},{"character":"Naomi Nagata","relationship":"Business associate"},{"character":"Amos Burton","relationship":"Business associate"},{"character":"Alex Kamal","relationship":"Business associate"}],"recentEvents":"Negotiated the use of the Rocinante for an Eros mission, revealed the fictional Lionel Polanski, and discussed the data cube."},{"name":"Mateo Judd","aliases":[],"importance":"main","status":"dead","lastSeen":"Chapter Ten: Miller","currentLocation":"Ceres","description":"A dockworker accused of running an extortion scheme, later found dead with OPA ties.","relationships":[{"character":"Asher Kamamatsu","relationship":"Client"}],"recentEvents":"Sought protection from the OPA, was killed by OPA operatives after Miller's investigation."},{"name":"Lieutenant Lopez","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter Eleven: Holden","currentLocation":"Donnager","description":"Naval intelligence officer conducting an interrogation of Holden, using focus drugs to monitor his responses.","relationships":[{"character":"Jim Holden","relationship":"Interrogated by naval intelligence"}],"recentEvents":"Conducted a detailed interrogation of Holden, discussed the political tensions between Mars and the Belt, and fled to the combat zone after the torpedo attack."},{"name":"Chief Gunderson","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter Eleven: Holden","currentLocation":"Donnager","description":"Martian military chief responsible for escorting Holden's crew to their quarters.","relationships":[{"character":"Jim Holden","relationship":"Escorted to quarters"}],"recentEvents":"Led Holden's crew to their temporary accommodations and coordinated with Lieutenant Kelly for their protection."},{"name":"Anderson Dawes","aliases":["Dawes"],"importance":"main","status":"alive","lastSeen":"Chapter Sixteen: Miller","currentLocation":"Ceres Station","description":"OPA liaison who approaches Detective Miller to stop his investigation into Julie Mao's disappearance, claiming it could escalate tensions between Mars and the Belt.","relationships":[{"character":"Detective Miller","relationship":"OPA agent attempting to dissuade Miller from pursuing a kidnapping case"}],"recentEvents":"Argued against Miller's investigation, claimed Holden's capture, and emphasized corporate neutrality."},{"name":"The Jiu Jitsu Instructor","aliases":[],"importance":"minor","status":"alive","lastSeen":"Chapter Twelve: Miller","currentLocation":"Ceres","description":"Owner of the Ceres Center for Jiu Jitsu, who provides limited information about Julie Mao's background and training.","relationships":[]},{"name":"Enrique Dos Santos","aliases":[],"importance":"minor","status":"dead","lastSeen":"Chapter Fourteen: Miller","currentLocation":"Ceres","description":"","relationships":[],"recentEvents":"Tortured and displayed near sector eleven's water reclamation works; identified by terminal, wedding ring, and credit data"},{"name":"Octavia Muss","aliases":["Muss"],"importance":"secondary","status":"alive","lastSeen":"Chapter Eighteen: Miller","currentLocation":"Ceres Station","description":"A pragmatic detective who handles interrogations and provides Miller with critical case updates.","relationships":[{"character":"Detective Miller","relationship":"Colleague"},{"character":"Miller","relationship":"Partner"},{"character":"Shaddid","relationship":"Superior"}],"recentEvents":"Provided Miller with a rape case witness detail, skipped work to attend to a stop, and observed the political upheaval on Ceres."},{"name":"Kelly","aliases":["Lieutenant Kelly"],"importance":"main","status":"dead","lastSeen":"Chapter Fifteen: Holden","currentLocation":"Tachi","description":"Deceased marine who died during the battle on the Donnager.","relationships":[{"character":"Jim Holden","relationship":"Crewmate"},{"character":"Alex Kamal","relationship":"Crewmate"}],"recentEvents":"Died from severe injuries during the battle, then buried by the crew."},{"name":"Gomez","aliases":[],"importance":"secondary","status":"dead","lastSeen":"Chapter Fifteen: Holden","currentLocation":"Unknown","description":"Marine who died during the battle on the Donnager.","relationships":[{"character":"Jim Holden","relationship":"Crewmate"}],"recentEvents":"Killed by enemy fire while defending the Donnager."},{"name":"Immanuel Corvus Dowd","aliases":[],"importance":"main","status":"alive","lastSeen":"Chapter Eighteen: Miller","currentLocation":"Ceres Station detention cells","description":"A businessman arrested for rape, portrayed as a high-profile client with connections to influential war effort figures.","relationships":[{"character":"Harry","relationship":"Lawyer"}],"recentEvents":"Detained under a warrant following a rape investigation, confronted by Detective Miller, and subjected to legal scrutiny."},{"name":"Harry","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter Eighteen: Miller","currentLocation":"Ceres Station","description":"Immanuel Corvus Dowd's lawyer, who warns Miller of potential legal repercussions for his investigation.","relationships":[{"character":"Immanuel Corvus Dowd","relationship":"Client"}],"recentEvents":"Attempted to shield his client from arrest, engaged in tense dialogue with Miller, and exited the interrogation room."},{"name":"Young Woman in Cream-Colored Linen","aliases":[],"importance":"minor","status":"unknown","lastSeen":"Chapter Eighteen: Miller","currentLocation":"Ceres Station","description":"A professional-looking woman who briefly acknowledged Miller before entering the accountancy office.","relationships":[],"recentEvents":"Nodded to Miller as he left the accountancy office, displaying a calm, fighter-like demeanor."},{"name":"Bartender","aliases":[],"importance":"minor","status":"alive","lastSeen":"Chapter Nineteen: Holden","currentLocation":"Tycho Station","relationships":[]},{"name":"Singer","aliases":[],"importance":"minor","status":"alive","lastSeen":"Chapter Nineteen: Holden","currentLocation":"Tycho Station","relationships":[]},{"name":"Teenage Girls","aliases":[],"importance":"minor","status":"alive","lastSeen":"Chapter Nineteen: Holden","currentLocation":"Tycho Station","relationships":[]},{"name":"Lionel Polanski","aliases":[],"importance":"secondary","status":"unknown","lastSeen":"Chapter Twenty-Three: Holden","currentLocation":"Eros hotel room","description":"A fictional person Fred Johnson claims to need retrieved from Eros, owning the courier ship Scopuli.","relationships":[{"character":"Fred Johnson","relationship":"Target of retrieval"}],"recentEvents":"Targeted by Holden's group, last seen in his hotel room."},{"name":"Missionary","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter Twenty-Two: Miller","currentLocation":"Eros","description":"A traveling missionary with a name tag and Bible","relationships":[],"recentEvents":"Engaging in philosophical conversation about religion and war with Miller"},{"name":"Inspector Sematimba","aliases":["Sematimba"],"importance":"secondary","status":"alive","lastSeen":"Chapter Twenty-Six: Miller","currentLocation":"Eros flophouse","description":"Police officer who imposed a lockdown on Holden's ship.","relationships":[{"character":"Detective Miller","relationship":"Contacted for police assistance"},{"character":"Jim Holden","relationship":"Enforced lockdown"}],"recentEvents":"Imposed a lockdown on Holden's ship, communicated with Miller about jurisdictional concerns."},{"name":"Woman with the gun","aliases":[],"importance":"minor","status":"dead","lastSeen":"Chapter Twenty-Three: Holden","currentLocation":"Eros flophouse","description":"Armed assailant who confronted Holden's group.","relationships":[],"recentEvents":"Shot and killed during the confrontation at Lionel Polanski's flophouse."},{"name":"Guard","aliases":[],"importance":"minor","status":"alive","lastSeen":"Chapter Twenty-Seven: Holden","currentLocation":"Eros station","description":"A fake riot cop leading civilians to a radiation shelter.","relationships":[],"recentEvents":"Nudged by Miller after the shootout."},{"name":"Gabby Smalls","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter Twenty-Seven: Holden","currentLocation":"Ceres","description":"A mobster and police riot gear supervisor on Ceres, leading civilians to shelters.","relationships":[],"recentEvents":"Mentioned as a key figure in the Ceres protection racket."},{"name":"Mikey Ko","aliases":[],"importance":"secondary","status":"dead","lastSeen":"Chapter Twenty-Eight: Miller","currentLocation":"Eros station","description":"A guard who mistook Miller and Holden for Protogen installers, leading to his death at Miller's hands.","relationships":[{"character":"Detective Miller","relationship":"Victim of Miller's lethal action"},{"character":"Jim Holden","relationship":"Witness to Miller's confrontation"}],"recentEvents":"Was killed by Miller after revealing details about Protogen's operations on Eros."},{"name":"Mafia Thug","aliases":[],"importance":"minor","status":"dead","lastSeen":"Chapter Twenty-Nine: Holden","currentLocation":"Eros station","description":"A violent enforcer killed by Holden during a mob incident.","relationships":[],"recentEvents":"Shot and killed by Holden after firing on civilians."},{"name":"Child Victim","aliases":[],"importance":"minor","status":"dead","lastSeen":"Chapter Twenty-Nine: Holden","currentLocation":"Eros station","description":"A thirteen-year-old boy killed by the mafia thug during the chaos on Eros station.","relationships":[],"recentEvents":"Died from a gunshot wound to the chest, rescued by Holden."},{"name":"Mr. Dresden","aliases":["sociopath"],"importance":"main","status":"alive","lastSeen":"Chapter Thirty-Four: Miller","currentLocation":"Unknown","description":"A charismatic corporate executive presenting Protogen's findings on the protomolecule.","relationships":[],"recentEvents":"Delivered a presentation about the protomolecule as a weapon from an alien civilization."}],"locations":[{"name":"Scopuli","arc":"OPA's Bioweapon Containment and Strategic Manipulation","description":"A stealth ship captured and repurposed, later found to be infected with a deadly biological agent.","recentEvents":"The ship's crew was killed by an unknown pathogen, with Julie Mao's body remaining in an unsealed locker.","relationships":[{"location":"Engineering deck","relationship":"Contains the ship's reactor and is the site of critical discoveries"},{"location":"Inner airlock","relationship":"Where Julie was initially confined and later accessed after escaping"},{"location":"MCRN Donnager","relationship":"The Scopuli's crew was transported here before their deaths."},{"location":"Eros Station","relationship":"The ship's contamination and events on Eros are interconnected."}]},{"name":"Engineering deck","aliases":["Engineering deck"],"arc":"Julie's Survival and Escape","description":"The ship's core area housing the fusion reactor and critical systems.","recentEvents":"Julie discovers the reactor's corrupted state, with biological material fused to its core. Captain Darren's head is found here.","relationships":[{"location":"Scopuli","relationship":"Central operational area of the ship"}]},{"name":"Inner airlock","aliases":["Inner airlock"],"description":"A sealed compartment connecting different sections of the ship.","recentEvents":"Julie was confined here for eight days before escaping. It served as a transition point between decks.","relationships":[{"location":"Scopuli","relationship":"Structural component of the ship"}]},{"name":"Canterbury","aliases":["Knight","Knight-class ship"],"arc":"OPA's Role in the Martian-Belt War","description":"A P and K shuttle craft carrying Jim Holden and his crew after the Canterbury's destruction.","recentEvents":"Holden's crew was boarded by Martian marines after docking, leading to an interrogation by Lieutenant Lopez and a tense standoff with approaching Belt ships.","relationships":[{"location":"Belt","relationship":"Travels between Saturn's rings and this region"},{"location":"Canterbury","relationship":"Adjacent spaceport for departure/arrival"},{"location":"CA-2216862","relationship":"Target location for salvage mission"},{"location":"MCRN Donnager","relationship":"Docked at the Donnager's docking bay"}]},{"name":"Belt","aliases":["Asteroid Belt"],"arc":"Holden's Crew Survival and Escape","description":"The region of space where the Canterbury and other ships operate, containing numerous asteroids and debris.","recentEvents":"The Canterbury was destroyed here by a nuclear weapon fired by a stealth ship. Holden and the Knight crew pursued the attackers while hiding behind an asteroid.","relationships":[{"location":"Callisto","relationship":"Adjacent to a charted non-Belt asteroid"},{"location":"Canterbury","relationship":"Destroyed in this region"},{"location":"Knight","relationship":"Survived here after the Canterbury's destruction"}]},{"name":"Callisto","description":"A non-Belt asteroid where a damaged Martian freighter sent an emergency signal.","recentEvents":"The Canterbury diverted its route to investigate the distress beacon near this location.","relationships":[{"location":"Belt","relationship":"Located near the asteroid belt"}]},{"name":"Ceres Station","aliases":["Ceres Port","Ceres"],"arc":"OPA's Role in the Martian-Belt War","description":"A major Belt station and economic hub, home to six million people. Serves as a critical node in the conflict between Mars and the Belt.","recentEvents":"The government of Ceres collapsed as Earth withdrew its oversight, leading to the formation of a provisional government. Detective Miller arrested Immanuel Corvus Dowd for a rape case, and the station's police force faced uncertainty about their authority.","relationships":[{"location":"Belt","relationship":"Central to Ceres' economic role as a transit point for Belt resources"},{"location":"Tycho Station","relationship":"Connected via trade routes and shared security concerns"},{"location":"Port Level","relationship":"Key area where the riot occurs"},{"location":"Station House","relationship":"Administrative center where security directives are issued"},{"location":"Ganymede","relationship":"Site of the Black Cat freighter's destination after transferring stolen riot gear"},{"location":"Io","relationship":"Destination of the perps who disposed of the murder weapon"},{"location":"Star Helix","relationship":"Former governing authority now withdrawn"},{"location":"Donnager","relationship":"Martian warship whose destruction triggered the Belt's uprising"}]},{"name":"Tycho Station","aliases":["Tycho"],"arc":"OPA's Political Manipulation and Trial Strategy","description":"Corporate station serving as a hub between the Belt and inner planets, known for its interplanetary transport operations.","recentEvents":"Julie Mao's last known employment and her apartment's network partition were linked to this station.","relationships":[{"location":"Ceres","relationship":"Serves as a key waypoint for cargo and passenger traffic between the Belt and inner systems"}]},{"name":"CA-2216862","aliases":["Asteroid 2216862"],"description":"A half-kilometer-wide asteroid in the asteroid belt, serving as a gravitational anchor for the Scopuli.","recentEvents":"The Scopuli was deliberately positioned near this asteroid, likely to exploit its microgravity for slow orbital capture.","relationships":[{"location":"Scopuli","relationship":"Gravitational anchor point"},{"location":"Belt","relationship":"Located within the asteroid belt"}]},{"name":"Port Level","description":"A bustling industrial area of Ceres Station where ships dock and cargo is handled, marked by high gravity and constant activity.","recentEvents":"Miller's squad confronts a violent mob, including an OPA-linked killer, to prevent the riot from escalating.","relationships":[{"location":"Ceres Station","relationship":"A distinct sector within the station"}]},{"name":"MCRN Donnager","aliases":["Donnager","Martian battleship"],"arc":"OPA's Role in the Martian-Belt War","description":"A massive Martian capital ship with a stark, utilitarian design, serving as a military base for Martian forces.","recentEvents":"Miller and Holden investigate the ship's engineering deck, discovering signs of a violent takeover and the presence of a mysterious infectious agent.","relationships":[{"location":"Saturn Station","relationship":"Origin of the order"},{"location":"Jupiter","relationship":"Destination for the Knight"},{"location":"Knight","relationship":"Hosted the docking and interrogation of the Knight"},{"location":"Belt","relationship":"Engaged in combat with Belt ships following a torpedo launch"},{"location":"Scopuli","relationship":"The Scopuli's crew was captured and held here before their deaths."},{"location":"Eros Station","relationship":"Events on Eros Station are linked to the ship's contamination and the crew's fate."}]},{"name":"Saturn Station","aliases":["Saturn Station"],"description":"A Martian-controlled space station where P and K legal counsel issued directives.","recentEvents":"Wallace Fitz communicated the order to head to Jupiter, escalating tensions with Mars.","relationships":[{"location":"Knight","relationship":"Source of the crew's orders"},{"location":"Ceres Station","relationship":"Previously mentioned in crew discussions"}]},{"name":"Jupiter","aliases":["Jupiter"],"description":"A gas giant and strategic destination for the Knight crew's flight path.","recentEvents":"Selected as a potential destination despite risks from unknown pursuers.","relationships":[{"location":"Belt","relationship":"Geographically adjacent region"},{"location":"MCRN Donnager","relationship":"Target location for the ship"}]},{"name":"Razorback","aliases":["Razorback"],"description":"A private racing vessel associated with the Mao family, symbolizing Julie Mao's past and the family's financial influence.","recentEvents":"Julie Mao's messages reveal her family's attempt to coerce her to return, referencing the ship's potential sale and its significance to her.","relationships":[{"location":"Ceres Station","relationship":"The Razorback is mentioned as a vessel tied to the Mao family's operations on Ceres."}]},{"name":"Anderson Station","aliases":["Anderson"],"description":"A minor Belt distribution station for water and air, infamous for the Massacre that made Fred Johnson a Belter hero.","recentEvents":"Fred Johnson's broadcast reveals the station's history as a site of Coalition brutality, framing it as a catalyst for OPA resistance.","relationships":[{"location":"Belt","relationship":"Part of the asteroid belt's contested regions"},{"location":"MCRN Donnager","relationship":"Johnson's message hints at potential Martian involvement in the current conflict"}]},{"name":"Phoebe Station","aliases":["Phoebe"],"description":"A science station in the asteroid belt, forbidden for Belters to dock at.","recentEvents":"Destroyed in an attack attributed to Belter guerrilla groups, with half its inhabitants dead or missing.","relationships":[{"location":"Ceres Station","relationship":"Linked via Belt political tensions"}]},{"name":"Hangar Bay","aliases":["Hangar"],"description":"A section of the Donnager containing multiple ships, including the Knight, where the crew attempts to escape.","recentEvents":"The crew fought through boarders to reach a corvette, with Lieutenant Kelly leading the evacuation.","relationships":[{"location":"MCRN Donnager","relationship":"Part of the ship's structure"},{"location":"Knight","relationship":"A ship stationed in the bay"}]},{"name":"Ganymede","description":"A moon with significant mining and trade operations in the Jupiter system.","recentEvents":"The Black Cat freighter, linked to stolen riot gear, made a stop here after departing Ceres.","relationships":[{"location":"Ceres Station","relationship":"Linked via the Black Cat's transit route"}]},{"name":"Io","arc":"OPA's Bioweapon Containment and Strategic Manipulation","description":"A volcanic moon in Jupiter's system, often used as a transit point for illicit operations.","recentEvents":"The perps who disposed of the murder weapon and stolen gear were headed here, though their arrival remains uncertain.","relationships":[{"location":"Ceres Station","relationship":"Linked via the Black Cat's transit route"}]},{"name":"Mars","aliases":["Martian Congressional Republic"],"arc":"OPA's Role in the Martian-Belt War","description":"Planet at the center of a conflict with the Belt, governed by the Martian Congressional Republic.","recentEvents":"The Martian Congressional Republic declared open war against the Belt, citing security threats and economic sabotage, escalating tensions across the system.","relationships":[{"location":"Belt","relationship":"Region in armed conflict with Mars"},{"location":"Ceres Station","relationship":"Site of growing unrest due to the war's proximity"}]},{"name":"Pallas","aliases":["Pallas Station"],"description":"A celestial body in the asteroid belt, serving as a transit hub for freighters and prospectors.","recentEvents":"The Adrianopole, a third-gen prospector, docked here after arriving from the Belt.","relationships":[{"location":"Ceres Station","relationship":"Linked via freighter routes and political tensions"}]},{"name":"Luna","description":"Earth's moon, a key node in interplanetary trade and military operations.","recentEvents":"The Badass Motherfucker freighter operated a triangle route between Luna, Ganymede, and the Belt.","relationships":[{"location":"Ganymede","relationship":"Connected via the Badass Motherfucker's trade route"},{"location":"Belt","relationship":"Part of a regional trade network"}]},{"name":"Triton","description":"Neptune's largest moon, home to deep astronomy labs repurposed by OPA-aligned prospectors.","recentEvents":"Prospectors sympathetic to the OPA occupied the labs, broadcasting Martian ship locations.","relationships":[{"location":"Belt","relationship":"Linked to OPA operations and resource conflicts"},{"location":"Mars","relationship":"Target of data broadcasts revealing Martian military assets"}]},{"name":"Eros Station Maintenance Corridor","aliases":["Eros","Eros Station","Maintenance Tunnel","Maintenance Shaft"],"arc":"OPA's Bioweapon Deployment and Strategic Manipulation","description":"A dimly lit service passage carved by early Belters, housing critical power lines and running through the first Belt colony's infrastructure.","recentEvents":"Miller and Holden use this corridor to evade guards and reach the hideout. Ko's body is carried through here.","relationships":[{"location":"Ceres Station","relationship":"Adjacent space station in the Belt"},{"location":"Scopuli","relationship":"Ship associated with the deceased Juliette Mao"},{"location":"Canterbury","relationship":"Home port of the freighter the Canterbury is responding to"},{"location":"Tycho Station","relationship":"Mole activity originated here"},{"location":"Radiation Shelters (Eros Station)","relationship":"Adjacent to the maintenance corridors"},{"location":"Casino Level","relationship":"Part of the lockdown area"},{"location":"MCRN Donnager","relationship":"Miller and Holden were rescued from Eros Station by the Donnager"},{"location":"Eros Station","relationship":"Part of the station's utility infrastructure"}]},{"name":"BA834024112","aliases":["Rock BA834024112","Julie's asteroid"],"arc":"Holden's Crew Survival and Escape","description":"A barren asteroid tethered to a wealthy owner, serving as a navigational warning.","recentEvents":"Holden and the crew of the Rocinante approach it, discovering a stealth ship linked to the Donnager's destruction.","relationships":[{"location":"Scopuli","relationship":"Linked to the shuttle that carried Julie and may hide the ship's remnants"},{"location":"Phoebe Station","relationship":"The Phoebe bug originated from this science station, connecting to Julie's infection"},{"location":"Ceres Station","relationship":"The Rocinante is en route to Ceres after analyzing data from this asteroid."}]},{"name":"Casino Level","aliases":["Radiological Shelter","Casino Area"],"description":"A restricted zone on Eros Station where the population is funneled during lockdowns, serving as a central gathering point.","recentEvents":"The level is under lockdown, with guards enforcing movement toward shelters. Miller and Holden use this as a strategic point to regroup.","relationships":[{"location":"Eros Station","relationship":"Part of the station's structure"}]},{"name":"Radiation Shelters (Eros Station)","aliases":["Radiation Lockdown Zones","Radiation Incubators"],"description":"Sealed-off sections of Eros Station purportedly designed to protect citizens from radiation, but secretly used as containment areas for lethal gas and biological agents.","recentEvents":"The shelters were emptied, leaving only Holden and Miller's footsteps. Ko's body is left here after being shot.","relationships":[{"location":"Eros Station","relationship":"Designated emergency lockdown zones"},{"location":"Ceres Station","relationship":"Linked via transit corridors"},{"location":"Eros Station Maintenance Corridor","relationship":"Located nearby"}]}],"arcs":[{"name":"OPA's Bioweapon Containment and Strategic Manipulation","status":"active","characters":["Jim Holden","Naomi Nagata","Detective Miller"],"summary":"Holden and Miller analyze data implicating Earth's shipyards in the Donnager's destruction, revealing OPA's potential role in escalating the war. Holden's broadcast of the data risks exposing secrets, complicating OPA's containment efforts."},{"name":"Miller's Grief, Revenge, and Moral Conflict","status":"active","characters":["Detective Miller"],"summary":"Miller's fear of Protogen's weaponization of the protomolecule intensifies, forcing him to confront his role in the bioweapon's spread and the ethical cost of his pursuit of justice."},{"name":"Holden's Crew Survival and Escape","status":"active","characters":["Jim Holden","Naomi Nagata","Amos Burton"],"summary":"The crew faces the protomolecule's existential threat as Holden grapples with the implications of Protogen's experiments, now linked to the bioweapon's spread across the Belt."},{"name":"Protogen's Protomolecule Experimentation and Alien Weapon Threat","status":"active","characters":["Jim Holden","Detective Miller","Naomi Nagata"],"summary":"Holden and Miller uncover Protogen's reckless testing of the protomolecule on Eros, revealing its potential to reshape life itself and the corporate greed driving its weaponization."}],"summary":"Miller and Holden analyze a corporate presentation revealing Protogen's discovery of the protomolecule on Phoebe, a weaponized alien artifact. They suspect Protogen's reckless experimentation on Eros and its broader plans for galactic domination, while Naomi hints at critical discoveries on the Rocinante. The narrative centers on the crew's struggle to counter Protogen's exploitation of the protomolecule's transformative potential."},"model":"qwen3:8b","appVersion":"0.1.0"},{"index":39,"result":{"characters":[{"name":"Juliette Andromeda Mao","aliases":["Julie Mao"],"importance":"main","status":"dead","lastSeen":"Chapter Twenty-Four: Miller","currentLocation":"Eros flophouse","description":"A captured crew member held in a storage locker, enduring eight days of isolation and dehydration while planning her escape. She discovers the ship's reactor has been replaced with an alien entity.","relationships":[{"character":"Dave","relationship":"Shipmate"},{"character":"Captain Darren","relationship":"Captain"},{"character":"Mike","relationship":"Shipmate"},{"character":"Wan Li","relationship":"Shipmate"},{"character":"Mao-Kwikowski Mercantile","relationship":"Family"},{"character":"Captain Shaddid","relationship":"Client"},{"character":"Detective Miller","relationship":"Target of search"}],"recentEvents":"Discovered dead in shower stall with severe biological modifications"},{"name":"Dave","aliases":[],"importance":"secondary","status":"dead","lastSeen":"Prologue: Julie","currentLocation":"Unknown","description":"Julie's shipmate and mechanic, who begged the captors not to take Julie before being thrown out an airlock.","relationships":[{"character":"Julie Mao","relationship":"Shipmate"}],"recentEvents":"Begged captors to spare Julie, was thrown out an airlock, and died."},{"name":"Captain Darren","aliases":[],"importance":"secondary","status":"dead","lastSeen":"Prologue: Julie","currentLocation":"Engineering deck","description":"The ship's captain who surrendered to the attackers without resistance, later found as a head fused to the alien reactor.","relationships":[{"character":"Julie Mao","relationship":"Captain"}],"recentEvents":"Surrendered to attackers, died after being part of the alien entity's fusion reactor."},{"name":"Mike","aliases":[],"importance":"secondary","status":"unknown","lastSeen":"Prologue: Julie","currentLocation":"Unknown","description":"A shipmate captured by the attackers along with others.","relationships":[{"character":"Julie Mao","relationship":"Shipmate"}],"recentEvents":"Captured by the attackers and taken off the ship."},{"name":"Wan Li","aliases":[],"importance":"secondary","status":"unknown","lastSeen":"Prologue: Julie","currentLocation":"Unknown","description":"A shipmate captured by the attackers along with others.","relationships":[{"character":"Julie Mao","relationship":"Shipmate"}],"recentEvents":"Captured by the attackers and taken off the ship."},{"name":"The Attackers","aliases":[],"importance":"secondary","status":"unknown","lastSeen":"Prologue: Julie","currentLocation":"Unknown","description":"The captors who took control of the ship, beat the crew, and sealed the ship's systems.","relationships":[{"character":"Julie Mao","relationship":"Captors"}],"recentEvents":"Captured the crew, sealed the ship, and replaced the reactor with an alien entity."},{"name":"Jim Holden","aliases":["James Holden","Holden"],"importance":"main","status":"alive","lastSeen":"Chapter Thirty-Five: Holden","currentLocation":"Rocinante","description":"Executive officer of the Canterbury, a colony transport ship. A former Earth navy officer with a cynical view of Belters and their physiology.","relationships":[{"character":"Naomi Nagata","relationship":"Commander and romantic interest"},{"character":"Ade Tukunbo","relationship":"Romantic interest"},{"character":"Captain McDowell","relationship":"Former commanding officer"},{"character":"Alex Kamal","relationship":"Crewmate and engineer"},{"character":"Amos Burton","relationship":"Crewmate and weapons expert"},{"character":"Shed Garvey","relationship":"Crew member"},{"character":"Captain Theresa Yao","relationship":"Debriefed by Martian naval officer"},{"character":"Kelly","relationship":"Crewmate (deceased)"},{"character":"Fred Johnson","relationship":"Business associate"},{"character":"Detective Miller","relationship":"Accompanied by Miller during the investigation"}],"recentEvents":"Discussed scuttling the stealth ship, debated Mars' potential retaliation, and planned to retrieve the Thoth Station safe."},{"name":"Naomi Nagata","aliases":["Naomi"],"importance":"main","status":"alive","lastSeen":"Chapter Thirty-Five: Holden","currentLocation":"Rocinante","description":"Medical officer who tends to Miller and Holden. Engages in a tense conversation with Holden about his feelings for her.","relationships":[{"character":"Jim Holden","relationship":"Commander and romantic interest"},{"character":"Amos Burton","relationship":"Subordinate"},{"character":"Alex Kamal","relationship":"Crew member"},{"character":"Kelly","relationship":"Crewmate (deceased)"},{"character":"Fred Johnson","relationship":"Business associate"},{"character":"Detective Miller","relationship":"Fought alongside during ambush"}],"recentEvents":"Attempted to access the Thoth Station safe, discussed the ship's value, and debated methods to retrieve it."},{"name":"Amos Burton","aliases":["Amos"],"importance":"main","status":"alive","lastSeen":"Chapter Thirty-Five: Holden","currentLocation":"Rocinante","description":"Earthborn assistant to Naomi Nagata. Known for his loud personality and loyalty to Naomi.","relationships":[{"character":"Naomi Nagata","relationship":"Subordinate"},{"character":"Jim Holden","relationship":"Companion on the mission"},{"character":"Alex Kamal","relationship":"Crew member"},{"character":"Fred Johnson","relationship":"Business associate"},{"character":"Detective Miller","relationship":"Fought alongside during ambush"}],"recentEvents":"Worked on the reactor, discussed scuttling the ship, and expressed skepticism about destroying the stealth ship."},{"name":"Shed Garvey","aliases":["Shed"],"importance":"secondary","status":"dead","lastSeen":"Chapter Eleven: Holden","currentLocation":"Donnager","description":"Medical tech responsible for treating injured crew members. Known for using medical maggots in procedures.","relationships":[{"character":"Cameron Paj","relationship":"Patient"},{"character":"Jim Holden","relationship":"Crew member"},{"character":"Naomi Nagata","relationship":"Crew member"},{"character":"Alex Kamal","relationship":"Crew member"}],"recentEvents":"Mentioned by Holden as someone he wished was still alive."},{"name":"Cameron Paj","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter Five: Holden","currentLocation":"Knight","description":"Crew member who lost his left arm in an ice-related accident. Uses a prosthetic limb.","relationships":[{"character":"Shed Garvey","relationship":"Crewmate"}],"recentEvents":"Implied to have an injured arm, mentioned by Shed during the aftermath."},{"name":"Ade Tukunbo","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter Five: Holden","currentLocation":"Knight","description":"Navigator with a Nigerian accent and a fondness for music. Has a flirtatious relationship with Holden.","relationships":[{"character":"Jim Holden","relationship":"Romantic interest"}],"recentEvents":"Attempted to power up the Knight's drive, survived the nuke blast, communicated with Holden during the crisis."},{"name":"Rebecca Byers","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter One: Holden","currentLocation":"Canterbury","description":"Comm officer with a sharp appearance and a history of legal troubles. Handles emergency communications.","relationships":[{"character":"Captain McDowell","relationship":"Subordinate"}],"recentEvents":"Received and relayed the emergency signal from an unknown ship."},{"name":"Captain McDowell","aliases":[],"importance":"main","status":"alive","lastSeen":"Chapter Five: Holden","currentLocation":"Knight","description":"Commanding officer of the Canterbury. A grizzled veteran with a distrust of corrective surgery.","relationships":[{"character":"Jim Holden","relationship":"Former subordinate"}],"recentEvents":"Gave Holden instructions for the broadcast operation"},{"name":"Detective Miller","aliases":["Miller"],"importance":"main","status":"alive","lastSeen":"Chapter Thirty-Five: Holden","currentLocation":"Rocinante","description":"Experienced security officer with a troubled past, investigating Julie Mao's disappearance while navigating political tensions between Mars, the Belt, and Earth.","relationships":[{"character":"Dmitri Havelock","relationship":"Partner"},{"character":"Captain Shaddid","relationship":"Superior"},{"character":"Juliette Andromeda Mao","relationship":"OPA contact"},{"character":"Havelock","relationship":"Partner who covers for Miller's absence"},{"character":"Octavia Muss","relationship":"Partner"},{"character":"Julie Mao","relationship":"Subject of investigation"},{"character":"Muss","relationship":"Partner"},{"character":"Shaddid","relationship":"Superior"},{"character":"Dawes","relationship":"Colleague"},{"character":"Inspector Sematimba","relationship":"Contacted for police assistance"},{"character":"Jim Holden","relationship":"Partner in investigating the station's crisis"},{"character":"Naomi Nagata","relationship":"Collaborated on the investigation"},{"character":"Sematimba","relationship":"Contacted police"},{"character":"Amos Burton","relationship":"Team member"}],"recentEvents":"Warned Holden about Mars' potential retaliation, showed footage of the Martian battle, and analyzed the political implications."},{"name":"Captain Shaddid","aliases":["Shaddid"],"importance":"main","status":"alive","lastSeen":"Chapter Sixteen: Miller","currentLocation":"Ceres Station","description":"Commander of Star Helix Security on Ceres, known for her pragmatic approach and disdain for inner planet residents.","relationships":[{"character":"Miller","relationship":"Subordinate"},{"character":"Julie Mao","relationship":"Client"},{"character":"Detective Miller","relationship":"Superior"}],"recentEvents":"Reassigned Miller from the Mao case, emphasized Star Helix's neutrality in Martian conflicts."},{"name":"Alex Kamal","aliases":["Alex"],"importance":"main","status":"alive","lastSeen":"Chapter Thirty-Five: Holden","currentLocation":"Rocinante","description":"Crewmate and engineer, skeptical of Martian involvement in the Canterbury's destruction.","relationships":[{"character":"Jim Holden","relationship":"Companion on the mission"},{"character":"Naomi Nagata","relationship":"Crew member"},{"character":"Amos Burton","relationship":"Crew member"},{"character":"Shed Garvey","relationship":"Crew member"},{"character":"Kelly","relationship":"Crewmate (deceased)"},{"character":"Fred Johnson","relationship":"Business associate"}],"recentEvents":"Helped calculate potential destinations for the stealth ship."},{"name":"Dmitri Havelock","aliases":["Havelock"],"importance":"main","status":"alive","lastSeen":"Chapter Twelve: Miller","currentLocation":"Ceres","description":"Miller's partner and fellow security officer, who agrees to cover for Miller's absence while he investigates Julie Mao's case.","relationships":[{"character":"Detective Miller","relationship":"Partner"},{"character":"Miller","relationship":"Partner who covers for Miller's absence"},{"character":"Captain Shaddid","relationship":"Superior"}],"recentEvents":"Agreed to take sick leave to avoid potential conflict, supporting Miller's decision to continue the investigation despite OPA warnings."},{"name":"Hasini","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter Sixteen: Miller","currentLocation":"Blue Frog (Ceres Station)","description":"Assistant manager of the Blue Frog, a portside bar on Ceres, who interacted with Detective Miller.","relationships":[{"character":"Detective Miller","relationship":"Informal acquaintance"}],"recentEvents":"Accompanied Miller home after a drinking session, revealed his feelings for Julie Mao."},{"name":"Brown","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter Six: Miller","currentLocation":"Ceres","description":"Security officer with SWAT experience, leading crowd control wings.","relationships":[],"recentEvents":"Part of Miller's riot squad, led during the mob confrontation."},{"name":"Gelbfish","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter Six: Miller","currentLocation":"Ceres","description":"Security officer with SWAT experience, part of Miller's team.","relationships":[],"recentEvents":"Identified the shirtless man's OPA tattoo, participated in crowd control."},{"name":"Aberforth","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter Six: Miller","currentLocation":"Ceres","description":"Security officer with a history of excessive violence, placed in second-string role.","relationships":[],"recentEvents":"Assigned to secondary roles due to past disciplinary issues."},{"name":"Yevgeny","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter Six: Miller","currentLocation":"Ceres","description":"Homicide detective who commented on government offices during the crisis.","relationships":[],"recentEvents":"Mentioned the government's infrastructure status during Shaddid's briefing."},{"name":"Shirtless Man","aliases":[],"importance":"minor","status":"alive","lastSeen":"Chapter Eight: Miller","currentLocation":"Ceres","description":"A former suspect in a crime, now in Star Helix detainment infirmary preparing for trial.","relationships":[],"recentEvents":"Mentioned in context of Ceres Station's ongoing legal cases"},{"name":"OPA Man","aliases":[],"importance":"minor","status":"alive","lastSeen":"Chapter Ten: Miller","currentLocation":"Ceres","description":"An OPA representative with a pock-marked face, engaged in a tense conversation with Miller about OPA's role.","relationships":[{"character":"Detective Miller","relationship":"OPA contact"}],"recentEvents":"Discussed OPA's economic terrorism claims, denied involvement in Mateo Judd's death, and warned Miller to stay away."},{"name":"Wallace Fitz","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter Seven: Holden","currentLocation":"Saturn Station","description":"P and K legal counsel who issued formal orders to Holden and his crew.","relationships":[{"character":"Jim Holden","relationship":"Legal contact"}],"recentEvents":"Delivered official response to Holden's request for assistance, accused Holden of unfounded Martian accusations."},{"name":"Captain Theresa Yao","aliases":[],"importance":"main","status":"alive","lastSeen":"Chapter Eleven: Holden","currentLocation":"Donnager","description":"Commander of the Donnager, a Martian capital ship, overseeing the interrogation of Holden's crew.","relationships":[{"character":"Jim Holden","relationship":"Debriefed by Martian naval officer"}],"recentEvents":"Ordered the torpedo launch against the Belt ships and interrogated Holden about the pursuing vessels."},{"name":"Masked Woman","aliases":["Woman"],"importance":"minor","status":"alive","lastSeen":"Chapter Eight: Miller","currentLocation":"Ceres","description":"Victim beaten to death by the shirtless man, identified as a Martian freight line employee.","relationships":[],"recentEvents":"Featured in Miller's terminal screen as part of OPA propaganda"},{"name":"Fred Johnson","aliases":[],"importance":"main","status":"alive","lastSeen":"Chapter Twenty-One: Holden","currentLocation":"Tycho Station","description":"Colonel and leader of the Outer Planets Alliance, contacting Holden about potential Martian threats.","relationships":[{"character":"Jim Holden","relationship":"Communications contact"},{"character":"Naomi Nagata","relationship":"Business associate"},{"character":"Amos Burton","relationship":"Business associate"},{"character":"Alex Kamal","relationship":"Business associate"}],"recentEvents":"Negotiated the use of the Rocinante for an Eros mission, revealed the fictional Lionel Polanski, and discussed the data cube."},{"name":"Mateo Judd","aliases":[],"importance":"main","status":"dead","lastSeen":"Chapter Ten: Miller","currentLocation":"Ceres","description":"A dockworker accused of running an extortion scheme, later found dead with OPA ties.","relationships":[{"character":"Asher Kamamatsu","relationship":"Client"}],"recentEvents":"Sought protection from the OPA, was killed by OPA operatives after Miller's investigation."},{"name":"Lieutenant Lopez","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter Eleven: Holden","currentLocation":"Donnager","description":"Naval intelligence officer conducting an interrogation of Holden, using focus drugs to monitor his responses.","relationships":[{"character":"Jim Holden","relationship":"Interrogated by naval intelligence"}],"recentEvents":"Conducted a detailed interrogation of Holden, discussed the political tensions between Mars and the Belt, and fled to the combat zone after the torpedo attack."},{"name":"Chief Gunderson","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter Eleven: Holden","currentLocation":"Donnager","description":"Martian military chief responsible for escorting Holden's crew to their quarters.","relationships":[{"character":"Jim Holden","relationship":"Escorted to quarters"}],"recentEvents":"Led Holden's crew to their temporary accommodations and coordinated with Lieutenant Kelly for their protection."},{"name":"Anderson Dawes","aliases":["Dawes"],"importance":"main","status":"alive","lastSeen":"Chapter Sixteen: Miller","currentLocation":"Ceres Station","description":"OPA liaison who approaches Detective Miller to stop his investigation into Julie Mao's disappearance, claiming it could escalate tensions between Mars and the Belt.","relationships":[{"character":"Detective Miller","relationship":"OPA agent attempting to dissuade Miller from pursuing a kidnapping case"}],"recentEvents":"Argued against Miller's investigation, claimed Holden's capture, and emphasized corporate neutrality."},{"name":"The Jiu Jitsu Instructor","aliases":[],"importance":"minor","status":"alive","lastSeen":"Chapter Twelve: Miller","currentLocation":"Ceres","description":"Owner of the Ceres Center for Jiu Jitsu, who provides limited information about Julie Mao's background and training.","relationships":[]},{"name":"Enrique Dos Santos","aliases":[],"importance":"minor","status":"dead","lastSeen":"Chapter Fourteen: Miller","currentLocation":"Ceres","description":"","relationships":[],"recentEvents":"Tortured and displayed near sector eleven's water reclamation works; identified by terminal, wedding ring, and credit data"},{"name":"Octavia Muss","aliases":["Muss"],"importance":"secondary","status":"alive","lastSeen":"Chapter Eighteen: Miller","currentLocation":"Ceres Station","description":"A pragmatic detective who handles interrogations and provides Miller with critical case updates.","relationships":[{"character":"Detective Miller","relationship":"Colleague"},{"character":"Miller","relationship":"Partner"},{"character":"Shaddid","relationship":"Superior"}],"recentEvents":"Provided Miller with a rape case witness detail, skipped work to attend to a stop, and observed the political upheaval on Ceres."},{"name":"Kelly","aliases":["Lieutenant Kelly"],"importance":"main","status":"dead","lastSeen":"Chapter Fifteen: Holden","currentLocation":"Tachi","description":"Deceased marine who died during the battle on the Donnager.","relationships":[{"character":"Jim Holden","relationship":"Crewmate"},{"character":"Alex Kamal","relationship":"Crewmate"}],"recentEvents":"Died from severe injuries during the battle, then buried by the crew."},{"name":"Gomez","aliases":[],"importance":"secondary","status":"dead","lastSeen":"Chapter Fifteen: Holden","currentLocation":"Unknown","description":"Marine who died during the battle on the Donnager.","relationships":[{"character":"Jim Holden","relationship":"Crewmate"}],"recentEvents":"Killed by enemy fire while defending the Donnager."},{"name":"Immanuel Corvus Dowd","aliases":[],"importance":"main","status":"alive","lastSeen":"Chapter Eighteen: Miller","currentLocation":"Ceres Station detention cells","description":"A businessman arrested for rape, portrayed as a high-profile client with connections to influential war effort figures.","relationships":[{"character":"Harry","relationship":"Lawyer"}],"recentEvents":"Detained under a warrant following a rape investigation, confronted by Detective Miller, and subjected to legal scrutiny."},{"name":"Harry","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter Eighteen: Miller","currentLocation":"Ceres Station","description":"Immanuel Corvus Dowd's lawyer, who warns Miller of potential legal repercussions for his investigation.","relationships":[{"character":"Immanuel Corvus Dowd","relationship":"Client"}],"recentEvents":"Attempted to shield his client from arrest, engaged in tense dialogue with Miller, and exited the interrogation room."},{"name":"Young Woman in Cream-Colored Linen","aliases":[],"importance":"minor","status":"unknown","lastSeen":"Chapter Eighteen: Miller","currentLocation":"Ceres Station","description":"A professional-looking woman who briefly acknowledged Miller before entering the accountancy office.","relationships":[],"recentEvents":"Nodded to Miller as he left the accountancy office, displaying a calm, fighter-like demeanor."},{"name":"Bartender","aliases":[],"importance":"minor","status":"alive","lastSeen":"Chapter Nineteen: Holden","currentLocation":"Tycho Station","relationships":[]},{"name":"Singer","aliases":[],"importance":"minor","status":"alive","lastSeen":"Chapter Nineteen: Holden","currentLocation":"Tycho Station","relationships":[]},{"name":"Teenage Girls","aliases":[],"importance":"minor","status":"alive","lastSeen":"Chapter Nineteen: Holden","currentLocation":"Tycho Station","relationships":[]},{"name":"Lionel Polanski","aliases":[],"importance":"secondary","status":"unknown","lastSeen":"Chapter Twenty-Three: Holden","currentLocation":"Eros hotel room","description":"A fictional person Fred Johnson claims to need retrieved from Eros, owning the courier ship Scopuli.","relationships":[{"character":"Fred Johnson","relationship":"Target of retrieval"}],"recentEvents":"Targeted by Holden's group, last seen in his hotel room."},{"name":"Missionary","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter Twenty-Two: Miller","currentLocation":"Eros","description":"A traveling missionary with a name tag and Bible","relationships":[],"recentEvents":"Engaging in philosophical conversation about religion and war with Miller"},{"name":"Inspector Sematimba","aliases":["Sematimba"],"importance":"secondary","status":"alive","lastSeen":"Chapter Twenty-Six: Miller","currentLocation":"Eros flophouse","description":"Police officer who imposed a lockdown on Holden's ship.","relationships":[{"character":"Detective Miller","relationship":"Contacted for police assistance"},{"character":"Jim Holden","relationship":"Enforced lockdown"}],"recentEvents":"Imposed a lockdown on Holden's ship, communicated with Miller about jurisdictional concerns."},{"name":"Woman with the gun","aliases":[],"importance":"minor","status":"dead","lastSeen":"Chapter Twenty-Three: Holden","currentLocation":"Eros flophouse","description":"Armed assailant who confronted Holden's group.","relationships":[],"recentEvents":"Shot and killed during the confrontation at Lionel Polanski's flophouse."},{"name":"Guard","aliases":[],"importance":"minor","status":"alive","lastSeen":"Chapter Twenty-Seven: Holden","currentLocation":"Eros station","description":"A fake riot cop leading civilians to a radiation shelter.","relationships":[],"recentEvents":"Nudged by Miller after the shootout."},{"name":"Gabby Smalls","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter Twenty-Seven: Holden","currentLocation":"Ceres","description":"A mobster and police riot gear supervisor on Ceres, leading civilians to shelters.","relationships":[],"recentEvents":"Mentioned as a key figure in the Ceres protection racket."},{"name":"Mikey Ko","aliases":[],"importance":"secondary","status":"dead","lastSeen":"Chapter Twenty-Eight: Miller","currentLocation":"Eros station","description":"A guard who mistook Miller and Holden for Protogen installers, leading to his death at Miller's hands.","relationships":[{"character":"Detective Miller","relationship":"Victim of Miller's lethal action"},{"character":"Jim Holden","relationship":"Witness to Miller's confrontation"}],"recentEvents":"Was killed by Miller after revealing details about Protogen's operations on Eros."},{"name":"Mafia Thug","aliases":[],"importance":"minor","status":"dead","lastSeen":"Chapter Twenty-Nine: Holden","currentLocation":"Eros station","description":"A violent enforcer killed by Holden during a mob incident.","relationships":[],"recentEvents":"Shot and killed by Holden after firing on civilians."},{"name":"Child Victim","aliases":[],"importance":"minor","status":"dead","lastSeen":"Chapter Twenty-Nine: Holden","currentLocation":"Eros station","description":"A thirteen-year-old boy killed by the mafia thug during the chaos on Eros station.","relationships":[],"recentEvents":"Died from a gunshot wound to the chest, rescued by Holden."},{"name":"Mr. Dresden","aliases":["sociopath"],"importance":"main","status":"alive","lastSeen":"Chapter Thirty-Four: Miller","currentLocation":"Unknown","description":"A charismatic corporate executive presenting Protogen's findings on the protomolecule.","relationships":[],"recentEvents":"Delivered a presentation about the protomolecule as a weapon from an alien civilization."},{"name":"Captain Higgins","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter Thirty-Five: Holden","currentLocation":"Thoth Station","description":"Commander of a ship infected by a lethal alien pathogen.","relationships":[],"recentEvents":"Sent a final distress message about crew casualties and the ship's condition before losing contact."}],"locations":[{"name":"Scopuli","arc":"Holden's Crew Survival and Escape","description":"A stealth ship captured and repurposed, later found to be infected with a deadly biological agent.","recentEvents":"The ship's crew was killed by an unknown pathogen, with Julie Mao's body remaining in an unsealed locker.","relationships":[{"location":"Engineering deck","relationship":"Contains the ship's reactor and is the site of critical discoveries"},{"location":"Inner airlock","relationship":"Where Julie was initially confined and later accessed after escaping"},{"location":"MCRN Donnager","relationship":"The Scopuli's crew was transported here before their deaths."},{"location":"Eros Station","relationship":"The ship's contamination and events on Eros are interconnected."}]},{"name":"Engineering deck","aliases":["Engineering deck"],"arc":"Julie's Survival and Escape","description":"The ship's core area housing the fusion reactor and critical systems.","recentEvents":"Julie discovers the reactor's corrupted state, with biological material fused to its core. Captain Darren's head is found here.","relationships":[{"location":"Scopuli","relationship":"Central operational area of the ship"}]},{"name":"Inner airlock","aliases":["Inner airlock"],"description":"A sealed compartment connecting different sections of the ship.","recentEvents":"Julie was confined here for eight days before escaping. It served as a transition point between decks.","relationships":[{"location":"Scopuli","relationship":"Structural component of the ship"}]},{"name":"Canterbury","aliases":["Knight","Knight-class ship"],"arc":"OPA's Role in the Martian-Belt War","description":"A P and K shuttle craft carrying Jim Holden and his crew after the Canterbury's destruction.","recentEvents":"Holden's crew was boarded by Martian marines after docking, leading to an interrogation by Lieutenant Lopez and a tense standoff with approaching Belt ships.","relationships":[{"location":"Belt","relationship":"Travels between Saturn's rings and this region"},{"location":"Canterbury","relationship":"Adjacent spaceport for departure/arrival"},{"location":"CA-2216862","relationship":"Target location for salvage mission"},{"location":"MCRN Donnager","relationship":"Docked at the Donnager's docking bay"}]},{"name":"Belt","aliases":["Asteroid Belt"],"arc":"Protogen's Protomolecule Experimentation and Alien Weapon Threat","description":"The region of space where the Canterbury and other ships operate, containing numerous asteroids and debris.","recentEvents":"The Canterbury was destroyed here by a nuclear weapon fired by a stealth ship. Holden and the Knight crew pursued the attackers while hiding behind an asteroid.","relationships":[{"location":"Callisto","relationship":"Adjacent to a charted non-Belt asteroid"},{"location":"Canterbury","relationship":"Destroyed in this region"},{"location":"Knight","relationship":"Survived here after the Canterbury's destruction"}]},{"name":"Callisto","description":"A non-Belt asteroid where a damaged Martian freighter sent an emergency signal.","recentEvents":"The Canterbury diverted its route to investigate the distress beacon near this location.","relationships":[{"location":"Belt","relationship":"Located near the asteroid belt"}]},{"name":"Ceres Station","aliases":["Ceres Port","Ceres"],"arc":"OPA's Role in the Martian-Belt War","description":"A major Belt station and economic hub, home to six million people. Serves as a critical node in the conflict between Mars and the Belt.","recentEvents":"The government of Ceres collapsed as Earth withdrew its oversight, leading to the formation of a provisional government. Detective Miller arrested Immanuel Corvus Dowd for a rape case, and the station's police force faced uncertainty about their authority.","relationships":[{"location":"Belt","relationship":"Central to Ceres' economic role as a transit point for Belt resources"},{"location":"Tycho Station","relationship":"Connected via trade routes and shared security concerns"},{"location":"Port Level","relationship":"Key area where the riot occurs"},{"location":"Station House","relationship":"Administrative center where security directives are issued"},{"location":"Ganymede","relationship":"Site of the Black Cat freighter's destination after transferring stolen riot gear"},{"location":"Io","relationship":"Destination of the perps who disposed of the murder weapon"},{"location":"Star Helix","relationship":"Former governing authority now withdrawn"},{"location":"Donnager","relationship":"Martian warship whose destruction triggered the Belt's uprising"}]},{"name":"Tycho Station","aliases":["Tycho"],"arc":"OPA's Political Manipulation and Trial Strategy","description":"Corporate station serving as a hub between the Belt and inner planets, known for its interplanetary transport operations.","recentEvents":"Julie Mao's last known employment and her apartment's network partition were linked to this station.","relationships":[{"location":"Ceres","relationship":"Serves as a key waypoint for cargo and passenger traffic between the Belt and inner systems"}]},{"name":"CA-2216862","aliases":["Asteroid 2216862"],"description":"A half-kilometer-wide asteroid in the asteroid belt, serving as a gravitational anchor for the Scopuli.","recentEvents":"The Scopuli was deliberately positioned near this asteroid, likely to exploit its microgravity for slow orbital capture.","relationships":[{"location":"Scopuli","relationship":"Gravitational anchor point"},{"location":"Belt","relationship":"Located within the asteroid belt"}]},{"name":"Port Level","description":"A bustling industrial area of Ceres Station where ships dock and cargo is handled, marked by high gravity and constant activity.","recentEvents":"Miller's squad confronts a violent mob, including an OPA-linked killer, to prevent the riot from escalating.","relationships":[{"location":"Ceres Station","relationship":"A distinct sector within the station"}]},{"name":"MCRN Donnager","aliases":["Donnager","Martian battleship"],"arc":"OPA's Role in the Martian-Belt War","description":"A massive Martian capital ship with a stark, utilitarian design, serving as a military base for Martian forces.","recentEvents":"Miller and Holden investigate the ship's engineering deck, discovering signs of a violent takeover and the presence of a mysterious infectious agent.","relationships":[{"location":"Saturn Station","relationship":"Origin of the order"},{"location":"Jupiter","relationship":"Destination for the Knight"},{"location":"Knight","relationship":"Hosted the docking and interrogation of the Knight"},{"location":"Belt","relationship":"Engaged in combat with Belt ships following a torpedo launch"},{"location":"Scopuli","relationship":"The Scopuli's crew was captured and held here before their deaths."},{"location":"Eros Station","relationship":"Events on Eros Station are linked to the ship's contamination and the crew's fate."}]},{"name":"Saturn Station","aliases":["Saturn Station"],"description":"A Martian-controlled space station where P and K legal counsel issued directives.","recentEvents":"Wallace Fitz communicated the order to head to Jupiter, escalating tensions with Mars.","relationships":[{"location":"Knight","relationship":"Source of the crew's orders"},{"location":"Ceres Station","relationship":"Previously mentioned in crew discussions"}]},{"name":"Jupiter","aliases":["Jupiter"],"description":"A gas giant and strategic destination for the Knight crew's flight path.","recentEvents":"Selected as a potential destination despite risks from unknown pursuers.","relationships":[{"location":"Belt","relationship":"Geographically adjacent region"},{"location":"MCRN Donnager","relationship":"Target location for the ship"}]},{"name":"Razorback","aliases":["Razorback"],"description":"A private racing vessel associated with the Mao family, symbolizing Julie Mao's past and the family's financial influence.","recentEvents":"Julie Mao's messages reveal her family's attempt to coerce her to return, referencing the ship's potential sale and its significance to her.","relationships":[{"location":"Ceres Station","relationship":"The Razorback is mentioned as a vessel tied to the Mao family's operations on Ceres."}]},{"name":"Anderson Station","aliases":["Anderson"],"description":"A minor Belt distribution station for water and air, infamous for the Massacre that made Fred Johnson a Belter hero.","recentEvents":"Fred Johnson's broadcast reveals the station's history as a site of Coalition brutality, framing it as a catalyst for OPA resistance.","relationships":[{"location":"Belt","relationship":"Part of the asteroid belt's contested regions"},{"location":"MCRN Donnager","relationship":"Johnson's message hints at potential Martian involvement in the current conflict"}]},{"name":"Phoebe Station","aliases":["Phoebe"],"description":"A science station in the asteroid belt, forbidden for Belters to dock at.","recentEvents":"Destroyed in an attack attributed to Belter guerrilla groups, with half its inhabitants dead or missing.","relationships":[{"location":"Ceres Station","relationship":"Linked via Belt political tensions"}]},{"name":"Hangar Bay","aliases":["Hangar"],"description":"A section of the Donnager containing multiple ships, including the Knight, where the crew attempts to escape.","recentEvents":"The crew fought through boarders to reach a corvette, with Lieutenant Kelly leading the evacuation.","relationships":[{"location":"MCRN Donnager","relationship":"Part of the ship's structure"},{"location":"Knight","relationship":"A ship stationed in the bay"}]},{"name":"Ganymede","description":"A moon with significant mining and trade operations in the Jupiter system.","recentEvents":"The Black Cat freighter, linked to stolen riot gear, made a stop here after departing Ceres.","relationships":[{"location":"Ceres Station","relationship":"Linked via the Black Cat's transit route"}]},{"name":"Io","arc":"OPA's Bioweapon Containment, Thoth Station Tracking, and Strategic Manipulation","description":"A volcanic moon in Jupiter's system, often used as a transit point for illicit operations.","recentEvents":"The perps who disposed of the murder weapon and stolen gear were headed here, though their arrival remains uncertain.","relationships":[{"location":"Ceres Station","relationship":"Linked via the Black Cat's transit route"}]},{"name":"Mars","aliases":["Martian Congressional Republic"],"arc":"Protogen's Protomolecule Experimentation and Alien Weapon Threat","description":"Planet at the center of a conflict with the Belt, governed by the Martian Congressional Republic.","recentEvents":"The Martian Congressional Republic declared open war against the Belt, citing security threats and economic sabotage, escalating tensions across the system.","relationships":[{"location":"Belt","relationship":"Region in armed conflict with Mars"},{"location":"Ceres Station","relationship":"Site of growing unrest due to the war's proximity"}]},{"name":"Pallas","aliases":["Pallas Station"],"description":"A celestial body in the asteroid belt, serving as a transit hub for freighters and prospectors.","recentEvents":"The Adrianopole, a third-gen prospector, docked here after arriving from the Belt.","relationships":[{"location":"Ceres Station","relationship":"Linked via freighter routes and political tensions"}]},{"name":"Luna","description":"Earth's moon, a key node in interplanetary trade and military operations.","recentEvents":"The Badass Motherfucker freighter operated a triangle route between Luna, Ganymede, and the Belt.","relationships":[{"location":"Ganymede","relationship":"Connected via the Badass Motherfucker's trade route"},{"location":"Belt","relationship":"Part of a regional trade network"}]},{"name":"Triton","description":"Neptune's largest moon, home to deep astronomy labs repurposed by OPA-aligned prospectors.","recentEvents":"Prospectors sympathetic to the OPA occupied the labs, broadcasting Martian ship locations.","relationships":[{"location":"Belt","relationship":"Linked to OPA operations and resource conflicts"},{"location":"Mars","relationship":"Target of data broadcasts revealing Martian military assets"}]},{"name":"Eros Station Maintenance Corridor","aliases":["Eros","Eros Station","Maintenance Tunnel","Maintenance Shaft"],"arc":"OPA's Bioweapon Deployment and Strategic Manipulation","description":"A dimly lit service passage carved by early Belters, housing critical power lines and running through the first Belt colony's infrastructure.","recentEvents":"Miller and Holden use this corridor to evade guards and reach the hideout. Ko's body is carried through here.","relationships":[{"location":"Ceres Station","relationship":"Adjacent space station in the Belt"},{"location":"Scopuli","relationship":"Ship associated with the deceased Juliette Mao"},{"location":"Canterbury","relationship":"Home port of the freighter the Canterbury is responding to"},{"location":"Tycho Station","relationship":"Mole activity originated here"},{"location":"Radiation Shelters (Eros Station)","relationship":"Adjacent to the maintenance corridors"},{"location":"Casino Level","relationship":"Part of the lockdown area"},{"location":"MCRN Donnager","relationship":"Miller and Holden were rescued from Eros Station by the Donnager"},{"location":"Eros Station","relationship":"Part of the station's utility infrastructure"}]},{"name":"BA834024112","aliases":["Rock BA834024112","Julie's asteroid"],"arc":"Holden's Crew Survival and Escape","description":"A barren asteroid tethered to a wealthy owner, serving as a navigational warning.","recentEvents":"Holden and the crew of the Rocinante approach it, discovering a stealth ship linked to the Donnager's destruction.","relationships":[{"location":"Scopuli","relationship":"Linked to the shuttle that carried Julie and may hide the ship's remnants"},{"location":"Phoebe Station","relationship":"The Phoebe bug originated from this science station, connecting to Julie's infection"},{"location":"Ceres Station","relationship":"The Rocinante is en route to Ceres after analyzing data from this asteroid."}]},{"name":"Casino Level","aliases":["Radiological Shelter","Casino Area"],"description":"A restricted zone on Eros Station where the population is funneled during lockdowns, serving as a central gathering point.","recentEvents":"The level is under lockdown, with guards enforcing movement toward shelters. Miller and Holden use this as a strategic point to regroup.","relationships":[{"location":"Eros Station","relationship":"Part of the station's structure"}]},{"name":"Radiation Shelters (Eros Station)","aliases":["Radiation Lockdown Zones","Radiation Incubators"],"description":"Sealed-off sections of Eros Station purportedly designed to protect citizens from radiation, but secretly used as containment areas for lethal gas and biological agents.","recentEvents":"The shelters were emptied, leaving only Holden and Miller's footsteps. Ko's body is left here after being shot.","relationships":[{"location":"Eros Station","relationship":"Designated emergency lockdown zones"},{"location":"Ceres Station","relationship":"Linked via transit corridors"},{"location":"Eros Station Maintenance Corridor","relationship":"Located nearby"}]},{"name":"Thoth Station","description":"A space station where Captain Higgins sent a distress message about the deteriorating condition of his crew and secured materials before the ship's fate.","recentEvents":"Holden and his crew received a comm log from Thoth Station indicating the ship's crew was turning into 'vomit zombies' and materials were secured, with vector data for locating the ship.","relationships":[{"location":"Belt","relationship":"The ship's location is being tracked in the Belt, as per the comm log."},{"location":"Rocinante","relationship":"The comm log was received on the Rocinante, which is now searching for the ship."}],"arc":"Protogen's Protomolecule Experimentation and Alien Weapon Threat"}],"arcs":[{"name":"OPA's Bioweapon Containment, Thoth Station Tracking, and Strategic Manipulation","status":"active","characters":["Jim Holden","Naomi Nagata","Detective Miller"],"summary":"Holden and Miller analyze data implicating Earth's shipyards in the Donnager's destruction, revealing OPA's potential role in escalating the war. Holden's broadcast of the data risks exposing secrets, complicating OPA's containment efforts."},{"name":"Miller's Grief, Revenge, and Moral Conflict","status":"active","characters":["Detective Miller","Jim Holden"],"summary":"Miller confronts Holden about the broadcast's consequences, revealing his belief that Holden's actions triggered the Martian attack. Miller's moral conflict deepens as he weighs revenge against the greater threat of the protomolecule."},{"name":"Holden's Crew Survival and Escape","status":"active","characters":["Jim Holden","Naomi Nagata","Amos Burton","Detective Miller"],"summary":"The crew debates scuttling the Scopuli to avoid detection, balancing the ship's value against the risk of infection. Holden's decision to pursue the ship's secrets ties their survival to the broader conflict over the protomolecule."},{"name":"Protogen's Protomolecule Experimentation and Alien Weapon Threat","status":"active","characters":["Jim Holden","Detective Miller","Naomi Nagata"],"summary":"The Thoth Station logs confirm Protogen's experimentation on Eros, with the Scopuli as a mobile lab. The protomolecule's weaponization and its potential to reshape life remain a existential threat to the Belt and Mars."},{"name":"OPA's Bioweapon Containment and Strategic Manipulation","status":"active","characters":["Jim Holden","Detective Miller","Naomi Nagata","Amos Burton"],"summary":"Holden and Miller discover Thoth Station's distress logs revealing a contaminated stealth ship, implicating OPA's containment efforts and escalating the bioweapon's threat. The OPA's strategic manipulation of Earth's shipyards is now directly tied to the ship's disappearance."}],"summary":"Holden and his crew on the Rocinante are racing to locate a stealth ship based on cryptic comm logs from Thoth Station, which hint at a dire crew situation and hidden coordinates in the Belt. Meanwhile, a surprise attack by Earth ships on Martian forces has erupted, destroying the Deimos radar station and escalating tensions between the two powers."},"model":"qwen3:8b","appVersion":"0.1.0"},{"index":40,"result":{"characters":[{"name":"Juliette Andromeda Mao","aliases":["Julie Mao"],"importance":"main","status":"dead","lastSeen":"Chapter Twenty-Four: Miller","currentLocation":"Eros flophouse","description":"A captured crew member held in a storage locker, enduring eight days of isolation and dehydration while planning her escape. She discovers the ship's reactor has been replaced with an alien entity.","relationships":[{"character":"Dave","relationship":"Shipmate"},{"character":"Captain Darren","relationship":"Captain"},{"character":"Mike","relationship":"Shipmate"},{"character":"Wan Li","relationship":"Shipmate"},{"character":"Mao-Kwikowski Mercantile","relationship":"Family"},{"character":"Captain Shaddid","relationship":"Client"},{"character":"Detective Miller","relationship":"Target of search"}],"recentEvents":"Discovered dead in shower stall with severe biological modifications"},{"name":"Dave","aliases":[],"importance":"secondary","status":"dead","lastSeen":"Prologue: Julie","currentLocation":"Unknown","description":"Julie's shipmate and mechanic, who begged the captors not to take Julie before being thrown out an airlock.","relationships":[{"character":"Julie Mao","relationship":"Shipmate"}],"recentEvents":"Begged captors to spare Julie, was thrown out an airlock, and died."},{"name":"Captain Darren","aliases":[],"importance":"secondary","status":"dead","lastSeen":"Prologue: Julie","currentLocation":"Engineering deck","description":"The ship's captain who surrendered to the attackers without resistance, later found as a head fused to the alien reactor.","relationships":[{"character":"Julie Mao","relationship":"Captain"}],"recentEvents":"Surrendered to attackers, died after being part of the alien entity's fusion reactor."},{"name":"Mike","aliases":[],"importance":"secondary","status":"unknown","lastSeen":"Prologue: Julie","currentLocation":"Unknown","description":"A shipmate captured by the attackers along with others.","relationships":[{"character":"Julie Mao","relationship":"Shipmate"}],"recentEvents":"Captured by the attackers and taken off the ship."},{"name":"Wan Li","aliases":[],"importance":"secondary","status":"unknown","lastSeen":"Prologue: Julie","currentLocation":"Unknown","description":"A shipmate captured by the attackers along with others.","relationships":[{"character":"Julie Mao","relationship":"Shipmate"}],"recentEvents":"Captured by the attackers and taken off the ship."},{"name":"The Attackers","aliases":[],"importance":"secondary","status":"unknown","lastSeen":"Prologue: Julie","currentLocation":"Unknown","description":"The captors who took control of the ship, beat the crew, and sealed the ship's systems.","relationships":[{"character":"Julie Mao","relationship":"Captors"}],"recentEvents":"Captured the crew, sealed the ship, and replaced the reactor with an alien entity."},{"name":"Jim Holden","aliases":["James Holden","Holden"],"importance":"main","status":"alive","lastSeen":"Chapter Thirty-Six: Miller","currentLocation":"Rocinante","description":"Executive officer of the Canterbury, a colony transport ship. A former Earth navy officer with a cynical view of Belters and their physiology.","relationships":[{"character":"Naomi Nagata","relationship":"Close ally, whose perspective influences Holden's decisions"},{"character":"Ade Tukunbo","relationship":"Romantic interest"},{"character":"Captain McDowell","relationship":"Former commanding officer"},{"character":"Alex Kamal","relationship":"Crewmate and engineer"},{"character":"Amos Burton","relationship":"Crewmate and weapons expert"},{"character":"Shed Garvey","relationship":"Crew member"},{"character":"Captain Theresa Yao","relationship":"Debriefed by Martian naval officer"},{"character":"Kelly","relationship":"Crewmate (deceased)"},{"character":"Fred Johnson","relationship":"Business associate"},{"character":"Detective Miller","relationship":"Debates with Miller about broadcasting the protomolecule data"}],"recentEvents":"Discussed the implications of revealing the protomolecule's existence, considered strategies to prevent further conflict"},{"name":"Naomi Nagata","aliases":["Naomi"],"importance":"main","status":"alive","lastSeen":"Chapter Thirty-Five: Holden","currentLocation":"Rocinante","description":"Medical officer who tends to Miller and Holden. Engages in a tense conversation with Holden about his feelings for her.","relationships":[{"character":"Jim Holden","relationship":"Commander and romantic interest"},{"character":"Amos Burton","relationship":"Subordinate"},{"character":"Alex Kamal","relationship":"Crew member"},{"character":"Kelly","relationship":"Crewmate (deceased)"},{"character":"Fred Johnson","relationship":"Business associate"},{"character":"Detective Miller","relationship":"Fought alongside during ambush"}],"recentEvents":"Attempted to access the Thoth Station safe, discussed the ship's value, and debated methods to retrieve it."},{"name":"Amos Burton","aliases":["Amos"],"importance":"main","status":"alive","lastSeen":"Chapter Thirty-Six: Miller","currentLocation":"Rocinante","description":"Earthborn assistant to Naomi Nagata. Known for his loud personality and loyalty to Naomi.","relationships":[{"character":"Naomi Nagata","relationship":"Subordinate"},{"character":"Jim Holden","relationship":"Companion on the mission"},{"character":"Alex Kamal","relationship":"Crew member"},{"character":"Fred Johnson","relationship":"Business associate"},{"character":"Detective Miller","relationship":"Visited Miller's cabin, shared breakfast, and discussed the war's impact"}],"recentEvents":"Visited Miller's cabin, engaged in conversation about the war's consequences, and provided company during Miller's medical procedures"},{"name":"Shed Garvey","aliases":["Shed"],"importance":"secondary","status":"dead","lastSeen":"Chapter Eleven: Holden","currentLocation":"Donnager","description":"Medical tech responsible for treating injured crew members. Known for using medical maggots in procedures.","relationships":[{"character":"Cameron Paj","relationship":"Patient"},{"character":"Jim Holden","relationship":"Crew member"},{"character":"Naomi Nagata","relationship":"Crew member"},{"character":"Alex Kamal","relationship":"Crew member"}],"recentEvents":"Mentioned by Holden as someone he wished was still alive."},{"name":"Cameron Paj","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter Five: Holden","currentLocation":"Knight","description":"Crew member who lost his left arm in an ice-related accident. Uses a prosthetic limb.","relationships":[{"character":"Shed Garvey","relationship":"Crewmate"}],"recentEvents":"Implied to have an injured arm, mentioned by Shed during the aftermath."},{"name":"Ade Tukunbo","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter Five: Holden","currentLocation":"Knight","description":"Navigator with a Nigerian accent and a fondness for music. Has a flirtatious relationship with Holden.","relationships":[{"character":"Jim Holden","relationship":"Romantic interest"}],"recentEvents":"Attempted to power up the Knight's drive, survived the nuke blast, communicated with Holden during the crisis."},{"name":"Rebecca Byers","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter One: Holden","currentLocation":"Canterbury","description":"Comm officer with a sharp appearance and a history of legal troubles. Handles emergency communications.","relationships":[{"character":"Captain McDowell","relationship":"Subordinate"}],"recentEvents":"Received and relayed the emergency signal from an unknown ship."},{"name":"Captain McDowell","aliases":[],"importance":"main","status":"alive","lastSeen":"Chapter Five: Holden","currentLocation":"Knight","description":"Commanding officer of the Canterbury. A grizzled veteran with a distrust of corrective surgery.","relationships":[{"character":"Jim Holden","relationship":"Former subordinate"}],"recentEvents":"Gave Holden instructions for the broadcast operation"},{"name":"Detective Miller","aliases":["Miller"],"importance":"main","status":"alive","lastSeen":"Chapter Thirty-Six: Miller","currentLocation":"Rocinante","description":"Experienced security officer with a troubled past, investigating Julie Mao's disappearance while navigating political tensions between Mars, the Belt, and Earth.","relationships":[{"character":"Dmitri Havelock","relationship":"Partner"},{"character":"Captain Shaddid","relationship":"Superior"},{"character":"Juliette Andromeda Mao","relationship":"OPA contact"},{"character":"Havelock","relationship":"Partner who covers for Miller's absence"},{"character":"Octavia Muss","relationship":"Partner"},{"character":"Julie Mao","relationship":"Subject of investigation"},{"character":"Muss","relationship":"Partner"},{"character":"Shaddid","relationship":"Superior"},{"character":"Dawes","relationship":"Colleague"},{"character":"Inspector Sematimba","relationship":"Contacted for police assistance"},{"character":"Jim Holden","relationship":"Captain of the Rocinante, debates with Miller about broadcasting the protomolecule data"},{"character":"Naomi Nagata","relationship":"Aboard the Rocinante, with whom Miller discusses ethical dilemmas"},{"character":"Sematimba","relationship":"Contacted police"},{"character":"Amos Burton","relationship":"Team member"}],"recentEvents":"Engaged in a tense conversation with Holden about the risks of broadcasting the protomolecule data, discussed potential outcomes of the Martian conflict"},{"name":"Captain Shaddid","aliases":["Shaddid"],"importance":"main","status":"alive","lastSeen":"Chapter Thirty-Six: Miller","currentLocation":"Ceres Station","description":"Commander of Star Helix Security on Ceres, known for her pragmatic approach and disdain for inner planet residents.","relationships":[{"character":"Miller","relationship":"Subordinate"},{"character":"Julie Mao","relationship":"Client"},{"character":"Detective Miller","relationship":"Superior"},{"character":"OPA","relationship":"Leadership of the OPA's security apparatus"}],"recentEvents":"Announced the execution of Martian spies via a public video feed, emphasizing the OPA's stance on security"},{"name":"Alex Kamal","aliases":["Alex"],"importance":"main","status":"alive","lastSeen":"Chapter Thirty-Five: Holden","currentLocation":"Rocinante","description":"Crewmate and engineer, skeptical of Martian involvement in the Canterbury's destruction.","relationships":[{"character":"Jim Holden","relationship":"Companion on the mission"},{"character":"Naomi Nagata","relationship":"Crew member"},{"character":"Amos Burton","relationship":"Crew member"},{"character":"Shed Garvey","relationship":"Crew member"},{"character":"Kelly","relationship":"Crewmate (deceased)"},{"character":"Fred Johnson","relationship":"Business associate"}],"recentEvents":"Helped calculate potential destinations for the stealth ship."},{"name":"Dmitri Havelock","aliases":["Havelock"],"importance":"main","status":"alive","lastSeen":"Chapter Twelve: Miller","currentLocation":"Ceres","description":"Miller's partner and fellow security officer, who agrees to cover for Miller's absence while he investigates Julie Mao's case.","relationships":[{"character":"Detective Miller","relationship":"Partner"},{"character":"Miller","relationship":"Partner who covers for Miller's absence"},{"character":"Captain Shaddid","relationship":"Superior"}],"recentEvents":"Agreed to take sick leave to avoid potential conflict, supporting Miller's decision to continue the investigation despite OPA warnings."},{"name":"Hasini","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter Sixteen: Miller","currentLocation":"Blue Frog (Ceres Station)","description":"Assistant manager of the Blue Frog, a portside bar on Ceres, who interacted with Detective Miller.","relationships":[{"character":"Detective Miller","relationship":"Informal acquaintance"}],"recentEvents":"Accompanied Miller home after a drinking session, revealed his feelings for Julie Mao."},{"name":"Brown","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter Six: Miller","currentLocation":"Ceres","description":"Security officer with SWAT experience, leading crowd control wings.","relationships":[],"recentEvents":"Part of Miller's riot squad, led during the mob confrontation."},{"name":"Gelbfish","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter Six: Miller","currentLocation":"Ceres","description":"Security officer with SWAT experience, part of Miller's team.","relationships":[],"recentEvents":"Identified the shirtless man's OPA tattoo, participated in crowd control."},{"name":"Aberforth","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter Six: Miller","currentLocation":"Ceres","description":"Security officer with a history of excessive violence, placed in second-string role.","relationships":[],"recentEvents":"Assigned to secondary roles due to past disciplinary issues."},{"name":"Yevgeny","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter Six: Miller","currentLocation":"Ceres","description":"Homicide detective who commented on government offices during the crisis.","relationships":[],"recentEvents":"Mentioned the government's infrastructure status during Shaddid's briefing."},{"name":"Shirtless Man","aliases":[],"importance":"minor","status":"alive","lastSeen":"Chapter Eight: Miller","currentLocation":"Ceres","description":"A former suspect in a crime, now in Star Helix detainment infirmary preparing for trial.","relationships":[],"recentEvents":"Mentioned in context of Ceres Station's ongoing legal cases"},{"name":"OPA Man","aliases":[],"importance":"minor","status":"alive","lastSeen":"Chapter Ten: Miller","currentLocation":"Ceres","description":"An OPA representative with a pock-marked face, engaged in a tense conversation with Miller about OPA's role.","relationships":[{"character":"Detective Miller","relationship":"OPA contact"}],"recentEvents":"Discussed OPA's economic terrorism claims, denied involvement in Mateo Judd's death, and warned Miller to stay away."},{"name":"Wallace Fitz","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter Seven: Holden","currentLocation":"Saturn Station","description":"P and K legal counsel who issued formal orders to Holden and his crew.","relationships":[{"character":"Jim Holden","relationship":"Legal contact"}],"recentEvents":"Delivered official response to Holden's request for assistance, accused Holden of unfounded Martian accusations."},{"name":"Captain Theresa Yao","aliases":[],"importance":"main","status":"alive","lastSeen":"Chapter Eleven: Holden","currentLocation":"Donnager","description":"Commander of the Donnager, a Martian capital ship, overseeing the interrogation of Holden's crew.","relationships":[{"character":"Jim Holden","relationship":"Debriefed by Martian naval officer"}],"recentEvents":"Ordered the torpedo launch against the Belt ships and interrogated Holden about the pursuing vessels."},{"name":"Masked Woman","aliases":["Woman"],"importance":"minor","status":"alive","lastSeen":"Chapter Eight: Miller","currentLocation":"Ceres","description":"Victim beaten to death by the shirtless man, identified as a Martian freight line employee.","relationships":[],"recentEvents":"Featured in Miller's terminal screen as part of OPA propaganda"},{"name":"Fred Johnson","aliases":[],"importance":"main","status":"alive","lastSeen":"Chapter Twenty-One: Holden","currentLocation":"Tycho Station","description":"Colonel and leader of the Outer Planets Alliance, contacting Holden about potential Martian threats.","relationships":[{"character":"Jim Holden","relationship":"Communications contact"},{"character":"Naomi Nagata","relationship":"Business associate"},{"character":"Amos Burton","relationship":"Business associate"},{"character":"Alex Kamal","relationship":"Business associate"}],"recentEvents":"Negotiated the use of the Rocinante for an Eros mission, revealed the fictional Lionel Polanski, and discussed the data cube."},{"name":"Mateo Judd","aliases":[],"importance":"main","status":"dead","lastSeen":"Chapter Ten: Miller","currentLocation":"Ceres","description":"A dockworker accused of running an extortion scheme, later found dead with OPA ties.","relationships":[{"character":"Asher Kamamatsu","relationship":"Client"}],"recentEvents":"Sought protection from the OPA, was killed by OPA operatives after Miller's investigation."},{"name":"Lieutenant Lopez","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter Eleven: Holden","currentLocation":"Donnager","description":"Naval intelligence officer conducting an interrogation of Holden, using focus drugs to monitor his responses.","relationships":[{"character":"Jim Holden","relationship":"Interrogated by naval intelligence"}],"recentEvents":"Conducted a detailed interrogation of Holden, discussed the political tensions between Mars and the Belt, and fled to the combat zone after the torpedo attack."},{"name":"Chief Gunderson","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter Eleven: Holden","currentLocation":"Donnager","description":"Martian military chief responsible for escorting Holden's crew to their quarters.","relationships":[{"character":"Jim Holden","relationship":"Escorted to quarters"}],"recentEvents":"Led Holden's crew to their temporary accommodations and coordinated with Lieutenant Kelly for their protection."},{"name":"Anderson Dawes","aliases":["Dawes"],"importance":"main","status":"alive","lastSeen":"Chapter Sixteen: Miller","currentLocation":"Ceres Station","description":"OPA liaison who approaches Detective Miller to stop his investigation into Julie Mao's disappearance, claiming it could escalate tensions between Mars and the Belt.","relationships":[{"character":"Detective Miller","relationship":"OPA agent attempting to dissuade Miller from pursuing a kidnapping case"}],"recentEvents":"Argued against Miller's investigation, claimed Holden's capture, and emphasized corporate neutrality."},{"name":"The Jiu Jitsu Instructor","aliases":[],"importance":"minor","status":"alive","lastSeen":"Chapter Twelve: Miller","currentLocation":"Ceres","description":"Owner of the Ceres Center for Jiu Jitsu, who provides limited information about Julie Mao's background and training.","relationships":[]},{"name":"Enrique Dos Santos","aliases":[],"importance":"minor","status":"dead","lastSeen":"Chapter Fourteen: Miller","currentLocation":"Ceres","description":"","relationships":[],"recentEvents":"Tortured and displayed near sector eleven's water reclamation works; identified by terminal, wedding ring, and credit data"},{"name":"Octavia Muss","aliases":["Muss"],"importance":"secondary","status":"alive","lastSeen":"Chapter Eighteen: Miller","currentLocation":"Ceres Station","description":"A pragmatic detective who handles interrogations and provides Miller with critical case updates.","relationships":[{"character":"Detective Miller","relationship":"Colleague"},{"character":"Miller","relationship":"Partner"},{"character":"Shaddid","relationship":"Superior"}],"recentEvents":"Provided Miller with a rape case witness detail, skipped work to attend to a stop, and observed the political upheaval on Ceres."},{"name":"Kelly","aliases":["Lieutenant Kelly"],"importance":"main","status":"dead","lastSeen":"Chapter Fifteen: Holden","currentLocation":"Tachi","description":"Deceased marine who died during the battle on the Donnager.","relationships":[{"character":"Jim Holden","relationship":"Crewmate"},{"character":"Alex Kamal","relationship":"Crewmate"}],"recentEvents":"Died from severe injuries during the battle, then buried by the crew."},{"name":"Gomez","aliases":[],"importance":"secondary","status":"dead","lastSeen":"Chapter Fifteen: Holden","currentLocation":"Unknown","description":"Marine who died during the battle on the Donnager.","relationships":[{"character":"Jim Holden","relationship":"Crewmate"}],"recentEvents":"Killed by enemy fire while defending the Donnager."},{"name":"Immanuel Corvus Dowd","aliases":[],"importance":"main","status":"alive","lastSeen":"Chapter Eighteen: Miller","currentLocation":"Ceres Station detention cells","description":"A businessman arrested for rape, portrayed as a high-profile client with connections to influential war effort figures.","relationships":[{"character":"Harry","relationship":"Lawyer"}],"recentEvents":"Detained under a warrant following a rape investigation, confronted by Detective Miller, and subjected to legal scrutiny."},{"name":"Harry","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter Eighteen: Miller","currentLocation":"Ceres Station","description":"Immanuel Corvus Dowd's lawyer, who warns Miller of potential legal repercussions for his investigation.","relationships":[{"character":"Immanuel Corvus Dowd","relationship":"Client"}],"recentEvents":"Attempted to shield his client from arrest, engaged in tense dialogue with Miller, and exited the interrogation room."},{"name":"Young Woman in Cream-Colored Linen","aliases":[],"importance":"minor","status":"unknown","lastSeen":"Chapter Eighteen: Miller","currentLocation":"Ceres Station","description":"A professional-looking woman who briefly acknowledged Miller before entering the accountancy office.","relationships":[],"recentEvents":"Nodded to Miller as he left the accountancy office, displaying a calm, fighter-like demeanor."},{"name":"Bartender","aliases":[],"importance":"minor","status":"alive","lastSeen":"Chapter Nineteen: Holden","currentLocation":"Tycho Station","relationships":[]},{"name":"Singer","aliases":[],"importance":"minor","status":"alive","lastSeen":"Chapter Nineteen: Holden","currentLocation":"Tycho Station","relationships":[]},{"name":"Teenage Girls","aliases":[],"importance":"minor","status":"alive","lastSeen":"Chapter Nineteen: Holden","currentLocation":"Tycho Station","relationships":[]},{"name":"Lionel Polanski","aliases":[],"importance":"secondary","status":"unknown","lastSeen":"Chapter Twenty-Three: Holden","currentLocation":"Eros hotel room","description":"A fictional person Fred Johnson claims to need retrieved from Eros, owning the courier ship Scopuli.","relationships":[{"character":"Fred Johnson","relationship":"Target of retrieval"}],"recentEvents":"Targeted by Holden's group, last seen in his hotel room."},{"name":"Missionary","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter Twenty-Two: Miller","currentLocation":"Eros","description":"A traveling missionary with a name tag and Bible","relationships":[],"recentEvents":"Engaging in philosophical conversation about religion and war with Miller"},{"name":"Inspector Sematimba","aliases":["Sematimba"],"importance":"secondary","status":"alive","lastSeen":"Chapter Twenty-Six: Miller","currentLocation":"Eros flophouse","description":"Police officer who imposed a lockdown on Holden's ship.","relationships":[{"character":"Detective Miller","relationship":"Contacted for police assistance"},{"character":"Jim Holden","relationship":"Enforced lockdown"}],"recentEvents":"Imposed a lockdown on Holden's ship, communicated with Miller about jurisdictional concerns."},{"name":"Woman with the gun","aliases":[],"importance":"minor","status":"dead","lastSeen":"Chapter Twenty-Three: Holden","currentLocation":"Eros flophouse","description":"Armed assailant who confronted Holden's group.","relationships":[],"recentEvents":"Shot and killed during the confrontation at Lionel Polanski's flophouse."},{"name":"Guard","aliases":[],"importance":"minor","status":"alive","lastSeen":"Chapter Twenty-Seven: Holden","currentLocation":"Eros station","description":"A fake riot cop leading civilians to a radiation shelter.","relationships":[],"recentEvents":"Nudged by Miller after the shootout."},{"name":"Gabby Smalls","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter Twenty-Seven: Holden","currentLocation":"Ceres","description":"A mobster and police riot gear supervisor on Ceres, leading civilians to shelters.","relationships":[],"recentEvents":"Mentioned as a key figure in the Ceres protection racket."},{"name":"Mikey Ko","aliases":[],"importance":"secondary","status":"dead","lastSeen":"Chapter Twenty-Eight: Miller","currentLocation":"Eros station","description":"A guard who mistook Miller and Holden for Protogen installers, leading to his death at Miller's hands.","relationships":[{"character":"Detective Miller","relationship":"Victim of Miller's lethal action"},{"character":"Jim Holden","relationship":"Witness to Miller's confrontation"}],"recentEvents":"Was killed by Miller after revealing details about Protogen's operations on Eros."},{"name":"Mafia Thug","aliases":[],"importance":"minor","status":"dead","lastSeen":"Chapter Twenty-Nine: Holden","currentLocation":"Eros station","description":"A violent enforcer killed by Holden during a mob incident.","relationships":[],"recentEvents":"Shot and killed by Holden after firing on civilians."},{"name":"Child Victim","aliases":[],"importance":"minor","status":"dead","lastSeen":"Chapter Twenty-Nine: Holden","currentLocation":"Eros station","description":"A thirteen-year-old boy killed by the mafia thug during the chaos on Eros station.","relationships":[],"recentEvents":"Died from a gunshot wound to the chest, rescued by Holden."},{"name":"Mr. Dresden","aliases":["sociopath"],"importance":"main","status":"alive","lastSeen":"Chapter Thirty-Four: Miller","currentLocation":"Unknown","description":"A charismatic corporate executive presenting Protogen's findings on the protomolecule.","relationships":[],"recentEvents":"Delivered a presentation about the protomolecule as a weapon from an alien civilization."},{"name":"Captain Higgins","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter Thirty-Five: Holden","currentLocation":"Thoth Station","description":"Commander of a ship infected by a lethal alien pathogen.","relationships":[],"recentEvents":"Sent a final distress message about crew casualties and the ship's condition before losing contact."}],"locations":[{"name":"Scopuli","arc":"Holden's Crew Survival and Escape","description":"A stealth ship captured and repurposed, later found to be infected with a deadly biological agent.","recentEvents":"The ship's crew was killed by an unknown pathogen, with Julie Mao's body remaining in an unsealed locker.","relationships":[{"location":"Engineering deck","relationship":"Contains the ship's reactor and is the site of critical discoveries"},{"location":"Inner airlock","relationship":"Where Julie was initially confined and later accessed after escaping"},{"location":"MCRN Donnager","relationship":"The Scopuli's crew was transported here before their deaths."},{"location":"Eros Station","relationship":"The ship's contamination and events on Eros are interconnected."}]},{"name":"Engineering deck","aliases":["Engineering deck"],"arc":"Julie's Survival and Escape","description":"The ship's core area housing the fusion reactor and critical systems.","recentEvents":"Julie discovers the reactor's corrupted state, with biological material fused to its core. Captain Darren's head is found here.","relationships":[{"location":"Scopuli","relationship":"Central operational area of the ship"}]},{"name":"Inner airlock","aliases":["Inner airlock"],"description":"A sealed compartment connecting different sections of the ship.","recentEvents":"Julie was confined here for eight days before escaping. It served as a transition point between decks.","relationships":[{"location":"Scopuli","relationship":"Structural component of the ship"}]},{"name":"Canterbury","aliases":["Knight","Knight-class ship"],"arc":"OPA's Role in the Martian-Belt War","description":"A P and K shuttle craft carrying Jim Holden and his crew after the Canterbury's destruction.","recentEvents":"Holden's crew was boarded by Martian marines after docking, leading to an interrogation by Lieutenant Lopez and a tense standoff with approaching Belt ships.","relationships":[{"location":"Belt","relationship":"Travels between Saturn's rings and this region"},{"location":"Canterbury","relationship":"Adjacent spaceport for departure/arrival"},{"location":"CA-2216862","relationship":"Target location for salvage mission"},{"location":"MCRN Donnager","relationship":"Docked at the Donnager's docking bay"}]},{"name":"Belt","aliases":["Asteroid Belt"],"arc":"Protogen's Protomolecule Experimentation and Alien Weapon Threat","description":"The region of space where the Canterbury and other ships operate, containing numerous asteroids and debris.","recentEvents":"The Canterbury was destroyed here by a nuclear weapon fired by a stealth ship. Holden and the Knight crew pursued the attackers while hiding behind an asteroid.","relationships":[{"location":"Callisto","relationship":"Adjacent to a charted non-Belt asteroid"},{"location":"Canterbury","relationship":"Destroyed in this region"},{"location":"Knight","relationship":"Survived here after the Canterbury's destruction"}]},{"name":"Callisto","description":"A non-Belt asteroid where a damaged Martian freighter sent an emergency signal.","recentEvents":"The Canterbury diverted its route to investigate the distress beacon near this location.","relationships":[{"location":"Belt","relationship":"Located near the asteroid belt"}]},{"name":"Ceres Station","aliases":["Ceres Port","Ceres"],"arc":"OPA's Role in the Martian-Belt War","description":"A major Belt station and economic hub, home to six million people. Serves as a critical node in the conflict between Mars and the Belt.","recentEvents":"The OPA announced the execution of Martian spies via an industrial airlock, framing it as a necessary action for freedom.","relationships":[{"location":"Belt","relationship":"Central to Ceres' economic role as a transit point for Belt resources"},{"location":"Tycho Station","relationship":"Connected via trade routes and shared security concerns"},{"location":"Port Level","relationship":"Key area where the riot occurs"},{"location":"Station House","relationship":"Administrative center where security directives are issued"},{"location":"Ganymede","relationship":"Site of the Black Cat freighter's destination after transferring stolen riot gear"},{"location":"Io","relationship":"Destination of the perps who disposed of the murder weapon"},{"location":"Star Helix","relationship":"Former governing authority now withdrawn"},{"location":"Donnager","relationship":"Martian warship whose destruction triggered the Belt's uprising"},{"location":"Rocinante","relationship":"Holden and Miller discuss the protomolecule's data here"}]},{"name":"Tycho Station","aliases":["Tycho"],"arc":"Holden's Crew Survival and Escape","description":"Corporate station serving as a hub between the Belt and inner planets, known for its interplanetary transport operations.","recentEvents":"Holden plans to travel here to seek trusted allies regarding the protomolecule's safe.","relationships":[{"location":"Ceres","relationship":"Serves as a key waypoint for cargo and passenger traffic between the Belt and inner systems"},{"location":"Ceres Station","relationship":"Linked by the Belt's orbital pathways"},{"location":"Rocinante","relationship":"Holden's destination after leaving the ship"}]},{"name":"CA-2216862","aliases":["Asteroid 2216862"],"description":"A half-kilometer-wide asteroid in the asteroid belt, serving as a gravitational anchor for the Scopuli.","recentEvents":"The Scopuli was deliberately positioned near this asteroid, likely to exploit its microgravity for slow orbital capture.","relationships":[{"location":"Scopuli","relationship":"Gravitational anchor point"},{"location":"Belt","relationship":"Located within the asteroid belt"}]},{"name":"Port Level","description":"A bustling industrial area of Ceres Station where ships dock and cargo is handled, marked by high gravity and constant activity.","recentEvents":"Miller's squad confronts a violent mob, including an OPA-linked killer, to prevent the riot from escalating.","relationships":[{"location":"Ceres Station","relationship":"A distinct sector within the station"}]},{"name":"MCRN Donnager","aliases":["Donnager","Martian battleship"],"arc":"OPA's Role in the Martian-Belt War","description":"A massive Martian capital ship with a stark, utilitarian design, serving as a military base for Martian forces.","recentEvents":"Miller and Holden investigate the ship's engineering deck, discovering signs of a violent takeover and the presence of a mysterious infectious agent.","relationships":[{"location":"Saturn Station","relationship":"Origin of the order"},{"location":"Jupiter","relationship":"Destination for the Knight"},{"location":"Knight","relationship":"Hosted the docking and interrogation of the Knight"},{"location":"Belt","relationship":"Engaged in combat with Belt ships following a torpedo launch"},{"location":"Scopuli","relationship":"The Scopuli's crew was captured and held here before their deaths."},{"location":"Eros Station","relationship":"Events on Eros Station are linked to the ship's contamination and the crew's fate."}]},{"name":"Saturn Station","aliases":["Saturn Station"],"description":"A Martian-controlled space station where P and K legal counsel issued directives.","recentEvents":"Wallace Fitz communicated the order to head to Jupiter, escalating tensions with Mars.","relationships":[{"location":"Knight","relationship":"Source of the crew's orders"},{"location":"Ceres Station","relationship":"Previously mentioned in crew discussions"}]},{"name":"Jupiter","aliases":["Jupiter"],"description":"A gas giant and strategic destination for the Knight crew's flight path.","recentEvents":"Selected as a potential destination despite risks from unknown pursuers.","relationships":[{"location":"Belt","relationship":"Geographically adjacent region"},{"location":"MCRN Donnager","relationship":"Target location for the ship"}]},{"name":"Razorback","aliases":["Razorback"],"description":"A private racing vessel associated with the Mao family, symbolizing Julie Mao's past and the family's financial influence.","recentEvents":"Julie Mao's messages reveal her family's attempt to coerce her to return, referencing the ship's potential sale and its significance to her.","relationships":[{"location":"Ceres Station","relationship":"The Razorback is mentioned as a vessel tied to the Mao family's operations on Ceres."}]},{"name":"Anderson Station","aliases":["Anderson"],"description":"A minor Belt distribution station for water and air, infamous for the Massacre that made Fred Johnson a Belter hero.","recentEvents":"Fred Johnson's broadcast reveals the station's history as a site of Coalition brutality, framing it as a catalyst for OPA resistance.","relationships":[{"location":"Belt","relationship":"Part of the asteroid belt's contested regions"},{"location":"MCRN Donnager","relationship":"Johnson's message hints at potential Martian involvement in the current conflict"}]},{"name":"Phoebe Station","aliases":["Phoebe"],"description":"A science station in the asteroid belt, forbidden for Belters to dock at.","recentEvents":"Destroyed in an attack attributed to Belter guerrilla groups, with half its inhabitants dead or missing.","relationships":[{"location":"Ceres Station","relationship":"Linked via Belt political tensions"}]},{"name":"Hangar Bay","aliases":["Hangar"],"description":"A section of the Donnager containing multiple ships, including the Knight, where the crew attempts to escape.","recentEvents":"The crew fought through boarders to reach a corvette, with Lieutenant Kelly leading the evacuation.","relationships":[{"location":"MCRN Donnager","relationship":"Part of the ship's structure"},{"location":"Knight","relationship":"A ship stationed in the bay"}]},{"name":"Ganymede","description":"A moon with significant mining and trade operations in the Jupiter system.","recentEvents":"The Black Cat freighter, linked to stolen riot gear, made a stop here after departing Ceres.","relationships":[{"location":"Ceres Station","relationship":"Linked via the Black Cat's transit route"}]},{"name":"Io","arc":"OPA's Bioweapon Containment and Strategic Manipulation","description":"A volcanic moon in Jupiter's system, often used as a transit point for illicit operations.","recentEvents":"The perps who disposed of the murder weapon and stolen gear were headed here, though their arrival remains uncertain.","relationships":[{"location":"Ceres Station","relationship":"Linked via the Black Cat's transit route"}]},{"name":"Mars","aliases":["Martian Congressional Republic"],"arc":"Protogen's Protomolecule Experimentation and Alien Weapon Threat","description":"Planet at the center of a conflict with the Belt, governed by the Martian Congressional Republic.","recentEvents":"The Martian Congressional Republic declared open war against the Belt, citing security threats and economic sabotage, escalating tensions across the system.","relationships":[{"location":"Belt","relationship":"Region in armed conflict with Mars"},{"location":"Ceres Station","relationship":"Site of growing unrest due to the war's proximity"}]},{"name":"Pallas","aliases":["Pallas Station"],"description":"A celestial body in the asteroid belt, serving as a transit hub for freighters and prospectors.","recentEvents":"The Adrianopole, a third-gen prospector, docked here after arriving from the Belt.","relationships":[{"location":"Ceres Station","relationship":"Linked via freighter routes and political tensions"}]},{"name":"Luna","description":"Earth's moon, a key node in interplanetary trade and military operations.","recentEvents":"The Badass Motherfucker freighter operated a triangle route between Luna, Ganymede, and the Belt.","relationships":[{"location":"Ganymede","relationship":"Connected via the Badass Motherfucker's trade route"},{"location":"Belt","relationship":"Part of a regional trade network"}]},{"name":"Triton","description":"Neptune's largest moon, home to deep astronomy labs repurposed by OPA-aligned prospectors.","recentEvents":"Prospectors sympathetic to the OPA occupied the labs, broadcasting Martian ship locations.","relationships":[{"location":"Belt","relationship":"Linked to OPA operations and resource conflicts"},{"location":"Mars","relationship":"Target of data broadcasts revealing Martian military assets"}]},{"name":"Eros Station Maintenance Corridor","aliases":["Eros","Eros Station","Maintenance Tunnel","Maintenance Shaft","Eros flophouse","Eros station"],"arc":"OPA's Bioweapon Deployment and Strategic Manipulation","description":"A dimly lit service passage carved by early Belters, housing critical power lines and running through the first Belt colony's infrastructure.","recentEvents":"Miller reflects on past events tied to the station, including the death of Juliette Mao and the aftermath of the attack on Deimos.","relationships":[{"location":"Ceres Station","relationship":"Part of the Belt's interconnected stations"},{"location":"Scopuli","relationship":"Ship associated with the deceased Juliette Mao"},{"location":"Canterbury","relationship":"Home port of the freighter the Canterbury is responding to"},{"location":"Tycho Station","relationship":"Mole activity originated here"},{"location":"Radiation Shelters (Eros Station)","relationship":"Adjacent to the maintenance corridors"},{"location":"Casino Level","relationship":"Part of the lockdown area"},{"location":"MCRN Donnager","relationship":"Miller and Holden were rescued from Eros Station by the Donnager"},{"location":"Eros Station","relationship":"Part of the station's utility infrastructure"},{"location":"Rocinante","relationship":"Miller's temporary residence before departing"}]},{"name":"BA834024112","aliases":["Rock BA834024112","Julie's asteroid"],"arc":"Holden's Crew Survival and Escape","description":"A barren asteroid tethered to a wealthy owner, serving as a navigational warning.","recentEvents":"Holden and the crew of the Rocinante approach it, discovering a stealth ship linked to the Donnager's destruction.","relationships":[{"location":"Scopuli","relationship":"Linked to the shuttle that carried Julie and may hide the ship's remnants"},{"location":"Phoebe Station","relationship":"The Phoebe bug originated from this science station, connecting to Julie's infection"},{"location":"Ceres Station","relationship":"The Rocinante is en route to Ceres after analyzing data from this asteroid."}]},{"name":"Casino Level","aliases":["Radiological Shelter","Casino Area"],"description":"A restricted zone on Eros Station where the population is funneled during lockdowns, serving as a central gathering point.","recentEvents":"The level is under lockdown, with guards enforcing movement toward shelters. Miller and Holden use this as a strategic point to regroup.","relationships":[{"location":"Eros Station","relationship":"Part of the station's structure"}]},{"name":"Radiation Shelters (Eros Station)","aliases":["Radiation Lockdown Zones","Radiation Incubators"],"description":"Sealed-off sections of Eros Station purportedly designed to protect citizens from radiation, but secretly used as containment areas for lethal gas and biological agents.","recentEvents":"The shelters were emptied, leaving only Holden and Miller's footsteps. Ko's body is left here after being shot.","relationships":[{"location":"Eros Station","relationship":"Designated emergency lockdown zones"},{"location":"Ceres Station","relationship":"Linked via transit corridors"},{"location":"Eros Station Maintenance Corridor","relationship":"Located nearby"}]},{"name":"Thoth Station","arc":"OPA's Bioweapon Containment and Strategic Manipulation","description":"A space station where Captain Higgins sent a distress message about the deteriorating condition of his crew and secured materials before the ship's fate.","recentEvents":"Holden and his crew received a comm log from Thoth Station indicating the ship's crew was turning into 'vomit zombies' and materials were secured, with vector data for locating the ship.","relationships":[{"location":"Belt","relationship":"The ship's location is being tracked in the Belt, as per the comm log."},{"location":"Rocinante","relationship":"The comm log was received on the Rocinante, which is now searching for the ship."}]},{"name":"Rocinante","aliases":["Roci"],"description":"A private ship used by the crew, serving as their mobile base of operations.","recentEvents":"Miller and Holden debate the ethical implications of broadcasting the protomolecule's data, with Holden deciding to proceed to Tycho Station.","relationships":[{"location":"Ceres Station","relationship":"Linked via the Belt's communication networks"},{"location":"Tycho Station","relationship":"Holden's next destination"}],"arc":"OPA's Bioweapon Containment and Strategic Manipulation"}],"arcs":[{"name":"OPA's Bioweapon Containment and Strategic Manipulation","status":"active","characters":["Jim Holden","Detective Miller","OPA","Naomi Nagata","Amos Burton"],"summary":"Holden and Miller discover Thoth Station's distress logs revealing a contaminated stealth ship, implicating OPA's containment efforts and escalating the bioweapon's threat. The OPA's strategic manipulation of Earth's shipyards is now directly tied to the ship's disappearance."},{"name":"Miller's Grief, Revenge, and Moral Conflict","status":"active","characters":["Detective Miller","Jim Holden"],"summary":"Miller confronts Holden about the ethical implications of broadcasting the protomolecule data, questioning whether exposing the truth will prevent or accelerate violence. Holden's refusal to abandon the broadcast plan deepens Miller's moral dilemma."},{"name":"Holden's Crew Survival and Escape","status":"active","characters":["Jim Holden","Naomi Nagata","Amos Burton"],"summary":"Holden decides to head to Tycho Station, seeking an ally to navigate the escalating conflict. The crew's survival hinges on their ability to outmaneuver both Martian forces and OPA interests while protecting the protomolecule data."},{"name":"Protogen's Protomolecule Experimentation and Alien Weapon Threat","status":"active","characters":["Jim Holden","Detective Miller","OPA"],"summary":"The protomolecule's weaponization remains a existential threat as Holden and Miller debate its dissemination. Holden's plan to broadcast the data risks triggering global conflict, while Miller advocates for containment to prevent further violence."}],"summary":"Miller and Holden grapple with the moral dilemma of exposing the protomolecule's data, as the OPA escalates its crackdown on Martian spies on Ceres. Holden resolves to seek allies on Tycho Station, while Miller questions the potential for violence and chaos if the truth is revealed. The narrative underscores the fragile balance of power in the Belt and the cost of political maneuvering."},"model":"qwen3:8b","appVersion":"0.1.0"},{"index":41,"result":{"characters":[{"name":"Juliette Andromeda Mao","aliases":["Julie Mao"],"importance":"main","status":"dead","lastSeen":"Chapter Twenty-Four: Miller","currentLocation":"Eros flophouse","description":"A captured crew member held in a storage locker, enduring eight days of isolation and dehydration while planning her escape. She discovers the ship's reactor has been replaced with an alien entity.","relationships":[{"character":"Dave","relationship":"Shipmate"},{"character":"Captain Darren","relationship":"Captain"},{"character":"Mike","relationship":"Shipmate"},{"character":"Wan Li","relationship":"Shipmate"},{"character":"Mao-Kwikowski Mercantile","relationship":"Family"},{"character":"Captain Shaddid","relationship":"Client"},{"character":"Detective Miller","relationship":"Target of search"}],"recentEvents":"Discovered dead in shower stall with severe biological modifications"},{"name":"Dave","aliases":[],"importance":"secondary","status":"dead","lastSeen":"Prologue: Julie","currentLocation":"Unknown","description":"Julie's shipmate and mechanic, who begged the captors not to take Julie before being thrown out an airlock.","relationships":[{"character":"Julie Mao","relationship":"Shipmate"}],"recentEvents":"Begged captors to spare Julie, was thrown out an airlock, and died."},{"name":"Captain Darren","aliases":[],"importance":"secondary","status":"dead","lastSeen":"Prologue: Julie","currentLocation":"Engineering deck","description":"The ship's captain who surrendered to the attackers without resistance, later found as a head fused to the alien reactor.","relationships":[{"character":"Julie Mao","relationship":"Captain"}],"recentEvents":"Surrendered to attackers, died after being part of the alien entity's fusion reactor."},{"name":"Mike","aliases":[],"importance":"secondary","status":"unknown","lastSeen":"Prologue: Julie","currentLocation":"Unknown","description":"A shipmate captured by the attackers along with others.","relationships":[{"character":"Julie Mao","relationship":"Shipmate"}],"recentEvents":"Captured by the attackers and taken off the ship."},{"name":"Wan Li","aliases":[],"importance":"secondary","status":"unknown","lastSeen":"Prologue: Julie","currentLocation":"Unknown","description":"A shipmate captured by the attackers along with others.","relationships":[{"character":"Julie Mao","relationship":"Shipmate"}],"recentEvents":"Captured by the attackers and taken off the ship."},{"name":"The Attackers","aliases":[],"importance":"secondary","status":"unknown","lastSeen":"Prologue: Julie","currentLocation":"Unknown","description":"The captors who took control of the ship, beat the crew, and sealed the ship's systems.","relationships":[{"character":"Julie Mao","relationship":"Captors"}],"recentEvents":"Captured the crew, sealed the ship, and replaced the reactor with an alien entity."},{"name":"Jim Holden","aliases":["James Holden","Holden"],"importance":"main","status":"alive","lastSeen":"Chapter Thirty-Seven: Holden","currentLocation":"Tycho Station","description":"Executive officer of the Canterbury, a colony transport ship. A former Earth navy officer with a cynical view of Belters and their physiology.","relationships":[{"character":"Naomi Nagata","relationship":"Close ally, whose perspective influences Holden's decisions"},{"character":"Ade Tukunbo","relationship":"Romantic interest"},{"character":"Captain McDowell","relationship":"Former commanding officer"},{"character":"Alex Kamal","relationship":"Crewmate and engineer"},{"character":"Amos Burton","relationship":"Crewmate and weapons expert"},{"character":"Shed Garvey","relationship":"Crew member"},{"character":"Captain Theresa Yao","relationship":"Debriefed by Martian naval officer"},{"character":"Kelly","relationship":"Crewmate (deceased)"},{"character":"Fred Johnson","relationship":"Business associate"},{"character":"Detective Miller","relationship":"Debates with Miller about broadcasting the protomolecule data"},{"character":"Miller","relationship":"Crewmate and former detective"}],"recentEvents":"Led a crew dinner on the Rocinante, discussed the protomolecule's purpose, and planned to meet Fred Johnson at Tycho Station."},{"name":"Naomi Nagata","aliases":["Naomi"],"importance":"main","status":"alive","lastSeen":"Chapter Thirty-Seven: Holden","currentLocation":"Tycho Station","description":"Medical officer who tends to Miller and Holden. Engages in a tense conversation with Holden about his feelings for her.","relationships":[{"character":"Jim Holden","relationship":"Commander and romantic interest"},{"character":"Amos Burton","relationship":"Subordinate"},{"character":"Alex Kamal","relationship":"Crew member"},{"character":"Kelly","relationship":"Crewmate (deceased)"},{"character":"Fred Johnson","relationship":"Business associate"},{"character":"Detective Miller","relationship":"Fought alongside during ambush"},{"character":"Miller","relationship":"Crewmate and former detective"}],"recentEvents":"Participated in dinner discussions about the protomolecule, shared theories on its purpose, and interacted with Holden during the meal."},{"name":"Amos Burton","aliases":["Amos"],"importance":"main","status":"alive","lastSeen":"Chapter Thirty-Seven: Holden","currentLocation":"Tycho Station","description":"Earthborn assistant to Naomi Nagata. Known for his loud personality and loyalty to Naomi.","relationships":[{"character":"Naomi Nagata","relationship":"Subordinate"},{"character":"Jim Holden","relationship":"Companion on the mission"},{"character":"Alex Kamal","relationship":"Crew member"},{"character":"Fred Johnson","relationship":"Business associate"},{"character":"Detective Miller","relationship":"Visited Miller's cabin, shared breakfast, and discussed the war's impact"}],"recentEvents":"Contributed to dinner conversations, laughed at Miller's stories, and discussed the cheese shortage's role in Eros' destruction."},{"name":"Shed Garvey","aliases":["Shed"],"importance":"secondary","status":"dead","lastSeen":"Chapter Eleven: Holden","currentLocation":"Donnager","description":"Medical tech responsible for treating injured crew members. Known for using medical maggots in procedures.","relationships":[{"character":"Cameron Paj","relationship":"Patient"},{"character":"Jim Holden","relationship":"Crew member"},{"character":"Naomi Nagata","relationship":"Crew member"},{"character":"Alex Kamal","relationship":"Crew member"}],"recentEvents":"Mentioned by Holden as someone he wished was still alive."},{"name":"Cameron Paj","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter Five: Holden","currentLocation":"Knight","description":"Crew member who lost his left arm in an ice-related accident. Uses a prosthetic limb.","relationships":[{"character":"Shed Garvey","relationship":"Crewmate"}],"recentEvents":"Implied to have an injured arm, mentioned by Shed during the aftermath."},{"name":"Ade Tukunbo","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter Five: Holden","currentLocation":"Knight","description":"Navigator with a Nigerian accent and a fondness for music. Has a flirtatious relationship with Holden.","relationships":[{"character":"Jim Holden","relationship":"Romantic interest"}],"recentEvents":"Attempted to power up the Knight's drive, survived the nuke blast, communicated with Holden during the crisis."},{"name":"Rebecca Byers","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter One: Holden","currentLocation":"Canterbury","description":"Comm officer with a sharp appearance and a history of legal troubles. Handles emergency communications.","relationships":[{"character":"Captain McDowell","relationship":"Subordinate"}],"recentEvents":"Received and relayed the emergency signal from an unknown ship."},{"name":"Captain McDowell","aliases":[],"importance":"main","status":"alive","lastSeen":"Chapter Five: Holden","currentLocation":"Knight","description":"Commanding officer of the Canterbury. A grizzled veteran with a distrust of corrective surgery.","relationships":[{"character":"Jim Holden","relationship":"Former subordinate"}],"recentEvents":"Gave Holden instructions for the broadcast operation"},{"name":"Detective Miller","aliases":["Miller"],"importance":"main","status":"alive","lastSeen":"Chapter Thirty-Seven: Holden","currentLocation":"Tycho Station","description":"Experienced security officer with a troubled past, investigating Julie Mao's disappearance while navigating political tensions between Mars, the Belt, and Earth.","relationships":[{"character":"Dmitri Havelock","relationship":"Partner"},{"character":"Captain Shaddid","relationship":"Superior"},{"character":"Juliette Andromeda Mao","relationship":"OPA contact"},{"character":"Havelock","relationship":"Partner who covers for Miller's absence"},{"character":"Octavia Muss","relationship":"Partner"},{"character":"Julie Mao","relationship":"Subject of investigation"},{"character":"Muss","relationship":"Partner"},{"character":"Shaddid","relationship":"Superior"},{"character":"Dawes","relationship":"Colleague"},{"character":"Inspector Sematimba","relationship":"Contacted for police assistance"},{"character":"Jim Holden","relationship":"Captain of the Rocinante, debates with Miller about broadcasting the protomolecule data"},{"character":"Naomi Nagata","relationship":"Aboard the Rocinante, with whom Miller discusses ethical dilemmas"},{"character":"Sematimba","relationship":"Contacted police"},{"character":"Amos Burton","relationship":"Team member"},{"character":"Alex Kamal","relationship":"Crewmate"}],"recentEvents":"Engaged in dinner conversations about the protomolecule, shared stories about Belt culture, and discussed strategies to stop Protogen."},{"name":"Captain Shaddid","aliases":["Shaddid"],"importance":"main","status":"alive","lastSeen":"Chapter Thirty-Six: Miller","currentLocation":"Ceres Station","description":"Commander of Star Helix Security on Ceres, known for her pragmatic approach and disdain for inner planet residents.","relationships":[{"character":"Miller","relationship":"Subordinate"},{"character":"Julie Mao","relationship":"Client"},{"character":"Detective Miller","relationship":"Superior"},{"character":"OPA","relationship":"Leadership of the OPA's security apparatus"}],"recentEvents":"Announced the execution of Martian spies via a public video feed, emphasizing the OPA's stance on security"},{"name":"Alex Kamal","aliases":["Alex"],"importance":"main","status":"alive","lastSeen":"Chapter Thirty-Seven: Holden","currentLocation":"Tycho Station","description":"Crewmate and engineer, skeptical of Martian involvement in the Canterbury's destruction.","relationships":[{"character":"Jim Holden","relationship":"Companion on the mission"},{"character":"Naomi Nagata","relationship":"Crew member"},{"character":"Amos Burton","relationship":"Crew member"},{"character":"Shed Garvey","relationship":"Crew member"},{"character":"Kelly","relationship":"Crewmate (deceased)"},{"character":"Fred Johnson","relationship":"Business associate"},{"character":"Miller","relationship":"Crewmate"}],"recentEvents":"Helped prepare fake food for dinner, shared jokes, and participated in discussions about the protomolecule."},{"name":"Dmitri Havelock","aliases":["Havelock"],"importance":"main","status":"alive","lastSeen":"Chapter Twelve: Miller","currentLocation":"Ceres","description":"Miller's partner and fellow security officer, who agrees to cover for Miller's absence while he investigates Julie Mao's case.","relationships":[{"character":"Detective Miller","relationship":"Partner"},{"character":"Miller","relationship":"Partner who covers for Miller's absence"},{"character":"Captain Shaddid","relationship":"Superior"}],"recentEvents":"Agreed to take sick leave to avoid potential conflict, supporting Miller's decision to continue the investigation despite OPA warnings."},{"name":"Hasini","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter Sixteen: Miller","currentLocation":"Blue Frog (Ceres Station)","description":"Assistant manager of the Blue Frog, a portside bar on Ceres, who interacted with Detective Miller.","relationships":[{"character":"Detective Miller","relationship":"Informal acquaintance"}],"recentEvents":"Accompanied Miller home after a drinking session, revealed his feelings for Julie Mao."},{"name":"Brown","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter Six: Miller","currentLocation":"Ceres","description":"Security officer with SWAT experience, leading crowd control wings.","relationships":[],"recentEvents":"Part of Miller's riot squad, led during the mob confrontation."},{"name":"Gelbfish","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter Six: Miller","currentLocation":"Ceres","description":"Security officer with SWAT experience, part of Miller's team.","relationships":[],"recentEvents":"Identified the shirtless man's OPA tattoo, participated in crowd control."},{"name":"Aberforth","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter Six: Miller","currentLocation":"Ceres","description":"Security officer with a history of excessive violence, placed in second-string role.","relationships":[],"recentEvents":"Assigned to secondary roles due to past disciplinary issues."},{"name":"Yevgeny","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter Six: Miller","currentLocation":"Ceres","description":"Homicide detective who commented on government offices during the crisis.","relationships":[],"recentEvents":"Mentioned the government's infrastructure status during Shaddid's briefing."},{"name":"Shirtless Man","aliases":[],"importance":"minor","status":"alive","lastSeen":"Chapter Eight: Miller","currentLocation":"Ceres","description":"A former suspect in a crime, now in Star Helix detainment infirmary preparing for trial.","relationships":[],"recentEvents":"Mentioned in context of Ceres Station's ongoing legal cases"},{"name":"OPA Man","aliases":[],"importance":"minor","status":"alive","lastSeen":"Chapter Ten: Miller","currentLocation":"Ceres","description":"An OPA representative with a pock-marked face, engaged in a tense conversation with Miller about OPA's role.","relationships":[{"character":"Detective Miller","relationship":"OPA contact"}],"recentEvents":"Discussed OPA's economic terrorism claims, denied involvement in Mateo Judd's death, and warned Miller to stay away."},{"name":"Wallace Fitz","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter Seven: Holden","currentLocation":"Saturn Station","description":"P and K legal counsel who issued formal orders to Holden and his crew.","relationships":[{"character":"Jim Holden","relationship":"Legal contact"}],"recentEvents":"Delivered official response to Holden's request for assistance, accused Holden of unfounded Martian accusations."},{"name":"Captain Theresa Yao","aliases":[],"importance":"main","status":"alive","lastSeen":"Chapter Eleven: Holden","currentLocation":"Donnager","description":"Commander of the Donnager, a Martian capital ship, overseeing the interrogation of Holden's crew.","relationships":[{"character":"Jim Holden","relationship":"Debriefed by Martian naval officer"}],"recentEvents":"Ordered the torpedo launch against the Belt ships and interrogated Holden about the pursuing vessels."},{"name":"Masked Woman","aliases":["Woman"],"importance":"minor","status":"alive","lastSeen":"Chapter Eight: Miller","currentLocation":"Ceres","description":"Victim beaten to death by the shirtless man, identified as a Martian freight line employee.","relationships":[],"recentEvents":"Featured in Miller's terminal screen as part of OPA propaganda"},{"name":"Fred Johnson","aliases":[],"importance":"main","status":"alive","lastSeen":"Chapter Twenty-One: Holden","currentLocation":"Tycho Station","description":"Colonel and leader of the Outer Planets Alliance, contacting Holden about potential Martian threats.","relationships":[{"character":"Jim Holden","relationship":"Communications contact"},{"character":"Naomi Nagata","relationship":"Business associate"},{"character":"Amos Burton","relationship":"Business associate"},{"character":"Alex Kamal","relationship":"Business associate"}],"recentEvents":"Negotiated the use of the Rocinante for an Eros mission, revealed the fictional Lionel Polanski, and discussed the data cube."},{"name":"Mateo Judd","aliases":[],"importance":"main","status":"dead","lastSeen":"Chapter Ten: Miller","currentLocation":"Ceres","description":"A dockworker accused of running an extortion scheme, later found dead with OPA ties.","relationships":[{"character":"Asher Kamamatsu","relationship":"Client"}],"recentEvents":"Sought protection from the OPA, was killed by OPA operatives after Miller's investigation."},{"name":"Lieutenant Lopez","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter Eleven: Holden","currentLocation":"Donnager","description":"Naval intelligence officer conducting an interrogation of Holden, using focus drugs to monitor his responses.","relationships":[{"character":"Jim Holden","relationship":"Interrogated by naval intelligence"}],"recentEvents":"Conducted a detailed interrogation of Holden, discussed the political tensions between Mars and the Belt, and fled to the combat zone after the torpedo attack."},{"name":"Chief Gunderson","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter Eleven: Holden","currentLocation":"Donnager","description":"Martian military chief responsible for escorting Holden's crew to their quarters.","relationships":[{"character":"Jim Holden","relationship":"Escorted to quarters"}],"recentEvents":"Led Holden's crew to their temporary accommodations and coordinated with Lieutenant Kelly for their protection."},{"name":"Anderson Dawes","aliases":["Dawes"],"importance":"main","status":"alive","lastSeen":"Chapter Sixteen: Miller","currentLocation":"Ceres Station","description":"OPA liaison who approaches Detective Miller to stop his investigation into Julie Mao's disappearance, claiming it could escalate tensions between Mars and the Belt.","relationships":[{"character":"Detective Miller","relationship":"OPA agent attempting to dissuade Miller from pursuing a kidnapping case"}],"recentEvents":"Argued against Miller's investigation, claimed Holden's capture, and emphasized corporate neutrality."},{"name":"The Jiu Jitsu Instructor","aliases":[],"importance":"minor","status":"alive","lastSeen":"Chapter Twelve: Miller","currentLocation":"Ceres","description":"Owner of the Ceres Center for Jiu Jitsu, who provides limited information about Julie Mao's background and training.","relationships":[]},{"name":"Enrique Dos Santos","aliases":[],"importance":"minor","status":"dead","lastSeen":"Chapter Fourteen: Miller","currentLocation":"Ceres","description":"","relationships":[],"recentEvents":"Tortured and displayed near sector eleven's water reclamation works; identified by terminal, wedding ring, and credit data"},{"name":"Octavia Muss","aliases":["Muss"],"importance":"secondary","status":"alive","lastSeen":"Chapter Eighteen: Miller","currentLocation":"Ceres Station","description":"A pragmatic detective who handles interrogations and provides Miller with critical case updates.","relationships":[{"character":"Detective Miller","relationship":"Colleague"},{"character":"Miller","relationship":"Partner"},{"character":"Shaddid","relationship":"Superior"}],"recentEvents":"Provided Miller with a rape case witness detail, skipped work to attend to a stop, and observed the political upheaval on Ceres."},{"name":"Kelly","aliases":["Lieutenant Kelly"],"importance":"main","status":"dead","lastSeen":"Chapter Fifteen: Holden","currentLocation":"Tachi","description":"Deceased marine who died during the battle on the Donnager.","relationships":[{"character":"Jim Holden","relationship":"Crewmate"},{"character":"Alex Kamal","relationship":"Crewmate"}],"recentEvents":"Died from severe injuries during the battle, then buried by the crew."},{"name":"Gomez","aliases":[],"importance":"secondary","status":"dead","lastSeen":"Chapter Fifteen: Holden","currentLocation":"Unknown","description":"Marine who died during the battle on the Donnager.","relationships":[{"character":"Jim Holden","relationship":"Crewmate"}],"recentEvents":"Killed by enemy fire while defending the Donnager."},{"name":"Immanuel Corvus Dowd","aliases":[],"importance":"main","status":"alive","lastSeen":"Chapter Eighteen: Miller","currentLocation":"Ceres Station detention cells","description":"A businessman arrested for rape, portrayed as a high-profile client with connections to influential war effort figures.","relationships":[{"character":"Harry","relationship":"Lawyer"}],"recentEvents":"Detained under a warrant following a rape investigation, confronted by Detective Miller, and subjected to legal scrutiny."},{"name":"Harry","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter Eighteen: Miller","currentLocation":"Ceres Station","description":"Immanuel Corvus Dowd's lawyer, who warns Miller of potential legal repercussions for his investigation.","relationships":[{"character":"Immanuel Corvus Dowd","relationship":"Client"}],"recentEvents":"Attempted to shield his client from arrest, engaged in tense dialogue with Miller, and exited the interrogation room."},{"name":"Young Woman in Cream-Colored Linen","aliases":[],"importance":"minor","status":"unknown","lastSeen":"Chapter Eighteen: Miller","currentLocation":"Ceres Station","description":"A professional-looking woman who briefly acknowledged Miller before entering the accountancy office.","relationships":[],"recentEvents":"Nodded to Miller as he left the accountancy office, displaying a calm, fighter-like demeanor."},{"name":"Bartender","aliases":[],"importance":"minor","status":"alive","lastSeen":"Chapter Nineteen: Holden","currentLocation":"Tycho Station","relationships":[]},{"name":"Singer","aliases":[],"importance":"minor","status":"alive","lastSeen":"Chapter Nineteen: Holden","currentLocation":"Tycho Station","relationships":[]},{"name":"Teenage Girls","aliases":[],"importance":"minor","status":"alive","lastSeen":"Chapter Nineteen: Holden","currentLocation":"Tycho Station","relationships":[]},{"name":"Lionel Polanski","aliases":[],"importance":"secondary","status":"unknown","lastSeen":"Chapter Twenty-Three: Holden","currentLocation":"Eros hotel room","description":"A fictional person Fred Johnson claims to need retrieved from Eros, owning the courier ship Scopuli.","relationships":[{"character":"Fred Johnson","relationship":"Target of retrieval"}],"recentEvents":"Targeted by Holden's group, last seen in his hotel room."},{"name":"Missionary","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter Twenty-Two: Miller","currentLocation":"Eros","description":"A traveling missionary with a name tag and Bible","relationships":[],"recentEvents":"Engaging in philosophical conversation about religion and war with Miller"},{"name":"Inspector Sematimba","aliases":["Sematimba"],"importance":"secondary","status":"alive","lastSeen":"Chapter Twenty-Six: Miller","currentLocation":"Eros flophouse","description":"Police officer who imposed a lockdown on Holden's ship.","relationships":[{"character":"Detective Miller","relationship":"Contacted for police assistance"},{"character":"Jim Holden","relationship":"Enforced lockdown"}],"recentEvents":"Imposed a lockdown on Holden's ship, communicated with Miller about jurisdictional concerns."},{"name":"Woman with the gun","aliases":[],"importance":"minor","status":"dead","lastSeen":"Chapter Twenty-Three: Holden","currentLocation":"Eros flophouse","description":"Armed assailant who confronted Holden's group.","relationships":[],"recentEvents":"Shot and killed during the confrontation at Lionel Polanski's flophouse."},{"name":"Guard","aliases":[],"importance":"minor","status":"alive","lastSeen":"Chapter Twenty-Seven: Holden","currentLocation":"Eros station","description":"A fake riot cop leading civilians to a radiation shelter.","relationships":[],"recentEvents":"Nudged by Miller after the shootout."},{"name":"Gabby Smalls","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter Twenty-Seven: Holden","currentLocation":"Ceres","description":"A mobster and police riot gear supervisor on Ceres, leading civilians to shelters.","relationships":[],"recentEvents":"Mentioned as a key figure in the Ceres protection racket."},{"name":"Mikey Ko","aliases":[],"importance":"secondary","status":"dead","lastSeen":"Chapter Twenty-Eight: Miller","currentLocation":"Eros station","description":"A guard who mistook Miller and Holden for Protogen installers, leading to his death at Miller's hands.","relationships":[{"character":"Detective Miller","relationship":"Victim of Miller's lethal action"},{"character":"Jim Holden","relationship":"Witness to Miller's confrontation"}],"recentEvents":"Was killed by Miller after revealing details about Protogen's operations on Eros."},{"name":"Mafia Thug","aliases":[],"importance":"minor","status":"dead","lastSeen":"Chapter Twenty-Nine: Holden","currentLocation":"Eros station","description":"A violent enforcer killed by Holden during a mob incident.","relationships":[],"recentEvents":"Shot and killed by Holden after firing on civilians."},{"name":"Child Victim","aliases":[],"importance":"minor","status":"dead","lastSeen":"Chapter Twenty-Nine: Holden","currentLocation":"Eros station","description":"A thirteen-year-old boy killed by the mafia thug during the chaos on Eros station.","relationships":[],"recentEvents":"Died from a gunshot wound to the chest, rescued by Holden."},{"name":"Mr. Dresden","aliases":["sociopath"],"importance":"main","status":"alive","lastSeen":"Chapter Thirty-Four: Miller","currentLocation":"Unknown","description":"A charismatic corporate executive presenting Protogen's findings on the protomolecule.","relationships":[],"recentEvents":"Delivered a presentation about the protomolecule as a weapon from an alien civilization."},{"name":"Captain Higgins","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter Thirty-Five: Holden","currentLocation":"Thoth Station","description":"Commander of a ship infected by a lethal alien pathogen.","relationships":[],"recentEvents":"Sent a final distress message about crew casualties and the ship's condition before losing contact."}],"locations":[{"name":"Scopuli","arc":"Holden's Crew Survival and Escape","description":"A stealth ship captured and repurposed, later found to be infected with a deadly biological agent.","recentEvents":"The ship's crew was killed by an unknown pathogen, with Julie Mao's body remaining in an unsealed locker.","relationships":[{"location":"Engineering deck","relationship":"Contains the ship's reactor and is the site of critical discoveries"},{"location":"Inner airlock","relationship":"Where Julie was initially confined and later accessed after escaping"},{"location":"MCRN Donnager","relationship":"The Scopuli's crew was transported here before their deaths."},{"location":"Eros Station","relationship":"The ship's contamination and events on Eros are interconnected."}]},{"name":"Engineering deck","aliases":["Engineering deck"],"arc":"Julie's Survival and Escape","description":"The ship's core area housing the fusion reactor and critical systems.","recentEvents":"Julie discovers the reactor's corrupted state, with biological material fused to its core. Captain Darren's head is found here.","relationships":[{"location":"Scopuli","relationship":"Central operational area of the ship"}]},{"name":"Inner airlock","aliases":["Inner airlock"],"description":"A sealed compartment connecting different sections of the ship.","recentEvents":"Julie was confined here for eight days before escaping. It served as a transition point between decks.","relationships":[{"location":"Scopuli","relationship":"Structural component of the ship"}]},{"name":"Canterbury","aliases":["Knight","Knight-class ship"],"arc":"OPA's Role in the Martian-Belt War","description":"A P and K shuttle craft carrying Jim Holden and his crew after the Canterbury's destruction.","recentEvents":"Holden's crew was boarded by Martian marines after docking, leading to an interrogation by Lieutenant Lopez and a tense standoff with approaching Belt ships.","relationships":[{"location":"Belt","relationship":"Travels between Saturn's rings and this region"},{"location":"Canterbury","relationship":"Adjacent spaceport for departure/arrival"},{"location":"CA-2216862","relationship":"Target location for salvage mission"},{"location":"MCRN Donnager","relationship":"Docked at the Donnager's docking bay"}]},{"name":"Belt","aliases":["Asteroid Belt"],"arc":"Miller's Grief, Revenge, and Moral Conflict","description":"The region of space where the Canterbury and other ships operate, containing numerous asteroids and debris.","recentEvents":"The Canterbury was destroyed here by a nuclear weapon fired by a stealth ship. Holden and the Knight crew pursued the attackers while hiding behind an asteroid.","relationships":[{"location":"Callisto","relationship":"Adjacent to a charted non-Belt asteroid"},{"location":"Canterbury","relationship":"Destroyed in this region"},{"location":"Knight","relationship":"Survived here after the Canterbury's destruction"}]},{"name":"Callisto","description":"A non-Belt asteroid where a damaged Martian freighter sent an emergency signal.","recentEvents":"The Canterbury diverted its route to investigate the distress beacon near this location.","relationships":[{"location":"Belt","relationship":"Located near the asteroid belt"}]},{"name":"Ceres Station","aliases":["Ceres Port","Ceres"],"arc":"OPA's Role in the Martian-Belt War","description":"A major Belt station and economic hub, home to six million people. Serves as a critical node in the conflict between Mars and the Belt.","recentEvents":"The OPA announced the execution of Martian spies via an industrial airlock, framing it as a necessary action for freedom.","relationships":[{"location":"Belt","relationship":"Central to Ceres' economic role as a transit point for Belt resources"},{"location":"Tycho Station","relationship":"Connected via trade routes and shared security concerns"},{"location":"Port Level","relationship":"Key area where the riot occurs"},{"location":"Station House","relationship":"Administrative center where security directives are issued"},{"location":"Ganymede","relationship":"Site of the Black Cat freighter's destination after transferring stolen riot gear"},{"location":"Io","relationship":"Destination of the perps who disposed of the murder weapon"},{"location":"Star Helix","relationship":"Former governing authority now withdrawn"},{"location":"Donnager","relationship":"Martian warship whose destruction triggered the Belt's uprising"},{"location":"Rocinante","relationship":"Holden and Miller discuss the protomolecule's data here"}]},{"name":"Tycho Station","aliases":["Tycho"],"arc":"Holden's Crew Survival and Escape","description":"Corporate station serving as a hub between the Belt and inner planets, known for its interplanetary transport operations.","recentEvents":"Holden plans to travel here to seek trusted allies regarding the protomolecule's safe.","relationships":[{"location":"Ceres","relationship":"Serves as a key waypoint for cargo and passenger traffic between the Belt and inner systems"},{"location":"Ceres Station","relationship":"Linked by the Belt's orbital pathways"},{"location":"Rocinante","relationship":"Holden's destination after leaving the ship"}]},{"name":"CA-2216862","aliases":["Asteroid 2216862"],"description":"A half-kilometer-wide asteroid in the asteroid belt, serving as a gravitational anchor for the Scopuli.","recentEvents":"The Scopuli was deliberately positioned near this asteroid, likely to exploit its microgravity for slow orbital capture.","relationships":[{"location":"Scopuli","relationship":"Gravitational anchor point"},{"location":"Belt","relationship":"Located within the asteroid belt"}]},{"name":"Port Level","description":"A bustling industrial area of Ceres Station where ships dock and cargo is handled, marked by high gravity and constant activity.","recentEvents":"Miller's squad confronts a violent mob, including an OPA-linked killer, to prevent the riot from escalating.","relationships":[{"location":"Ceres Station","relationship":"A distinct sector within the station"}]},{"name":"MCRN Donnager","aliases":["Donnager","Martian battleship"],"arc":"OPA's Role in the Martian-Belt War","description":"A massive Martian capital ship with a stark, utilitarian design, serving as a military base for Martian forces.","recentEvents":"Miller and Holden investigate the ship's engineering deck, discovering signs of a violent takeover and the presence of a mysterious infectious agent.","relationships":[{"location":"Saturn Station","relationship":"Origin of the order"},{"location":"Jupiter","relationship":"Destination for the Knight"},{"location":"Knight","relationship":"Hosted the docking and interrogation of the Knight"},{"location":"Belt","relationship":"Engaged in combat with Belt ships following a torpedo launch"},{"location":"Scopuli","relationship":"The Scopuli's crew was captured and held here before their deaths."},{"location":"Eros Station","relationship":"Events on Eros Station are linked to the ship's contamination and the crew's fate."}]},{"name":"Saturn Station","aliases":["Saturn Station"],"description":"A Martian-controlled space station where P and K legal counsel issued directives.","recentEvents":"Wallace Fitz communicated the order to head to Jupiter, escalating tensions with Mars.","relationships":[{"location":"Knight","relationship":"Source of the crew's orders"},{"location":"Ceres Station","relationship":"Previously mentioned in crew discussions"}]},{"name":"Jupiter","aliases":["Jupiter"],"description":"A gas giant and strategic destination for the Knight crew's flight path.","recentEvents":"Selected as a potential destination despite risks from unknown pursuers.","relationships":[{"location":"Belt","relationship":"Geographically adjacent region"},{"location":"MCRN Donnager","relationship":"Target location for the ship"}]},{"name":"Razorback","aliases":["Razorback"],"description":"A private racing vessel associated with the Mao family, symbolizing Julie Mao's past and the family's financial influence.","recentEvents":"Julie Mao's messages reveal her family's attempt to coerce her to return, referencing the ship's potential sale and its significance to her.","relationships":[{"location":"Ceres Station","relationship":"The Razorback is mentioned as a vessel tied to the Mao family's operations on Ceres."}]},{"name":"Anderson Station","aliases":["Anderson"],"description":"A minor Belt distribution station for water and air, infamous for the Massacre that made Fred Johnson a Belter hero.","recentEvents":"Fred Johnson's broadcast reveals the station's history as a site of Coalition brutality, framing it as a catalyst for OPA resistance.","relationships":[{"location":"Belt","relationship":"Part of the asteroid belt's contested regions"},{"location":"MCRN Donnager","relationship":"Johnson's message hints at potential Martian involvement in the current conflict"}]},{"name":"Phoebe Station","aliases":["Phoebe"],"description":"A science station in the asteroid belt, forbidden for Belters to dock at.","recentEvents":"Destroyed in an attack attributed to Belter guerrilla groups, with half its inhabitants dead or missing.","relationships":[{"location":"Ceres Station","relationship":"Linked via Belt political tensions"}]},{"name":"Hangar Bay","aliases":["Hangar"],"description":"A section of the Donnager containing multiple ships, including the Knight, where the crew attempts to escape.","recentEvents":"The crew fought through boarders to reach a corvette, with Lieutenant Kelly leading the evacuation.","relationships":[{"location":"MCRN Donnager","relationship":"Part of the ship's structure"},{"location":"Knight","relationship":"A ship stationed in the bay"}]},{"name":"Ganymede","description":"A moon with significant mining and trade operations in the Jupiter system.","recentEvents":"The Black Cat freighter, linked to stolen riot gear, made a stop here after departing Ceres.","relationships":[{"location":"Ceres Station","relationship":"Linked via the Black Cat's transit route"}]},{"name":"Io","arc":"OPA's Bioweapon Containment and Strategic Manipulation","description":"A volcanic moon in Jupiter's system, often used as a transit point for illicit operations.","recentEvents":"The perps who disposed of the murder weapon and stolen gear were headed here, though their arrival remains uncertain.","relationships":[{"location":"Ceres Station","relationship":"Linked via the Black Cat's transit route"}]},{"name":"Mars","aliases":["Martian Congressional Republic"],"arc":"Protogen's Protomolecule Experimentation and Alien Weapon Threat","description":"Planet at the center of a conflict with the Belt, governed by the Martian Congressional Republic.","recentEvents":"The Martian Congressional Republic declared open war against the Belt, citing security threats and economic sabotage, escalating tensions across the system.","relationships":[{"location":"Belt","relationship":"Region in armed conflict with Mars"},{"location":"Ceres Station","relationship":"Site of growing unrest due to the war's proximity"}]},{"name":"Pallas","aliases":["Pallas Station"],"description":"A celestial body in the asteroid belt, serving as a transit hub for freighters and prospectors.","recentEvents":"The Adrianopole, a third-gen prospector, docked here after arriving from the Belt.","relationships":[{"location":"Ceres Station","relationship":"Linked via freighter routes and political tensions"}]},{"name":"Luna","description":"Earth's moon, a key node in interplanetary trade and military operations.","recentEvents":"The Badass Motherfucker freighter operated a triangle route between Luna, Ganymede, and the Belt.","relationships":[{"location":"Ganymede","relationship":"Connected via the Badass Motherfucker's trade route"},{"location":"Belt","relationship":"Part of a regional trade network"}]},{"name":"Triton","description":"Neptune's largest moon, home to deep astronomy labs repurposed by OPA-aligned prospectors.","recentEvents":"Prospectors sympathetic to the OPA occupied the labs, broadcasting Martian ship locations.","relationships":[{"location":"Belt","relationship":"Linked to OPA operations and resource conflicts"},{"location":"Mars","relationship":"Target of data broadcasts revealing Martian military assets"}]},{"name":"Eros Station Maintenance Corridor","aliases":["Eros","Eros Station","Maintenance Tunnel","Maintenance Shaft","Eros flophouse","Eros station"],"arc":"OPA's Bioweapon Deployment and Strategic Manipulation","description":"A dimly lit service passage carved by early Belters, housing critical power lines and running through the first Belt colony's infrastructure.","recentEvents":"Miller reflects on past events tied to the station, including the death of Juliette Mao and the aftermath of the attack on Deimos.","relationships":[{"location":"Ceres Station","relationship":"Part of the Belt's interconnected stations"},{"location":"Scopuli","relationship":"Ship associated with the deceased Juliette Mao"},{"location":"Canterbury","relationship":"Home port of the freighter the Canterbury is responding to"},{"location":"Tycho Station","relationship":"Mole activity originated here"},{"location":"Radiation Shelters (Eros Station)","relationship":"Adjacent to the maintenance corridors"},{"location":"Casino Level","relationship":"Part of the lockdown area"},{"location":"MCRN Donnager","relationship":"Miller and Holden were rescued from Eros Station by the Donnager"},{"location":"Eros Station","relationship":"Part of the station's utility infrastructure"},{"location":"Rocinante","relationship":"Miller's temporary residence before departing"}]},{"name":"BA834024112","aliases":["Rock BA834024112","Julie's asteroid"],"arc":"Holden's Crew Survival and Escape","description":"A barren asteroid tethered to a wealthy owner, serving as a navigational warning.","recentEvents":"Holden and the crew of the Rocinante approach it, discovering a stealth ship linked to the Donnager's destruction.","relationships":[{"location":"Scopuli","relationship":"Linked to the shuttle that carried Julie and may hide the ship's remnants"},{"location":"Phoebe Station","relationship":"The Phoebe bug originated from this science station, connecting to Julie's infection"},{"location":"Ceres Station","relationship":"The Rocinante is en route to Ceres after analyzing data from this asteroid."}]},{"name":"Casino Level","aliases":["Radiological Shelter","Casino Area"],"description":"A restricted zone on Eros Station where the population is funneled during lockdowns, serving as a central gathering point.","recentEvents":"The level is under lockdown, with guards enforcing movement toward shelters. Miller and Holden use this as a strategic point to regroup.","relationships":[{"location":"Eros Station","relationship":"Part of the station's structure"}]},{"name":"Radiation Shelters (Eros Station)","aliases":["Radiation Lockdown Zones","Radiation Incubators"],"description":"Sealed-off sections of Eros Station purportedly designed to protect citizens from radiation, but secretly used as containment areas for lethal gas and biological agents.","recentEvents":"The shelters were emptied, leaving only Holden and Miller's footsteps. Ko's body is left here after being shot.","relationships":[{"location":"Eros Station","relationship":"Designated emergency lockdown zones"},{"location":"Ceres Station","relationship":"Linked via transit corridors"},{"location":"Eros Station Maintenance Corridor","relationship":"Located nearby"}]},{"name":"Thoth Station","arc":"OPA's Bioweapon Containment and Strategic Manipulation","description":"A space station where Captain Higgins sent a distress message about the deteriorating condition of his crew and secured materials before the ship's fate.","recentEvents":"Holden and his crew received a comm log from Thoth Station indicating the ship's crew was turning into 'vomit zombies' and materials were secured, with vector data for locating the ship.","relationships":[{"location":"Belt","relationship":"The ship's location is being tracked in the Belt, as per the comm log."},{"location":"Rocinante","relationship":"The comm log was received on the Rocinante, which is now searching for the ship."}]},{"name":"Rocinante","aliases":["Roci"],"arc":"OPA's Bioweapon Containment and Strategic Manipulation","description":"A private ship used by the crew, serving as their mobile base of operations.","recentEvents":"Miller and Holden debate the ethical implications of broadcasting the protomolecule's data, with Holden deciding to proceed to Tycho Station.","relationships":[{"location":"Ceres Station","relationship":"Linked via the Belt's communication networks"},{"location":"Tycho Station","relationship":"Holden's next destination"}]},{"name":"Nauvoo","aliases":["Generation Ship"],"description":"A massive, half-built generation ship under construction at Tycho Station, serving as a potential vessel for interstellar travel.","recentEvents":"Holden and his crew discussed the protomolecule's purpose and debated strategies to counter Protogen, with Fred considering their plan to use the ship for a political gambit.","relationships":[{"location":"Tycho Station","relationship":"Under construction within Tycho Station's habitat rings"}]}],"arcs":[{"name":"OPA's Bioweapon Containment and Strategic Manipulation","status":"active","characters":["Jim Holden","Detective Miller","Fred Johnson"],"summary":"Holden and Miller confront Fred Johnson's ambiguous OPA allegiance, as Fred acknowledges the protomolecule's existential threat but prioritizes political survival over immediate action, revealing OPA's continued manipulation of interplanetary power dynamics."},{"name":"Miller's Grief, Revenge, and Moral Conflict","status":"active","characters":["Detective Miller","Jim Holden","Naomi Nagata"],"summary":"Miller grapples with the ethical implications of Holden's plan to weaponize the protomolecule data, while Holden's internalized guilt over past failures intensifies during conversations about Belters' systemic oppression and the war's human cost."},{"name":"Holden's Crew Survival and Escape","status":"active","characters":["Jim Holden","Naomi Nagata","Alex Kamal","Detective Miller"],"summary":"The crew arrives at Tycho Station, where Holden plans to secure Fred Johnson's political leverage. Holden's decision to trust Fred despite OPA's history of violence underscores the crew's precarious position in the escalating conflict."},{"name":"Protogen's Protomolecule Experimentation and Alien Weapon Threat","status":"active","characters":["Jim Holden","Detective Miller","Naomi Nagata","Alex Kamal"],"summary":"Holden and Miller debate the protomolecule's purpose as a distributed computing system, with Naomi theorizing it requires vast biomass to complete its mission. Holden connects this to Eros' role as a controlled experiment, while Miller questions the scale of human collaboration needed for such a project."}],"summary":"Holden's crew prepares to dock at Tycho Station, where they confront the ethical and strategic implications of the protomolecule's threat. They plan to leverage Fred's political influence to counter Protogen, while the Nauvoo's construction symbolizes humanity's hope for survival. Tensions remain high as the crew balances survival with the looming war between Earth, Mars, and the Belt."},"model":"qwen3:8b","appVersion":"0.1.0"},{"index":42,"result":{"characters":[{"name":"Juliette Andromeda Mao","aliases":["Julie Mao"],"importance":"main","status":"dead","lastSeen":"Chapter Twenty-Four: Miller","currentLocation":"Eros flophouse","description":"A captured crew member held in a storage locker, enduring eight days of isolation and dehydration while planning her escape. She discovers the ship's reactor has been replaced with an alien entity.","relationships":[{"character":"Dave","relationship":"Shipmate"},{"character":"Captain Darren","relationship":"Captain"},{"character":"Mike","relationship":"Shipmate"},{"character":"Wan Li","relationship":"Shipmate"},{"character":"Mao-Kwikowski Mercantile","relationship":"Family"},{"character":"Captain Shaddid","relationship":"Client"},{"character":"Detective Miller","relationship":"Target of search"}],"recentEvents":"Discovered dead in shower stall with severe biological modifications"},{"name":"Dave","aliases":[],"importance":"secondary","status":"dead","lastSeen":"Prologue: Julie","currentLocation":"Unknown","description":"Julie's shipmate and mechanic, who begged the captors not to take Julie before being thrown out an airlock.","relationships":[{"character":"Julie Mao","relationship":"Shipmate"}],"recentEvents":"Begged captors to spare Julie, was thrown out an airlock, and died."},{"name":"Captain Darren","aliases":[],"importance":"secondary","status":"dead","lastSeen":"Prologue: Julie","currentLocation":"Engineering deck","description":"The ship's captain who surrendered to the attackers without resistance, later found as a head fused to the alien reactor.","relationships":[{"character":"Julie Mao","relationship":"Captain"}],"recentEvents":"Surrendered to attackers, died after being part of the alien entity's fusion reactor."},{"name":"Mike","aliases":[],"importance":"secondary","status":"unknown","lastSeen":"Prologue: Julie","currentLocation":"Unknown","description":"A shipmate captured by the attackers along with others.","relationships":[{"character":"Julie Mao","relationship":"Shipmate"}],"recentEvents":"Captured by the attackers and taken off the ship."},{"name":"Wan Li","aliases":[],"importance":"secondary","status":"unknown","lastSeen":"Prologue: Julie","currentLocation":"Unknown","description":"A shipmate captured by the attackers along with others.","relationships":[{"character":"Julie Mao","relationship":"Shipmate"}],"recentEvents":"Captured by the attackers and taken off the ship."},{"name":"The Attackers","aliases":[],"importance":"secondary","status":"unknown","lastSeen":"Prologue: Julie","currentLocation":"Unknown","description":"The captors who took control of the ship, beat the crew, and sealed the ship's systems.","relationships":[{"character":"Julie Mao","relationship":"Captors"}],"recentEvents":"Captured the crew, sealed the ship, and replaced the reactor with an alien entity."},{"name":"Jim Holden [aliases: James Holden, Holden]","aliases":["James Holden","Holden","Jim Holden"],"importance":"main","status":"alive","lastSeen":"Chapter Thirty-Eight: Miller","currentLocation":"Tycho Station","description":"Executive officer of the Canterbury, a colony transport ship. A former Earth navy officer with a cynical view of Belters and their physiology.","relationships":[{"character":"Naomi Nagata","relationship":"Close ally, whose perspective influences Holden's decisions"},{"character":"Ade Tukunbo","relationship":"Romantic interest"},{"character":"Captain McDowell","relationship":"Former commanding officer"},{"character":"Alex Kamal","relationship":"Crewmate and engineer"},{"character":"Amos Burton","relationship":"Crewmate and weapons expert"},{"character":"Shed Garvey","relationship":"Crew member"},{"character":"Captain Theresa Yao","relationship":"Debriefed by Martian naval officer"},{"character":"Kelly","relationship":"Crewmate (deceased)"},{"character":"Fred Johnson [aliases: Colonel Frederick Lucius Johnson, Colonel Johnson]","relationship":"Business associate"},{"character":"Detective Miller","relationship":"Debates with Miller about broadcasting the protomolecule data"},{"character":"Miller","relationship":"Crewmate and former detective"}],"recentEvents":"Met with Miller and Naomi to discuss the assault on Thoth Station, confirmed Fred Johnson's involvement."},{"name":"Naomi Nagata [aliases: Naomi]","aliases":["Naomi","Naomi Nagata"],"importance":"main","status":"alive","lastSeen":"Chapter Thirty-Eight: Miller","currentLocation":"Tycho Station","description":"Medical officer who tends to Miller and Holden. Engages in a tense conversation with Holden about his feelings for her.","relationships":[{"character":"Jim Holden","relationship":"Commander and romantic interest"},{"character":"Amos Burton","relationship":"Subordinate"},{"character":"Alex Kamal","relationship":"Crew member"},{"character":"Kelly","relationship":"Crewmate (deceased)"},{"character":"Fred Johnson [aliases: Colonel Frederick Lucius Johnson, Colonel Johnson]","relationship":"Business associate"},{"character":"Detective Miller","relationship":"Fought alongside during ambush"},{"character":"Miller","relationship":"Crewmate and former detective"}],"recentEvents":"Analyzed comm data from the ship, discussed orbital plotting with Miller, and participated in the meeting with Fred Johnson."},{"name":"Amos Burton","aliases":["Amos"],"importance":"main","status":"alive","lastSeen":"Chapter Thirty-Seven: Holden","currentLocation":"Tycho Station","description":"Earthborn assistant to Naomi Nagata. Known for his loud personality and loyalty to Naomi.","relationships":[{"character":"Naomi Nagata","relationship":"Subordinate"},{"character":"Jim Holden","relationship":"Companion on the mission"},{"character":"Alex Kamal","relationship":"Crew member"},{"character":"Fred Johnson [aliases: Colonel Frederick Lucius Johnson, Colonel Johnson]","relationship":"Business associate"},{"character":"Detective Miller","relationship":"Visited Miller's cabin, shared breakfast, and discussed the war's impact"}],"recentEvents":"Contributed to dinner conversations, laughed at Miller's stories, and discussed the cheese shortage's role in Eros' destruction."},{"name":"Shed Garvey","aliases":["Shed"],"importance":"secondary","status":"dead","lastSeen":"Chapter Eleven: Holden","currentLocation":"Donnager","description":"Medical tech responsible for treating injured crew members. Known for using medical maggots in procedures.","relationships":[{"character":"Cameron Paj","relationship":"Patient"},{"character":"Jim Holden","relationship":"Crew member"},{"character":"Naomi Nagata","relationship":"Crew member"},{"character":"Alex Kamal","relationship":"Crew member"}],"recentEvents":"Mentioned by Holden as someone he wished was still alive."},{"name":"Cameron Paj","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter Five: Holden","currentLocation":"Knight","description":"Crew member who lost his left arm in an ice-related accident. Uses a prosthetic limb.","relationships":[{"character":"Shed Garvey","relationship":"Crewmate"}],"recentEvents":"Implied to have an injured arm, mentioned by Shed during the aftermath."},{"name":"Ade Tukunbo","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter Five: Holden","currentLocation":"Knight","description":"Navigator with a Nigerian accent and a fondness for music. Has a flirtatious relationship with Holden.","relationships":[{"character":"Jim Holden","relationship":"Romantic interest"}],"recentEvents":"Attempted to power up the Knight's drive, survived the nuke blast, communicated with Holden during the crisis."},{"name":"Rebecca Byers","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter One: Holden","currentLocation":"Canterbury","description":"Comm officer with a sharp appearance and a history of legal troubles. Handles emergency communications.","relationships":[{"character":"Captain McDowell","relationship":"Subordinate"}],"recentEvents":"Received and relayed the emergency signal from an unknown ship."},{"name":"Captain McDowell","aliases":[],"importance":"main","status":"alive","lastSeen":"Chapter Five: Holden","currentLocation":"Knight","description":"Commanding officer of the Canterbury. A grizzled veteran with a distrust of corrective surgery.","relationships":[{"character":"Jim Holden","relationship":"Former subordinate"}],"recentEvents":"Gave Holden instructions for the broadcast operation"},{"name":"Detective Miller [aliases: Miller]","aliases":["Miller","Detective Miller"],"importance":"main","status":"alive","lastSeen":"Chapter Thirty-Eight: Miller","currentLocation":"Tycho Station","description":"Experienced security officer with a troubled past, investigating Julie Mao's disappearance while navigating political tensions between Mars, the Belt, and Earth.","relationships":[{"character":"Dmitri Havelock","relationship":"Former partner"},{"character":"Captain Shaddid","relationship":"Superior"},{"character":"Juliette Andromeda Mao","relationship":"OPA contact"},{"character":"Havelock","relationship":"Partner who covers for Miller's absence"},{"character":"Octavia Muss","relationship":"Partner"},{"character":"Julie Mao","relationship":"Subject of investigation"},{"character":"Muss","relationship":"Partner"},{"character":"Shaddid","relationship":"Superior"},{"character":"Dawes","relationship":"Colleague"},{"character":"Inspector Sematimba","relationship":"Contacted for police assistance"},{"character":"Jim Holden","relationship":"Captain of the Rocinante, debates with Miller about broadcasting the protomolecule data"},{"character":"Naomi Nagata","relationship":"Aboard the Rocinante, with whom Miller discusses ethical dilemmas"},{"character":"Sematimba","relationship":"Contacted police"},{"character":"Amos Burton","relationship":"Team member"},{"character":"Alex Kamal","relationship":"Crewmate"}],"recentEvents":"Discussed coordinates for Thoth Station with Fred Johnson, confirmed Havelock's intel on the black ops station, and agreed to join the assault."},{"name":"Captain Shaddid","aliases":["Shaddid"],"importance":"main","status":"alive","lastSeen":"Chapter Thirty-Six: Miller","currentLocation":"Ceres Station","description":"Commander of Star Helix Security on Ceres, known for her pragmatic approach and disdain for inner planet residents.","relationships":[{"character":"Miller","relationship":"Subordinate"},{"character":"Julie Mao","relationship":"Client"},{"character":"Detective Miller","relationship":"Superior"},{"character":"OPA","relationship":"Leadership of the OPA's security apparatus"}],"recentEvents":"Announced the execution of Martian spies via a public video feed, emphasizing the OPA's stance on security"},{"name":"Alex Kamal","aliases":["Alex"],"importance":"main","status":"alive","lastSeen":"Chapter Thirty-Seven: Holden","currentLocation":"Tycho Station","description":"Crewmate and engineer, skeptical of Martian involvement in the Canterbury's destruction.","relationships":[{"character":"Jim Holden","relationship":"Companion on the mission"},{"character":"Naomi Nagata","relationship":"Crew member"},{"character":"Amos Burton","relationship":"Crew member"},{"character":"Shed Garvey","relationship":"Crew member"},{"character":"Kelly","relationship":"Crewmate (deceased)"},{"character":"Fred Johnson [aliases: Colonel Frederick Lucius Johnson, Colonel Johnson]","relationship":"Business associate"},{"character":"Miller","relationship":"Crewmate"}],"recentEvents":"Helped prepare fake food for dinner, shared jokes, and participated in discussions about the protomolecule."},{"name":"Dmitri Havelock [aliases: Havelock]","aliases":["Havelock","Dmitri Havelock"],"importance":"main","status":"alive","lastSeen":"Chapter Thirty-Eight: Miller","currentLocation":"Ganymede server cluster","description":"Miller's partner and fellow security officer, who agrees to cover for Miller's absence while he investigates Julie Mao's case.","relationships":[{"character":"Detective Miller","relationship":"Former partner"},{"character":"Miller","relationship":"Partner who covers for Miller's absence"},{"character":"Captain Shaddid","relationship":"Superior"}],"recentEvents":"Provided encrypted intel on Thoth Station's location to Miller."},{"name":"Hasini","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter Sixteen: Miller","currentLocation":"Blue Frog (Ceres Station)","description":"Assistant manager of the Blue Frog, a portside bar on Ceres, who interacted with Detective Miller.","relationships":[{"character":"Detective Miller","relationship":"Informal acquaintance"}],"recentEvents":"Accompanied Miller home after a drinking session, revealed his feelings for Julie Mao."},{"name":"Brown","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter Six: Miller","currentLocation":"Ceres","description":"Security officer with SWAT experience, leading crowd control wings.","relationships":[],"recentEvents":"Part of Miller's riot squad, led during the mob confrontation."},{"name":"Gelbfish","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter Six: Miller","currentLocation":"Ceres","description":"Security officer with SWAT experience, part of Miller's team.","relationships":[],"recentEvents":"Identified the shirtless man's OPA tattoo, participated in crowd control."},{"name":"Aberforth","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter Six: Miller","currentLocation":"Ceres","description":"Security officer with a history of excessive violence, placed in second-string role.","relationships":[],"recentEvents":"Assigned to secondary roles due to past disciplinary issues."},{"name":"Yevgeny","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter Six: Miller","currentLocation":"Ceres","description":"Homicide detective who commented on government offices during the crisis.","relationships":[],"recentEvents":"Mentioned the government's infrastructure status during Shaddid's briefing."},{"name":"Shirtless Man","aliases":[],"importance":"minor","status":"alive","lastSeen":"Chapter Eight: Miller","currentLocation":"Ceres","description":"A former suspect in a crime, now in Star Helix detainment infirmary preparing for trial.","relationships":[],"recentEvents":"Mentioned in context of Ceres Station's ongoing legal cases"},{"name":"OPA Man","aliases":[],"importance":"minor","status":"alive","lastSeen":"Chapter Ten: Miller","currentLocation":"Ceres","description":"An OPA representative with a pock-marked face, engaged in a tense conversation with Miller about OPA's role.","relationships":[{"character":"Detective Miller","relationship":"OPA contact"}],"recentEvents":"Discussed OPA's economic terrorism claims, denied involvement in Mateo Judd's death, and warned Miller to stay away."},{"name":"Wallace Fitz","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter Seven: Holden","currentLocation":"Saturn Station","description":"P and K legal counsel who issued formal orders to Holden and his crew.","relationships":[{"character":"Jim Holden","relationship":"Legal contact"}],"recentEvents":"Delivered official response to Holden's request for assistance, accused Holden of unfounded Martian accusations."},{"name":"Captain Theresa Yao","aliases":[],"importance":"main","status":"alive","lastSeen":"Chapter Eleven: Holden","currentLocation":"Donnager","description":"Commander of the Donnager, a Martian capital ship, overseeing the interrogation of Holden's crew.","relationships":[{"character":"Jim Holden","relationship":"Debriefed by Martian naval officer"}],"recentEvents":"Ordered the torpedo launch against the Belt ships and interrogated Holden about the pursuing vessels."},{"name":"Masked Woman","aliases":["Woman"],"importance":"minor","status":"alive","lastSeen":"Chapter Eight: Miller","currentLocation":"Ceres","description":"Victim beaten to death by the shirtless man, identified as a Martian freight line employee.","relationships":[],"recentEvents":"Featured in Miller's terminal screen as part of OPA propaganda"},{"name":"Mateo Judd","aliases":[],"importance":"main","status":"dead","lastSeen":"Chapter Ten: Miller","currentLocation":"Ceres","description":"A dockworker accused of running an extortion scheme, later found dead with OPA ties.","relationships":[{"character":"Asher Kamamatsu","relationship":"Client"}],"recentEvents":"Sought protection from the OPA, was killed by OPA operatives after Miller's investigation."},{"name":"Lieutenant Lopez","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter Eleven: Holden","currentLocation":"Donnager","description":"Naval intelligence officer conducting an interrogation of Holden, using focus drugs to monitor his responses.","relationships":[{"character":"Jim Holden","relationship":"Interrogated by naval intelligence"}],"recentEvents":"Conducted a detailed interrogation of Holden, discussed the political tensions between Mars and the Belt, and fled to the combat zone after the torpedo attack."},{"name":"Chief Gunderson","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter Eleven: Holden","currentLocation":"Donnager","description":"Martian military chief responsible for escorting Holden's crew to their quarters.","relationships":[{"character":"Jim Holden","relationship":"Escorted to quarters"}],"recentEvents":"Led Holden's crew to their temporary accommodations and coordinated with Lieutenant Kelly for their protection."},{"name":"Anderson Dawes","aliases":["Dawes"],"importance":"main","status":"alive","lastSeen":"Chapter Sixteen: Miller","currentLocation":"Ceres Station","description":"OPA liaison who approaches Detective Miller to stop his investigation into Julie Mao's disappearance, claiming it could escalate tensions between Mars and the Belt.","relationships":[{"character":"Detective Miller","relationship":"OPA agent attempting to dissuade Miller from pursuing a kidnapping case"}],"recentEvents":"Argued against Miller's investigation, claimed Holden's capture, and emphasized corporate neutrality."},{"name":"The Jiu Jitsu Instructor","aliases":[],"importance":"minor","status":"alive","lastSeen":"Chapter Twelve: Miller","currentLocation":"Ceres","description":"Owner of the Ceres Center for Jiu Jitsu, who provides limited information about Julie Mao's background and training.","relationships":[]},{"name":"Enrique Dos Santos","aliases":[],"importance":"minor","status":"dead","lastSeen":"Chapter Fourteen: Miller","currentLocation":"Ceres","description":"","relationships":[],"recentEvents":"Tortured and displayed near sector eleven's water reclamation works; identified by terminal, wedding ring, and credit data"},{"name":"Octavia Muss","aliases":["Muss"],"importance":"secondary","status":"alive","lastSeen":"Chapter Eighteen: Miller","currentLocation":"Ceres Station","description":"A pragmatic detective who handles interrogations and provides Miller with critical case updates.","relationships":[{"character":"Detective Miller","relationship":"Colleague"},{"character":"Miller","relationship":"Partner"},{"character":"Shaddid","relationship":"Superior"}],"recentEvents":"Provided Miller with a rape case witness detail, skipped work to attend to a stop, and observed the political upheaval on Ceres."},{"name":"Kelly","aliases":["Lieutenant Kelly"],"importance":"main","status":"dead","lastSeen":"Chapter Fifteen: Holden","currentLocation":"Tachi","description":"Deceased marine who died during the battle on the Donnager.","relationships":[{"character":"Jim Holden","relationship":"Crewmate"},{"character":"Alex Kamal","relationship":"Crewmate"}],"recentEvents":"Died from severe injuries during the battle, then buried by the crew."},{"name":"Gomez","aliases":[],"importance":"secondary","status":"dead","lastSeen":"Chapter Fifteen: Holden","currentLocation":"Unknown","description":"Marine who died during the battle on the Donnager.","relationships":[{"character":"Jim Holden","relationship":"Crewmate"}],"recentEvents":"Killed by enemy fire while defending the Donnager."},{"name":"Immanuel Corvus Dowd","aliases":[],"importance":"main","status":"alive","lastSeen":"Chapter Eighteen: Miller","currentLocation":"Ceres Station detention cells","description":"A businessman arrested for rape, portrayed as a high-profile client with connections to influential war effort figures.","relationships":[{"character":"Harry","relationship":"Lawyer"}],"recentEvents":"Detained under a warrant following a rape investigation, confronted by Detective Miller, and subjected to legal scrutiny."},{"name":"Harry","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter Eighteen: Miller","currentLocation":"Ceres Station","description":"Immanuel Corvus Dowd's lawyer, who warns Miller of potential legal repercussions for his investigation.","relationships":[{"character":"Immanuel Corvus Dowd","relationship":"Client"}],"recentEvents":"Attempted to shield his client from arrest, engaged in tense dialogue with Miller, and exited the interrogation room."},{"name":"Young Woman in Cream-Colored Linen","aliases":[],"importance":"minor","status":"unknown","lastSeen":"Chapter Eighteen: Miller","currentLocation":"Ceres Station","description":"A professional-looking woman who briefly acknowledged Miller before entering the accountancy office.","relationships":[],"recentEvents":"Nodded to Miller as he left the accountancy office, displaying a calm, fighter-like demeanor."},{"name":"Bartender","aliases":[],"importance":"minor","status":"alive","lastSeen":"Chapter Nineteen: Holden","currentLocation":"Tycho Station","relationships":[]},{"name":"Singer","aliases":[],"importance":"minor","status":"alive","lastSeen":"Chapter Nineteen: Holden","currentLocation":"Tycho Station","relationships":[]},{"name":"Teenage Girls","aliases":[],"importance":"minor","status":"alive","lastSeen":"Chapter Nineteen: Holden","currentLocation":"Tycho Station","relationships":[]},{"name":"Lionel Polanski","aliases":[],"importance":"secondary","status":"unknown","lastSeen":"Chapter Twenty-Three: Holden","currentLocation":"Eros hotel room","description":"A fictional person Fred Johnson claims to need retrieved from Eros, owning the courier ship Scopuli.","relationships":[{"character":"Fred Johnson [aliases: Colonel Frederick Lucius Johnson, Colonel Johnson]","relationship":"Target of retrieval"}],"recentEvents":"Targeted by Holden's group, last seen in his hotel room."},{"name":"Missionary","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter Twenty-Two: Miller","currentLocation":"Eros","description":"A traveling missionary with a name tag and Bible","relationships":[],"recentEvents":"Engaging in philosophical conversation about religion and war with Miller"},{"name":"Inspector Sematimba","aliases":["Sematimba"],"importance":"secondary","status":"alive","lastSeen":"Chapter Twenty-Six: Miller","currentLocation":"Eros flophouse","description":"Police officer who imposed a lockdown on Holden's ship.","relationships":[{"character":"Detective Miller","relationship":"Contacted for police assistance"},{"character":"Jim Holden","relationship":"Enforced lockdown"}],"recentEvents":"Imposed a lockdown on Holden's ship, communicated with Miller about jurisdictional concerns."},{"name":"Woman with the gun","aliases":[],"importance":"minor","status":"dead","lastSeen":"Chapter Twenty-Three: Holden","currentLocation":"Eros flophouse","description":"Armed assailant who confronted Holden's group.","relationships":[],"recentEvents":"Shot and killed during the confrontation at Lionel Polanski's flophouse."},{"name":"Guard","aliases":[],"importance":"minor","status":"alive","lastSeen":"Chapter Twenty-Seven: Holden","currentLocation":"Eros station","description":"A fake riot cop leading civilians to a radiation shelter.","relationships":[],"recentEvents":"Nudged by Miller after the shootout."},{"name":"Gabby Smalls","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter Twenty-Seven: Holden","currentLocation":"Ceres","description":"A mobster and police riot gear supervisor on Ceres, leading civilians to shelters.","relationships":[],"recentEvents":"Mentioned as a key figure in the Ceres protection racket."},{"name":"Mikey Ko","aliases":[],"importance":"secondary","status":"dead","lastSeen":"Chapter Twenty-Eight: Miller","currentLocation":"Eros station","description":"A guard who mistook Miller and Holden for Protogen installers, leading to his death at Miller's hands.","relationships":[{"character":"Detective Miller","relationship":"Victim of Miller's lethal action"},{"character":"Jim Holden","relationship":"Witness to Miller's confrontation"}],"recentEvents":"Was killed by Miller after revealing details about Protogen's operations on Eros."},{"name":"Mafia Thug","aliases":[],"importance":"minor","status":"dead","lastSeen":"Chapter Twenty-Nine: Holden","currentLocation":"Eros station","description":"A violent enforcer killed by Holden during a mob incident.","relationships":[],"recentEvents":"Shot and killed by Holden after firing on civilians."},{"name":"Child Victim","aliases":[],"importance":"minor","status":"dead","lastSeen":"Chapter Twenty-Nine: Holden","currentLocation":"Eros station","description":"A thirteen-year-old boy killed by the mafia thug during the chaos on Eros station.","relationships":[],"recentEvents":"Died from a gunshot wound to the chest, rescued by Holden."},{"name":"Mr. Dresden","aliases":["sociopath"],"importance":"main","status":"alive","lastSeen":"Chapter Thirty-Four: Miller","currentLocation":"Unknown","description":"A charismatic corporate executive presenting Protogen's findings on the protomolecule.","relationships":[],"recentEvents":"Delivered a presentation about the protomolecule as a weapon from an alien civilization."},{"name":"Captain Higgins","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter Thirty-Five: Holden","currentLocation":"Thoth Station","description":"Commander of a ship infected by a lethal alien pathogen.","relationships":[],"recentEvents":"Sent a final distress message about crew casualties and the ship's condition before losing contact."},{"name":"Fred Johnson [aliases: Colonel Frederick Lucius Johnson, Colonel Johnson]","aliases":["Fred Johnson","Colonel Frederick Lucius Johnson","Colonel Johnson"],"importance":"main","status":"alive","lastSeen":"Chapter Thirty-Eight: Miller","currentLocation":"Tycho Station","description":"Colonel and leader of the Outer Planets Alliance, contacting Holden about potential Martian threats.","relationships":[{"character":"Detective Miller","relationship":"Informant"},{"character":"Jim Holden","relationship":"Communications contact"},{"character":"Naomi Nagata","relationship":"Business associate"},{"character":"Amos Burton","relationship":"Business associate"},{"character":"Alex Kamal","relationship":"Business associate"}],"recentEvents":"Negotiated the use of the Rocinante for an Eros mission, revealed the fictional Lionel Polanski, and discussed the data cube."}],"locations":[{"name":"Scopuli","arc":"Holden's Crew Survival and Escape","description":"A stealth ship captured and repurposed, later found to be infected with a deadly biological agent.","recentEvents":"The ship's crew was killed by an unknown pathogen, with Julie Mao's body remaining in an unsealed locker.","relationships":[{"location":"Engineering deck","relationship":"Contains the ship's reactor and is the site of critical discoveries"},{"location":"Inner airlock","relationship":"Where Julie was initially confined and later accessed after escaping"},{"location":"MCRN Donnager","relationship":"The Scopuli's crew was transported here before their deaths."},{"location":"Eros Station","relationship":"The ship's contamination and events on Eros are interconnected."}]},{"name":"Engineering deck","aliases":["Engineering deck"],"arc":"Julie's Survival and Escape","description":"The ship's core area housing the fusion reactor and critical systems.","recentEvents":"Julie discovers the reactor's corrupted state, with biological material fused to its core. Captain Darren's head is found here.","relationships":[{"location":"Scopuli","relationship":"Central operational area of the ship"}]},{"name":"Inner airlock","aliases":["Inner airlock"],"description":"A sealed compartment connecting different sections of the ship.","recentEvents":"Julie was confined here for eight days before escaping. It served as a transition point between decks.","relationships":[{"location":"Scopuli","relationship":"Structural component of the ship"}]},{"name":"Canterbury","aliases":["Knight","Knight-class ship"],"arc":"OPA's Role in the Martian-Belt War","description":"A P and K shuttle craft carrying Jim Holden and his crew after the Canterbury's destruction.","recentEvents":"Holden's crew was boarded by Martian marines after docking, leading to an interrogation by Lieutenant Lopez and a tense standoff with approaching Belt ships.","relationships":[{"location":"Belt","relationship":"Travels between Saturn's rings and this region"},{"location":"Canterbury","relationship":"Adjacent spaceport for departure/arrival"},{"location":"CA-2216862","relationship":"Target location for salvage mission"},{"location":"MCRN Donnager","relationship":"Docked at the Donnager's docking bay"}]},{"name":"Belt","aliases":["Asteroid Belt"],"arc":"Miller's Grief, Revenge, and Moral Conflict","description":"The region of space where the Canterbury and other ships operate, containing numerous asteroids and debris.","recentEvents":"The Canterbury was destroyed here by a nuclear weapon fired by a stealth ship. Holden and the Knight crew pursued the attackers while hiding behind an asteroid.","relationships":[{"location":"Callisto","relationship":"Adjacent to a charted non-Belt asteroid"},{"location":"Canterbury","relationship":"Destroyed in this region"},{"location":"Knight","relationship":"Survived here after the Canterbury's destruction"}]},{"name":"Callisto","description":"A non-Belt asteroid where a damaged Martian freighter sent an emergency signal.","recentEvents":"The Canterbury diverted its route to investigate the distress beacon near this location.","relationships":[{"location":"Belt","relationship":"Located near the asteroid belt"}]},{"name":"Ceres Station","aliases":["Ceres Port","Ceres"],"arc":"OPA's Role in the Martian-Belt War","description":"A major Belt station and economic hub, home to six million people. Serves as a critical node in the conflict between Mars and the Belt.","recentEvents":"The OPA announced the execution of Martian spies via an industrial airlock, framing it as a necessary action for freedom.","relationships":[{"location":"Belt","relationship":"Central to Ceres' economic role as a transit point for Belt resources"},{"location":"Tycho Station","relationship":"Connected via trade routes and shared security concerns"},{"location":"Port Level","relationship":"Key area where the riot occurs"},{"location":"Station House","relationship":"Administrative center where security directives are issued"},{"location":"Ganymede","relationship":"Site of the Black Cat freighter's destination after transferring stolen riot gear"},{"location":"Io","relationship":"Destination of the perps who disposed of the murder weapon"},{"location":"Star Helix","relationship":"Former governing authority now withdrawn"},{"location":"Donnager","relationship":"Martian warship whose destruction triggered the Belt's uprising"},{"location":"Rocinante","relationship":"Holden and Miller discuss the protomolecule's data here"}]},{"name":"Tycho Station","aliases":["Tycho"],"arc":"Holden's Crew Survival and Escape","description":"Corporate station serving as a hub between the Belt and inner planets, known for its interplanetary transport operations.","recentEvents":"Holden plans to travel here to seek trusted allies regarding the protomolecule's safe.","relationships":[{"location":"Ceres","relationship":"Serves as a key waypoint for cargo and passenger traffic between the Belt and inner systems"},{"location":"Ceres Station","relationship":"Linked by the Belt's orbital pathways"},{"location":"Rocinante","relationship":"Holden's destination after leaving the ship"}]},{"name":"CA-2216862","aliases":["Asteroid 2216862"],"description":"A half-kilometer-wide asteroid in the asteroid belt, serving as a gravitational anchor for the Scopuli.","recentEvents":"The Scopuli was deliberately positioned near this asteroid, likely to exploit its microgravity for slow orbital capture.","relationships":[{"location":"Scopuli","relationship":"Gravitational anchor point"},{"location":"Belt","relationship":"Located within the asteroid belt"}]},{"name":"Port Level","description":"A bustling industrial area of Ceres Station where ships dock and cargo is handled, marked by high gravity and constant activity.","recentEvents":"Miller's squad confronts a violent mob, including an OPA-linked killer, to prevent the riot from escalating.","relationships":[{"location":"Ceres Station","relationship":"A distinct sector within the station"}]},{"name":"MCRN Donnager","aliases":["Donnager","Martian battleship"],"arc":"OPA's Role in the Martian-Belt War","description":"A massive Martian capital ship with a stark, utilitarian design, serving as a military base for Martian forces.","recentEvents":"Miller and Holden investigate the ship's engineering deck, discovering signs of a violent takeover and the presence of a mysterious infectious agent.","relationships":[{"location":"Saturn Station","relationship":"Origin of the order"},{"location":"Jupiter","relationship":"Destination for the Knight"},{"location":"Knight","relationship":"Hosted the docking and interrogation of the Knight"},{"location":"Belt","relationship":"Engaged in combat with Belt ships following a torpedo launch"},{"location":"Scopuli","relationship":"The Scopuli's crew was captured and held here before their deaths."},{"location":"Eros Station","relationship":"Events on Eros Station are linked to the ship's contamination and the crew's fate."}]},{"name":"Saturn Station","aliases":["Saturn Station"],"description":"A Martian-controlled space station where P and K legal counsel issued directives.","recentEvents":"Wallace Fitz communicated the order to head to Jupiter, escalating tensions with Mars.","relationships":[{"location":"Knight","relationship":"Source of the crew's orders"},{"location":"Ceres Station","relationship":"Previously mentioned in crew discussions"}]},{"name":"Jupiter","aliases":["Jupiter"],"description":"A gas giant and strategic destination for the Knight crew's flight path.","recentEvents":"Selected as a potential destination despite risks from unknown pursuers.","relationships":[{"location":"Belt","relationship":"Geographically adjacent region"},{"location":"MCRN Donnager","relationship":"Target location for the ship"}]},{"name":"Razorback","aliases":["Razorback"],"description":"A private racing vessel associated with the Mao family, symbolizing Julie Mao's past and the family's financial influence.","recentEvents":"Julie Mao's messages reveal her family's attempt to coerce her to return, referencing the ship's potential sale and its significance to her.","relationships":[{"location":"Ceres Station","relationship":"The Razorback is mentioned as a vessel tied to the Mao family's operations on Ceres."}]},{"name":"Anderson Station","aliases":["Anderson"],"description":"A minor Belt distribution station for water and air, infamous for the Massacre that made Fred Johnson a Belter hero.","recentEvents":"Fred Johnson's broadcast reveals the station's history as a site of Coalition brutality, framing it as a catalyst for OPA resistance.","relationships":[{"location":"Belt","relationship":"Part of the asteroid belt's contested regions"},{"location":"MCRN Donnager","relationship":"Johnson's message hints at potential Martian involvement in the current conflict"}]},{"name":"Phoebe Station","aliases":["Phoebe"],"description":"A science station in the asteroid belt, forbidden for Belters to dock at.","recentEvents":"Destroyed in an attack attributed to Belter guerrilla groups, with half its inhabitants dead or missing.","relationships":[{"location":"Ceres Station","relationship":"Linked via Belt political tensions"}]},{"name":"Hangar Bay","aliases":["Hangar"],"description":"A section of the Donnager containing multiple ships, including the Knight, where the crew attempts to escape.","recentEvents":"The crew fought through boarders to reach a corvette, with Lieutenant Kelly leading the evacuation.","relationships":[{"location":"MCRN Donnager","relationship":"Part of the ship's structure"},{"location":"Knight","relationship":"A ship stationed in the bay"}]},{"name":"Ganymede","description":"A moon with significant mining and trade operations in the Jupiter system.","recentEvents":"The Black Cat freighter, linked to stolen riot gear, made a stop here after departing Ceres.","relationships":[{"location":"Ceres Station","relationship":"Linked via the Black Cat's transit route"}]},{"name":"Io","arc":"OPA's Bioweapon Containment and Strategic Manipulation (Fred Johnson's Role Revealed)","description":"A volcanic moon in Jupiter's system, often used as a transit point for illicit operations.","recentEvents":"The perps who disposed of the murder weapon and stolen gear were headed here, though their arrival remains uncertain.","relationships":[{"location":"Ceres Station","relationship":"Linked via the Black Cat's transit route"}]},{"name":"Mars","aliases":["Martian Congressional Republic"],"arc":"Protogen's Protomolecule Experimentation and Alien Weapon Threat","description":"Planet at the center of a conflict with the Belt, governed by the Martian Congressional Republic.","recentEvents":"The Martian Congressional Republic declared open war against the Belt, citing security threats and economic sabotage, escalating tensions across the system.","relationships":[{"location":"Belt","relationship":"Region in armed conflict with Mars"},{"location":"Ceres Station","relationship":"Site of growing unrest due to the war's proximity"}]},{"name":"Pallas","aliases":["Pallas Station"],"description":"A celestial body in the asteroid belt, serving as a transit hub for freighters and prospectors.","recentEvents":"The Adrianopole, a third-gen prospector, docked here after arriving from the Belt.","relationships":[{"location":"Ceres Station","relationship":"Linked via freighter routes and political tensions"}]},{"name":"Luna","description":"Earth's moon, a key node in interplanetary trade and military operations.","recentEvents":"The Badass Motherfucker freighter operated a triangle route between Luna, Ganymede, and the Belt.","relationships":[{"location":"Ganymede","relationship":"Connected via the Badass Motherfucker's trade route"},{"location":"Belt","relationship":"Part of a regional trade network"}]},{"name":"Triton","description":"Neptune's largest moon, home to deep astronomy labs repurposed by OPA-aligned prospectors.","recentEvents":"Prospectors sympathetic to the OPA occupied the labs, broadcasting Martian ship locations.","relationships":[{"location":"Belt","relationship":"Linked to OPA operations and resource conflicts"},{"location":"Mars","relationship":"Target of data broadcasts revealing Martian military assets"}]},{"name":"Eros Station Maintenance Corridor","aliases":["Eros","Eros Station","Maintenance Tunnel","Maintenance Shaft","Eros flophouse","Eros station"],"arc":"OPA's Bioweapon Deployment and Strategic Manipulation","description":"A dimly lit service passage carved by early Belters, housing critical power lines and running through the first Belt colony's infrastructure.","recentEvents":"Miller reflects on past events tied to the station, including the death of Juliette Mao and the aftermath of the attack on Deimos.","relationships":[{"location":"Ceres Station","relationship":"Part of the Belt's interconnected stations"},{"location":"Scopuli","relationship":"Ship associated with the deceased Juliette Mao"},{"location":"Canterbury","relationship":"Home port of the freighter the Canterbury is responding to"},{"location":"Tycho Station","relationship":"Mole activity originated here"},{"location":"Radiation Shelters (Eros Station)","relationship":"Adjacent to the maintenance corridors"},{"location":"Casino Level","relationship":"Part of the lockdown area"},{"location":"MCRN Donnager","relationship":"Miller and Holden were rescued from Eros Station by the Donnager"},{"location":"Eros Station","relationship":"Part of the station's utility infrastructure"},{"location":"Rocinante","relationship":"Miller's temporary residence before departing"}]},{"name":"BA834024112","aliases":["Rock BA834024112","Julie's asteroid"],"arc":"Holden's Crew Survival and Escape","description":"A barren asteroid tethered to a wealthy owner, serving as a navigational warning.","recentEvents":"Holden and the crew of the Rocinante approach it, discovering a stealth ship linked to the Donnager's destruction.","relationships":[{"location":"Scopuli","relationship":"Linked to the shuttle that carried Julie and may hide the ship's remnants"},{"location":"Phoebe Station","relationship":"The Phoebe bug originated from this science station, connecting to Julie's infection"},{"location":"Ceres Station","relationship":"The Rocinante is en route to Ceres after analyzing data from this asteroid."}]},{"name":"Casino Level","aliases":["Radiological Shelter","Casino Area"],"description":"A restricted zone on Eros Station where the population is funneled during lockdowns, serving as a central gathering point.","recentEvents":"The level is under lockdown, with guards enforcing movement toward shelters. Miller and Holden use this as a strategic point to regroup.","relationships":[{"location":"Eros Station","relationship":"Part of the station's structure"}]},{"name":"Radiation Shelters (Eros Station)","aliases":["Radiation Lockdown Zones","Radiation Incubators"],"description":"Sealed-off sections of Eros Station purportedly designed to protect citizens from radiation, but secretly used as containment areas for lethal gas and biological agents.","recentEvents":"The shelters were emptied, leaving only Holden and Miller's footsteps. Ko's body is left here after being shot.","relationships":[{"location":"Eros Station","relationship":"Designated emergency lockdown zones"},{"location":"Ceres Station","relationship":"Linked via transit corridors"},{"location":"Eros Station Maintenance Corridor","relationship":"Located nearby"}]},{"name":"Thoth Station","arc":"Miller's Grief, Revenge, and Moral Conflict","description":"A space station where Captain Higgins sent a distress message about the deteriorating condition of his crew and secured materials before the ship's fate.","recentEvents":"Miller obtains its orbital coordinates from Havelock, leading to plans for an assault with the OPA.","relationships":[{"location":"Belt","relationship":"The ship's location is being tracked in the Belt, as per the comm log."},{"location":"Rocinante","relationship":"The comm log was received on the Rocinante, which is now searching for the ship."},{"location":"Ganymede","relationship":"Linked via secure server cluster"}]},{"name":"Rocinante","aliases":["Roci"],"arc":"OPA's Bioweapon Containment and Strategic Manipulation","description":"A private ship used by the crew, serving as their mobile base of operations.","recentEvents":"Miller and Holden debate the ethical implications of broadcasting the protomolecule's data, with Holden deciding to proceed to Tycho Station.","relationships":[{"location":"Ceres Station","relationship":"Linked via the Belt's communication networks"},{"location":"Tycho Station","relationship":"Holden's next destination"}]},{"name":"Nauvoo","aliases":["Generation Ship"],"description":"A massive, half-built generation ship under construction at Tycho Station, serving as a potential vessel for interstellar travel.","recentEvents":"Miller observes its construction and meets Naomi to discuss comm data. He later connects with Havelock via a secure drop site.","relationships":[{"location":"Tycho Station","relationship":"Under construction within Tycho Station's habitat rings"}]}],"arcs":[{"name":"OPA's Bioweapon Containment and Strategic Manipulation (Fred Johnson's Role Revealed)","status":"active","characters":["Jim Holden","Detective Miller","Fred Johnson [aliases: Colonel Frederick Lucius Johnson, Colonel Johnson]"],"summary":"Holden and Miller confront Fred Johnson's ambiguous OPA allegiance, as Fred acknowledges the protomolecule's existential threat but prioritizes political survival over immediate action, revealing OPA's continued manipulation of interplanetary power dynamics."},{"name":"Miller's Grief, Revenge, and Moral Conflict","status":"active","characters":["Detective Miller","Jim Holden","Naomi Nagata"],"summary":"Miller's decision to join the assault on Thoth Station marks a shift from passive investigation to active participation, balancing his desire for vengeance against Fred Johnson with ethical doubts about the mission's risks."},{"name":"Holden's Crew Survival and Escape","status":"active","characters":["Jim Holden","Naomi Nagata","Amos Burton","Alex Kamal"],"summary":"The crew prepares for the high-stakes assault on Thoth Station, with Holden prioritizing crew unity and contingency plans amid growing tensions over the mission's moral implications."},{"name":"Protogen's Protomolecule Experimentation and Alien Weapon Threat","status":"active","characters":["Jim Holden","Detective Miller","Naomi Nagata","Fred Johnson [aliases: Colonel Frederick Lucius Johnson, Colonel Johnson]"],"summary":"Miller obtains coordinates for Thoth Station, a secret Protogen facility linked to the protomolecule's research, forcing Holden's crew to confront the existential threat of a potential alien weapon."}],"summary":"Miller secures coordinates for Thoth Station, a secret Belt ops facility, and collaborates with the OPA to plan its assault. He prepares to leave the Rocinante, reflecting on his role in the growing conflict between Belters and inner planets forces."},"model":"qwen3:8b","appVersion":"0.1.0"},{"index":43,"result":{"characters":[{"name":"Juliette Andromeda Mao","aliases":["Julie Mao"],"importance":"main","status":"dead","lastSeen":"Chapter Twenty-Four: Miller","currentLocation":"Eros flophouse","description":"A captured crew member held in a storage locker, enduring eight days of isolation and dehydration while planning her escape. She discovers the ship's reactor has been replaced with an alien entity.","relationships":[{"character":"Dave","relationship":"Shipmate"},{"character":"Captain Darren","relationship":"Captain"},{"character":"Mike","relationship":"Shipmate"},{"character":"Wan Li","relationship":"Shipmate"},{"character":"Mao-Kwikowski Mercantile","relationship":"Family"},{"character":"Captain Shaddid","relationship":"Client"},{"character":"Detective Miller","relationship":"Target of search"}],"recentEvents":"Discovered dead in shower stall with severe biological modifications"},{"name":"Dave","aliases":[],"importance":"secondary","status":"dead","lastSeen":"Prologue: Julie","currentLocation":"Unknown","description":"Julie's shipmate and mechanic, who begged the captors not to take Julie before being thrown out an airlock.","relationships":[{"character":"Julie Mao","relationship":"Shipmate"}],"recentEvents":"Begged captors to spare Julie, was thrown out an airlock, and died."},{"name":"Captain Darren","aliases":[],"importance":"secondary","status":"dead","lastSeen":"Prologue: Julie","currentLocation":"Engineering deck","description":"The ship's captain who surrendered to the attackers without resistance, later found as a head fused to the alien reactor.","relationships":[{"character":"Julie Mao","relationship":"Captain"}],"recentEvents":"Surrendered to attackers, died after being part of the alien entity's fusion reactor."},{"name":"Mike","aliases":[],"importance":"secondary","status":"unknown","lastSeen":"Prologue: Julie","currentLocation":"Unknown","description":"A shipmate captured by the attackers along with others.","relationships":[{"character":"Julie Mao","relationship":"Shipmate"}],"recentEvents":"Captured by the attackers and taken off the ship."},{"name":"Wan Li","aliases":[],"importance":"secondary","status":"unknown","lastSeen":"Prologue: Julie","currentLocation":"Unknown","description":"A shipmate captured by the attackers along with others.","relationships":[{"character":"Julie Mao","relationship":"Shipmate"}],"recentEvents":"Captured by the attackers and taken off the ship."},{"name":"The Attackers","aliases":[],"importance":"secondary","status":"unknown","lastSeen":"Prologue: Julie","currentLocation":"Unknown","description":"The captors who took control of the ship, beat the crew, and sealed the ship's systems.","relationships":[{"character":"Julie Mao","relationship":"Captors"}],"recentEvents":"Captured the crew, sealed the ship, and replaced the reactor with an alien entity."},{"name":"Jim Holden [aliases: James Holden, Holden]","aliases":["James Holden","Holden","Jim Holden"],"importance":"main","status":"alive","lastSeen":"Chapter Thirty-Nine: Holden","currentLocation":"Thoth Station (Rocinante)","description":"Executive officer of the Canterbury, a colony transport ship. A former Earth navy officer with a cynical view of Belters and their physiology.","relationships":[{"character":"Naomi Nagata","relationship":"Close ally, whose perspective influences Holden's decisions"},{"character":"Ade Tukunbo","relationship":"Romantic interest"},{"character":"Captain McDowell","relationship":"Former commanding officer"},{"character":"Alex Kamal","relationship":"Crewmate and engineer"},{"character":"Amos Burton","relationship":"Crewmate and weapons expert"},{"character":"Shed Garvey","relationship":"Crew member"},{"character":"Captain Theresa Yao","relationship":"Debriefed by Martian naval officer"},{"character":"Kelly","relationship":"Crewmate (deceased)"},{"character":"Fred Johnson [aliases: Colonel Frederick Lucius Johnson, Colonel Johnson]","relationship":"Business associate"},{"character":"Detective Miller","relationship":"Debates with Miller about broadcasting the protomolecule data"},{"character":"Miller","relationship":"Crewmate and former detective"}],"recentEvents":"Survived a fighter attack on the Rocinante, coordinated with Fred Johnson for docking"},{"name":"Naomi Nagata [aliases: Naomi]","aliases":["Naomi","Naomi Nagata"],"importance":"main","status":"alive","lastSeen":"Chapter Thirty-Nine: Holden","currentLocation":"Thoth Station (Rocinante)","description":"Medical officer who tends to Miller and Holden. Engages in a tense conversation with Holden about his feelings for her.","relationships":[{"character":"Jim Holden","relationship":"Commander and romantic interest"},{"character":"Amos Burton","relationship":"Subordinate"},{"character":"Alex Kamal","relationship":"Crew member"},{"character":"Kelly","relationship":"Crewmate (deceased)"},{"character":"Fred Johnson [aliases: Colonel Frederick Lucius Johnson, Colonel Johnson]","relationship":"Business associate"},{"character":"Detective Miller","relationship":"Fought alongside during ambush"},{"character":"Miller","relationship":"Crewmate and former detective"}],"recentEvents":"Survived a near-miss cannon strike, assisted in communication with Fred Johnson"},{"name":"Amos Burton","aliases":["Amos"],"importance":"main","status":"alive","lastSeen":"Chapter Thirty-Nine: Holden","currentLocation":"Thoth Station (Rocinante)","description":"Earthborn assistant to Naomi Nagata. Known for his loud personality and loyalty to Naomi.","relationships":[{"character":"Naomi Nagata","relationship":"Subordinate"},{"character":"Jim Holden","relationship":"Companion on the mission"},{"character":"Alex Kamal","relationship":"Crew member"},{"character":"Fred Johnson [aliases: Colonel Frederick Lucius Johnson, Colonel Johnson]","relationsh
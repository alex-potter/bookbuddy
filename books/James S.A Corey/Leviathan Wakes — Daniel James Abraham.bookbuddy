estruction.","relationships":[{"character":"Jim Holden","relationship":"Crew member"},{"character":"Naomi Nagata","relationship":"Crew member"},{"character":"Amos Burton","relationship":"Crew member"},{"character":"Shed Garvey","relationship":"Crew member"}],"recentEvents":"Analyzed the comm transmission, discussed the OPA contact, and evaluated the threat from approaching ships."},{"name":"Dmitri Havelock","aliases":["Havelock"],"importance":"main","status":"alive","lastSeen":"Chapter Ten: Miller","currentLocation":"Ceres","description":"Miller's partner, a cynical detective navigating the complexities of Ceres Station's law enforcement.","relationships":[{"character":"Detective Miller","relationship":"Partner"},{"character":"Miller","relationship":"Partner"},{"character":"Captain Shaddid","relationship":"Superior"}],"recentEvents":"Assisted Miller in the hardware shop investigation, observed OPA activity, and witnessed Mateo Judd's murder."},{"name":"Hasini","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter Four: Miller","currentLocation":"Ceres","description":"Assistant manager of the Blue Frog, a portside bar on Ceres, who interacted with Detective Miller.","relationships":[],"recentEvents":"Provided information about Havelock's presence at the Blue Frog and facilitated Miller's encounter with him."},{"name":"Brown","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter Six: Miller","currentLocation":"Ceres","description":"Security officer with SWAT experience, leading crowd control wings.","relationships":[],"recentEvents":"Part of Miller's riot squad, led during the mob confrontation."},{"name":"Gelbfish","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter Six: Miller","currentLocation":"Ceres","description":"Security officer with SWAT experience, part of Miller's team.","relationships":[],"recentEvents":"Identified the shirtless man's OPA tattoo, participated in crowd control."},{"name":"Aberforth","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter Six: Miller","currentLocation":"Ceres","description":"Security officer with a history of excessive violence, placed in second-string role.","relationships":[],"recentEvents":"Assigned to secondary roles due to past disciplinary issues."},{"name":"Yevgeny","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter Six: Miller","currentLocation":"Ceres","description":"Homicide detective who commented on government offices during the crisis.","relationships":[],"recentEvents":"Mentioned the government's infrastructure status during Shaddid's briefing."},{"name":"Shirtless Man","aliases":[],"importance":"minor","status":"alive","lastSeen":"Chapter Eight: Miller","currentLocation":"Ceres","description":"A former suspect in a crime, now in Star Helix detainment infirmary preparing for trial.","relationships":[],"recentEvents":"Mentioned in context of Ceres Station's ongoing legal cases"},{"name":"OPA Man","aliases":[],"importance":"minor","status":"alive","lastSeen":"Chapter Ten: Miller","currentLocation":"Ceres","description":"An OPA representative with a pock-marked face, engaged in a tense conversation with Miller about OPA's role.","relationships":[{"character":"Detective Miller","relationship":"OPA contact"}],"recentEvents":"Discussed OPA's economic terrorism claims, denied involvement in Mateo Judd's death, and warned Miller to stay away."},{"name":"Wallace Fitz","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter Seven: Holden","currentLocation":"Saturn Station","description":"P and K legal counsel who issued formal orders to Holden and his crew.","relationships":[{"character":"Jim Holden","relationship":"Legal contact"}],"recentEvents":"Delivered official response to Holden's request for assistance, accused Holden of unfounded Martian accusations."},{"name":"Captain Theresa Yao","aliases":[],"importance":"main","status":"alive","lastSeen":"Chapter Seven: Holden","currentLocation":"MCRN Donnager","description":"Commander of the MCRN Donnager, tasked with intercepting Holden's ship.","relationships":[{"character":"Jim Holden","relationship":"Designated contact"}],"recentEvents":"Ordered Holden's ship to follow a specific course toward the Jupiter system."},{"name":"Masked Woman","aliases":["Woman"],"importance":"minor","status":"alive","lastSeen":"Chapter Eight: Miller","currentLocation":"Ceres","description":"Victim beaten to death by the shirtless man, identified as a Martian freight line employee.","relationships":[],"recentEvents":"Featured in Miller's terminal screen as part of OPA propaganda"},{"name":"Fred Johnson","aliases":[],"importance":"main","status":"alive","lastSeen":"Chapter Nine: Holden","currentLocation":"Unknown","description":"Colonel and leader of the Outer Planets Alliance, contacting Holden about potential Martian threats.","relationships":[{"character":"Jim Holden","relationship":"Contacted via comm"}],"recentEvents":"Sent a comm message warning Holden about potential Martian coercion and offering assistance."},{"name":"Mateo Judd","aliases":[],"importance":"main","status":"dead","lastSeen":"Chapter Ten: Miller","currentLocation":"Ceres","description":"A dockworker accused of running an extortion scheme, later found dead with OPA ties.","relationships":[{"character":"Asher Kamamatsu","relationship":"Client"}],"recentEvents":"Sought protection from the OPA, was killed by OPA operatives after Miller's investigation."}],"locations":[{"name":"Scopuli","aliases":["Scopuli"],"arc":"Julie's Survival and Escape","description":"A large, heavily modified transport ship serving as the primary setting for the events.","recentEvents":"Julie Mao was captured and held in a storage locker aboard the ship. She later escapes and explores the ship's decks, discovering the reactor's corrupted state.","relationships":[{"location":"Engineering deck","relationship":"Contains the ship's reactor and is the site of critical discoveries"},{"location":"Inner airlock","relationship":"Where Julie was initially confined and later accessed after escaping"}]},{"name":"Engineering deck","aliases":["Engineering deck"],"arc":"Julie's Survival and Escape","description":"The ship's core area housing the fusion reactor and critical systems.","recentEvents":"Julie discovers the reactor's corrupted state, with biological material fused to its core. Captain Darren's head is found here.","relationships":[{"location":"Scopuli","relationship":"Central operational area of the ship"}]},{"name":"Inner airlock","aliases":["Inner airlock"],"description":"A sealed compartment connecting different sections of the ship.","recentEvents":"Julie was confined here for eight days before escaping. It served as a transition point between decks.","relationships":[{"location":"Scopuli","relationship":"Structural component of the ship"}]},{"name":"Canterbury","aliases":["Knight","Knight-class ship"],"arc":"OPA's Protective Role and Belt Security Crisis","description":"A P and K shuttle craft carrying Jim Holden and his crew after the Canterbury's destruction.","recentEvents":"Holden's crew debates their next move, receives orders to travel to Jupiter, and prepares to evade pursuers.","relationships":[{"location":"Belt","relationship":"Travels between Saturn's rings and this region"},{"location":"Canterbury","relationship":"Adjacent spaceport for departure/arrival"},{"location":"CA-2216862","relationship":"Target location for salvage mission"},{"location":"MCRN Donnager","relationship":"Target of their flight path"}]},{"name":"Belt","aliases":["Asteroid Belt"],"arc":"Julie's Survival and Escape","description":"The region of space where the Canterbury and other ships operate, containing numerous asteroids and debris.","recentEvents":"The Canterbury was destroyed here by a nuclear weapon fired by a stealth ship. Holden and the Knight crew pursued the attackers while hiding behind an asteroid.","relationships":[{"location":"Callisto","relationship":"Adjacent to a charted non-Belt asteroid"},{"location":"Canterbury","relationship":"Destroyed in this region"},{"location":"Knight","relationship":"Survived here after the Canterbury's destruction"}]},{"name":"Callisto","description":"A non-Belt asteroid where a damaged Martian freighter sent an emergency signal.","recentEvents":"The Canterbury diverted its route to investigate the distress beacon near this location.","relationships":[{"location":"Belt","relationship":"Located near the asteroid belt"}]},{"name":"Eros","description":"A celestial body serving as the home port of the damaged Martian freighter.","recentEvents":"The freighter, registered to Eros, sent an emergency signal requiring aid.","relationships":[{"location":"Canterbury","relationship":"Home port of the freighter the Canterbury is responding to"}]},{"name":"Ceres Station","aliases":["Ceres Port","Ceres"],"arc":"Julie's Survival and Escape","description":"A massive space station in the asteroid belt, serving as a hub for trade and conflict between Belters and Earthlings.","recentEvents":"Miller and his team quell a riot sparked by Holden's broadcast about a Martian battery, confronting OPA agents and a violent mob.","relationships":[{"location":"Belt","relationship":"Central to Ceres' economic role as a transit point for Belt resources"},{"location":"Tycho Station","relationship":"Connected via trade routes and shared security concerns"},{"location":"Port Level","relationship":"Key area where the riot occurs"},{"location":"Station House","relationship":"Administrative center where security directives are issued"}]},{"name":"Tycho Station","aliases":["Tycho"],"description":"Corporate station serving as a hub between the Belt and inner planets, known for its interplanetary transport operations.","recentEvents":"Julie Mao's last known employment and her apartment's network partition were linked to this station.","relationships":[{"location":"Ceres","relationship":"Serves as a key waypoint for cargo and passenger traffic between the Belt and inner systems"}]},{"name":"CA-2216862","aliases":["Asteroid 2216862"],"description":"A half-kilometer-wide asteroid in the asteroid belt, serving as a gravitational anchor for the Scopuli.","recentEvents":"The Scopuli was deliberately positioned near this asteroid, likely to exploit its microgravity for slow orbital capture.","relationships":[{"location":"Scopuli","relationship":"Gravitational anchor point"},{"location":"Belt","relationship":"Located within the asteroid belt"}]},{"name":"Port Level","description":"A bustling industrial area of Ceres Station where ships dock and cargo is handled, marked by high gravity and constant activity.","recentEvents":"Miller's squad confronts a violent mob, including an OPA-linked killer, to prevent the riot from escalating.","relationships":[{"location":"Ceres Station","relationship":"A distinct sector within the station"}]},{"name":"MCRN Donnager","aliases":["Donnager"],"description":"A Martian Congressional Republic Navy battleship dispatched to intercept the Knight.","recentEvents":"Ordered to pick up the Knight crew, with a 13-day arrival window.","relationships":[{"location":"Saturn Station","relationship":"Origin of the order"},{"location":"Jupiter","relationship":"Destination for the Knight"}]},{"name":"Saturn Station","aliases":["Saturn Station"],"description":"A Martian-controlled space station where P and K legal counsel issued directives.","recentEvents":"Wallace Fitz communicated the order to head to Jupiter, escalating tensions with Mars.","relationships":[{"location":"Knight","relationship":"Source of the crew's orders"},{"location":"Ceres Station","relationship":"Previously mentioned in crew discussions"}]},{"name":"Jupiter","aliases":["Jupiter"],"description":"A gas giant and strategic destination for the Knight crew's flight path.","recentEvents":"Selected as a potential destination despite risks from unknown pursuers.","relationships":[{"location":"Belt","relationship":"Geographically adjacent region"},{"location":"MCRN Donnager","relationship":"Target location for the ship"}]},{"name":"Razorback","aliases":["Razorback"],"description":"A private racing vessel associated with the Mao family, symbolizing Julie Mao's past and the family's financial influence.","recentEvents":"Julie Mao's messages reveal her family's attempt to coerce her to return, referencing the ship's potential sale and its significance to her.","relationships":[{"location":"Ceres Station","relationship":"The Razorback is mentioned as a vessel tied to the Mao family's operations on Ceres."}]},{"name":"Anderson Station","aliases":["Anderson"],"description":"A minor Belt distribution station for water and air, infamous for the Massacre that made Fred Johnson a Belter hero.","recentEvents":"Fred Johnson's broadcast reveals the station's history as a site of Coalition brutality, framing it as a catalyst for OPA resistance.","relationships":[{"location":"Belt","relationship":"Part of the asteroid belt's contested regions"},{"location":"MCRN Donnager","relationship":"Johnson's message hints at potential Martian involvement in the current conflict"}]}],"arcs":[{"name":"Julie's Survival and Escape","status":"active","characters":["Julie Mao","Detective Miller","OPA"],"summary":"Miller's investigation into Mateo Judd's OPA ties reveals Julie Mao's father may have been complicit in OPA operations, linking her disappearance to broader Belt security tensions. Miller's personal connection to Julie's cryptic warnings deepens as he uncovers OPA's dual role as both oppressor and protector."},{"name":"OPA's Protective Role and Belt Security Crisis","status":"active","characters":["Martian Navy","OPA","Ceres Station","Jim Holden"],"summary":"The OPA's propaganda and Julie's warning about the Belt's safety intertwine with the Martian Navy's covert operations, escalating tensions between Earth, Mars, and the Belt."},{"name":"Martian Navy, OPA, and Belt Security Crisis","status":"active","characters":["OPA","Martian Congressional Republic","Belters","Detective Miller"],"summary":"Miller discovers the OPA is actively countering inner-planet economic exploitation of Belters, not merely engaging in criminal activity. This revelation complicates the security crisis, as the OPA's actions blur lines between protection and oppression, with implications for Julie's disappearance and the Belt's stability."}],"summary":"Detective Miller investigates a protection racket on Ceres Station, uncovering ties between the OPA and organized crime. After questioning a hardware shop manager, he traces the suspect Mateo Judd to the John Rock Gentlemen's Club, where he encounters an OPA operative. Judd is later found dead, and Miller suspects the OPA is targeting cops rather than criminals, linking the case to Julie Mao's disappearance and broader Belt-planet tensions. The chapter ends with Miller realizing the conspiracy is more complex than initially thought."},"model":"qwen3:8b","appVersion":"0.1.0"},{"index":15,"result":{"characters":[{"name":"Julie Mao","aliases":["Juliette Andromeda Mao"],"importance":"main","status":"unknown","lastSeen":"Chapter Eight: Miller","currentLocation":"Unknown","description":"A captured crew member held in a storage locker, enduring eight days of isolation and dehydration while planning her escape. She discovers the ship's reactor has been replaced with an alien entity.","relationships":[{"character":"Dave","relationship":"Shipmate"},{"character":"Captain Darren","relationship":"Captain"},{"character":"Mike","relationship":"Shipmate"},{"character":"Wan Li","relationship":"Shipmate"},{"character":"Mao-Kwikowski Mercantile","relationship":"Family"},{"character":"Captain Shaddid","relationship":"Client"}],"recentEvents":"Miller accessed her digital files, discovered personal correspondence and OPA affiliations"},{"name":"Dave","aliases":[],"importance":"secondary","status":"dead","lastSeen":"Prologue: Julie","currentLocation":"Unknown","description":"Julie's shipmate and mechanic, who begged the captors not to take Julie before being thrown out an airlock.","relationships":[{"character":"Julie Mao","relationship":"Shipmate"}],"recentEvents":"Begged captors to spare Julie, was thrown out an airlock, and died."},{"name":"Captain Darren","aliases":[],"importance":"secondary","status":"dead","lastSeen":"Prologue: Julie","currentLocation":"Engineering deck","description":"The ship's captain who surrendered to the attackers without resistance, later found as a head fused to the alien reactor.","relationships":[{"character":"Julie Mao","relationship":"Captain"}],"recentEvents":"Surrendered to attackers, died after being part of the alien entity's fusion reactor."},{"name":"Mike","aliases":[],"importance":"secondary","status":"unknown","lastSeen":"Prologue: Julie","currentLocation":"Unknown","description":"A shipmate captured by the attackers along with others.","relationships":[{"character":"Julie Mao","relationship":"Shipmate"}],"recentEvents":"Captured by the attackers and taken off the ship."},{"name":"Wan Li","aliases":[],"importance":"secondary","status":"unknown","lastSeen":"Prologue: Julie","currentLocation":"Unknown","description":"A shipmate captured by the attackers along with others.","relationships":[{"character":"Julie Mao","relationship":"Shipmate"}],"recentEvents":"Captured by the attackers and taken off the ship."},{"name":"The Attackers","aliases":[],"importance":"secondary","status":"unknown","lastSeen":"Prologue: Julie","currentLocation":"Unknown","description":"The captors who took control of the ship, beat the crew, and sealed the ship's systems.","relationships":[{"character":"Julie Mao","relationship":"Captors"}],"recentEvents":"Captured the crew, sealed the ship, and replaced the reactor with an alien entity."},{"name":"Jim Holden","aliases":["James Holden","Holden"],"importance":"main","status":"alive","lastSeen":"Chapter Eleven: Holden","currentLocation":"Donnager","description":"Executive officer of the Canterbury, a colony transport ship. A former Earth navy officer with a cynical view of Belters and their physiology.","relationships":[{"character":"Naomi Nagata","relationship":"Commander and close ally"},{"character":"Ade Tukunbo","relationship":"Romantic interest"},{"character":"Captain McDowell","relationship":"Former commanding officer"},{"character":"Alex Kamal","relationship":"Crewmate and engineer"},{"character":"Amos Burton","relationship":"Crewmate and weapons expert"},{"character":"Shed Garvey","relationship":"Crew member"},{"character":"Captain Theresa Yao","relationship":"Debriefed by Martian naval officer"}],"recentEvents":"Docked with the Donnager, interrogated by Lieutenant Lopez, survived a torpedo attack, and witnessed Shed Garvey's death."},{"name":"Naomi Nagata","aliases":[],"importance":"main","status":"alive","lastSeen":"Chapter One: Holden","currentLocation":"Canterbury","description":"Chief engineer of the Canterbury. A Belter with a sharp demeanor and a reputation for technical expertise.","relationships":[{"character":"Jim Holden","relationship":"Superior officer"},{"character":"Amos Burton","relationship":"Subordinate"}],"recentEvents":"Diagnosed and repaired the Knight's landing gear, interacted with Holden and Amos Burton."},{"name":"Amos Burton","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter One: Holden","currentLocation":"Canterbury","description":"Earthborn assistant to Naomi Nagata. Known for his loud personality and loyalty to Naomi.","relationships":[{"character":"Naomi Nagata","relationship":"Subordinate"}],"recentEvents":"Assisted Naomi Nagata with a damaged cable on the hangar deck."},{"name":"Shed Garvey","aliases":["Shed"],"importance":"secondary","status":"dead","lastSeen":"Chapter Eleven: Holden","currentLocation":"Donnager","description":"Medical tech responsible for treating injured crew members. Known for using medical maggots in procedures.","relationships":[{"character":"Cameron Paj","relationship":"Patient"},{"character":"Jim Holden","relationship":"Crew member"},{"character":"Naomi Nagata","relationship":"Crew member"},{"character":"Alex Kamal","relationship":"Crew member"}],"recentEvents":"Died instantly from a gauss round fired during the Donnager's engagement with the Belt ships."},{"name":"Cameron Paj","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter Five: Holden","currentLocation":"Knight","description":"Crew member who lost his left arm in an ice-related accident. Uses a prosthetic limb.","relationships":[{"character":"Shed Garvey","relationship":"Crewmate"}],"recentEvents":"Implied to have an injured arm, mentioned by Shed during the aftermath."},{"name":"Ade Tukunbo","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter Five: Holden","currentLocation":"Knight","description":"Navigator with a Nigerian accent and a fondness for music. Has a flirtatious relationship with Holden.","relationships":[{"character":"Jim Holden","relationship":"Romantic interest"}],"recentEvents":"Attempted to power up the Knight's drive, survived the nuke blast, communicated with Holden during the crisis."},{"name":"Rebecca Byers","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter One: Holden","currentLocation":"Canterbury","description":"Comm officer with a sharp appearance and a history of legal troubles. Handles emergency communications.","relationships":[{"character":"Captain McDowell","relationship":"Subordinate"}],"recentEvents":"Received and relayed the emergency signal from an unknown ship."},{"name":"Captain McDowell","aliases":[],"importance":"main","status":"alive","lastSeen":"Chapter Five: Holden","currentLocation":"Knight","description":"Commanding officer of the Canterbury. A grizzled veteran with a distrust of corrective surgery.","relationships":[{"character":"Jim Holden","relationship":"Former subordinate"}],"recentEvents":"Gave Holden instructions for the broadcast operation"},{"name":"Detective Miller","aliases":["Miller"],"importance":"main","status":"alive","lastSeen":"Chapter Ten: Miller","currentLocation":"Ceres","description":"A seasoned detective working for Star Helix Security on Ceres, known for his poker skills and ability to interpret underworld slang.","relationships":[{"character":"Dmitri Havelock","relationship":"Partner"},{"character":"Captain Shaddid","relationship":"Superior"},{"character":"Juliette Andromeda Mao","relationship":"OPA contact"}],"recentEvents":"Investigated a hardware shop extortion case, discovered Mateo Judd's OPA ties, faced OPA threats, and uncovered a homicide."},{"name":"Captain Shaddid","aliases":[],"importance":"main","status":"alive","lastSeen":"Chapter Ten: Miller","currentLocation":"Ceres","description":"Commander of Star Helix Security on Ceres, known for her pragmatic approach and disdain for inner planet residents.","relationships":[{"character":"Miller","relationship":"Subordinate"},{"character":"Julie Mao","relationship":"Client"},{"character":"Detective Miller","relationship":"Superior"}],"recentEvents":"Assigned Miller to investigate a hardware shop extortion case, dismissed conspiracy theories about Mars."},{"name":"Alex Kamal","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter Eleven: Holden","currentLocation":"Donnager","description":"Crewmate and engineer, skeptical of Martian involvement in the Canterbury's destruction.","relationships":[{"character":"Jim Holden","relationship":"Crew member"},{"character":"Naomi Nagata","relationship":"Crew member"},{"character":"Amos Burton","relationship":"Crew member"},{"character":"Shed Garvey","relationship":"Crew member"}],"recentEvents":"Guided the Knight into the Donnager's docking bay and participated in the tense standoff with the Martian military."},{"name":"Dmitri Havelock","aliases":["Havelock"],"importance":"main","status":"alive","lastSeen":"Chapter Ten: Miller","currentLocation":"Ceres","description":"Miller's partner, a cynical detective navigating the complexities of Ceres Station's law enforcement.","relationships":[{"character":"Detective Miller","relationship":"Partner"},{"character":"Miller","relationship":"Partner"},{"character":"Captain Shaddid","relationship":"Superior"}],"recentEvents":"Assisted Miller in the hardware shop investigation, observed OPA activity, and witnessed Mateo Judd's murder."},{"name":"Hasini","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter Four: Miller","currentLocation":"Ceres","description":"Assistant manager of the Blue Frog, a portside bar on Ceres, who interacted with Detective Miller.","relationships":[],"recentEvents":"Provided information about Havelock's presence at the Blue Frog and facilitated Miller's encounter with him."},{"name":"Brown","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter Six: Miller","currentLocation":"Ceres","description":"Security officer with SWAT experience, leading crowd control wings.","relationships":[],"recentEvents":"Part of Miller's riot squad, led during the mob confrontation."},{"name":"Gelbfish","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter Six: Miller","currentLocation":"Ceres","description":"Security officer with SWAT experience, part of Miller's team.","relationships":[],"recentEvents":"Identified the shirtless man's OPA tattoo, participated in crowd control."},{"name":"Aberforth","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter Six: Miller","currentLocation":"Ceres","description":"Security officer with a history of excessive violence, placed in second-string role.","relationships":[],"recentEvents":"Assigned to secondary roles due to past disciplinary issues."},{"name":"Yevgeny","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter Six: Miller","currentLocation":"Ceres","description":"Homicide detective who 
ionships":[{"location":"Scopuli","relationship":"Structural component of the ship"}]},{"name":"Canterbury","aliases":["Knight"],"description":"A retooled colony transport ship hauling ice between Saturn's rings and the asteroid belt.","recentEvents":"The crew receives an emergency signal from a damaged Martian freighter near Callisto, prompting a course change.","relationships":[{"location":"Belt","relationship":"Travels between Saturn's rings and this region"}]},{"name":"Belt","description":"The asteroid belt, a vast region of space containing millions of celestial bodies and human settlements.","recentEvents":"The Canterbury and other ships traverse this region, encountering a damaged freighter near a non-Belt asteroid.","relationships":[{"location":"Callisto","relationship":"Adjacent to a charted non-Belt asteroid"}]},{"name":"Callisto","description":"A non-Belt asteroid where a damaged Martian freighter sent an emergency signal.","recentEvents":"The Canterbury diverted its route to investigate the distress beacon near this location.","relationships":[{"location":"Belt","relationship":"Located near the asteroid belt"}]},{"name":"Eros","description":"A celestial body serving as the home port of the damaged Martian freighter.","recentEvents":"The freighter, registered to Eros, sent an emergency signal requiring aid.","relationships":[{"location":"Canterbury","relationship":"Home port of the freighter the Canterbury is responding to"}]},{"name":"Ceres","description":"A destination in the asteroid belt, where the Canterbury is scheduled to deliver ice.","recentEvents":"The ship's route was altered to investigate the emergency signal instead of proceeding directly to Ceres.","relationships":[{"location":"Belt","relationship":"Located within the asteroid belt"}]}],"arcs":[{"name":"Julie's Survival and Escape","status":"active","characters":["Julie Mao","Dave","Captain Darren","Mike","Wan Li"],"summary":"Julie is trapped in a locker on the Scopuli after the ship is taken over by unknown attackers. She endures eight days of isolation, dehydration, and the trauma of her crew's apparent disappearance, culminating in her violent escape and discovery of the ship's eerie silence."},{"name":"The Scopuli's Attack and Abduction","status":"active","characters":["Julie Mao","The Attackers","Dave","Captain Darren","Mike","Wan Li"],"summary":"The Scopuli is seized by mysterious attackers who bypass standard protocols, leading to the crew's brutal abduction. The attack's unconventional methods and the ship's subsequent eerie emptiness hint at a larger, unresolved conspiracy."},{"name":"The Biotech Entity in Engineering","status":"active","characters":["Julie Mao","Captain Darren"],"summary":"Julie discovers a pulsating, flesh-like substance surrounding the reactor core in engineering, revealing the attackers' presence and suggesting a biotech horror that may have consumed the crew, with Captain Darren's severed head as a chilling clue."}],"summary":"The Canterbury, a ice-hauling ship, diverts its course toward a distress signal near Callisto after receiving an emergency beacon from a damaged Martian freighter. The crew debates whether to investigate, balancing legal obligations with the risks of diverting their mission to deliver ice to Ceres."},"model":"qwen3:8b","appVersion":"0.1.0"},{"index":6,"result":{"characters":[{"name":"Julie Mao","aliases":["Juliette Andromeda Mao"],"importance":"main","status":"unknown","lastSeen":"Chapter Two: Miller","currentLocation":"Unknown","description":"A captured crew member held in a storage locker, enduring eight days of isolation and dehydration while planning her escape. She discovers the ship's reactor has been replaced with an alien entity.","relationships":[{"character":"Dave","relationship":"Shipmate"},{"character":"Captain Darren","relationship":"Captain"},{"character":"Mike","relationship":"Shipmate"},{"character":"Wan Li","relationship":"Shipmate"},{"character":"Mao-Kwikowski Mercantile","relation